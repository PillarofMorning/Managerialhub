                                                    <Text size={200} color="neutralSecondary" block className="mb-4">Lead: {formatFullName(getField(ld, 'craa5_name'))}</Text>
                                                    <div className="grid grid-cols-1 md:grid-cols-[1fr_1fr_150px] gap-4">
                                                        <div className="flex flex-col gap-1"><Text size={200} weight="semibold">Current Status</Text><Input placeholder="Enter current status..." value={d.currentStatus || ""} onChange={(e:any, dObj:any) => setAreaDetails(p => ({...p, [aid]: { ...p[aid], currentStatus: getInputValue(e, dObj) }}))} /></div>
                                                        <div className="flex flex-col gap-1"><Text size={200} weight="semibold">Future / Notes</Text><Input placeholder="Enter future tasks or notes..." value={d.futureNotes || ""} onChange={(e:any, dObj:any) => setAreaDetails(p => ({...p, [aid]: { ...p[aid], futureNotes: getInputValue(e, dObj) }}))} /></div>
                                                        <div className="flex flex-col gap-1"><Text size={200} weight="semibold">% Complete</Text><select value={d.percent || ""} onChange={(e) => setAreaDetails(p => ({...p, [aid]: { ...p[aid], percent: e.target.value }}))} className="px-2 py-1 rounded border border-gray-300 h-8"><option value="">Select...</option>{Array.from({length: 21}, (_, i) => i * 5).map(v => <option key={v} value={v}>{v}%</option>)}</select></div>
                                                    </div>
                                                </div>
                                            );
                                        })}</div></div>
                                    );
                                })}
                            </div>
                        )}
                    </div>
                );
                break;
            case 5:
                const wsms = getShiftStartMs(currentShift), wtm = 24 * 3600000; const tbe: Record<string, any[]> = {};
                finalizeTasks.forEach(t => { const k = t.empName || "Unassigned"; if (!tbe[k]) tbe[k] = []; tbe[k].push(t); });
                SC = (
                    <div className="flex flex-col h-full p-5 overflow-hidden bg-white flex-1 box-border">
                        <div className="flex justify-between items-start mb-5 flex-wrap gap-3">
                            <div><Text as="h2" size={600} weight="semibold">Finalize & Time Tracking</Text><Text size={300} color="neutralSecondary" block className="mt-1">Review all assignments currently logged to your shift. Update start/stop times, correct areas, or add missed tasks.</Text></div>
                            <Button appearance="primary" onClick={handleAddFinalizeRow}>+ Add Entry</Button>
                        </div>
                        <datalist id="emp-list">{allEmployees.map(e => <option key={getField(e, 'craa5__aa_employeeid')} value={renderSafe(getField(e, 'craa5_name'))} />)}</datalist>
                        <datalist id="lead-list">{allEmployees.filter(e => String(getField(e, 'craa5_role')).includes('256000001') || String(getField(e, 'craa5_role')).includes('256000002')).map(e => <option key={getField(e, 'craa5__aa_employeeid')} value={renderSafe(getField(e, 'craa5_name'))} />)}</datalist>
                        <datalist id="area-list">{areas.map(a => <option key={getField(a, 'craa5_aa_mss_areaid')} value={renderSafe(getField(a, 'craa5_area'))} />)}</datalist>

                        {isFinalizeLoading ? <Spinner label="Fetching shift assignments..." className="my-10 mx-auto" /> : finalizeTasks.length === 0 ? <div className="text-center p-10 bg-gray-50 rounded-lg border border-dashed border-gray-300"><Text color="neutralSecondary">No assignments found for this shift.</Text></div> : (
                            <>
                                <div className="flex-[0_0_35%] min-h-[250px] border border-gray-300 rounded-lg mb-4 flex flex-col bg-white overflow-hidden">
                                    <div className="bg-gray-100 py-2 px-3 border-b border-gray-300 flex justify-between items-center"><Text weight="semibold">Gantt Timeline (Last 24h)</Text><Text size={200} color="neutralSecondary">Drag blocks to adjust start times.</Text></div>
                                    <div className="flex-1 overflow-y-auto flex flex-col custom-scrollbar">
                                        <div className="flex border-b border-gray-300 bg-gray-50 sticky top-0 z-20"><div className="w-[200px] shrink-0 p-2 border-r border-gray-300"><Text size={200} weight="bold">Employee</Text></div><div className="flex-1 flex relative">{Array.from({length: 12}).map((_, i) => <div key={i} className="flex-1 border-l border-gray-300 p-1 box-border"><Text size={100} color="neutralSecondary">{new Date(wsms + (i * 2 * 3600000)).getHours().toString().padStart(2, '0')}:00</Text></div>)}</div></div>
                                        {Object.entries(tbe).sort(([a],[b]) => a.localeCompare(b)).map(([en, tskList]) => (
                                            <div key={en} className="flex border-b border-gray-100 min-h-[40px]">
                                                <div className="w-[200px] shrink-0 p-2 border-r border-gray-300 bg-white flex items-center z-10"><Text size={200} weight="semibold" truncate>{en}</Text></div>
                                                <div className="flex-1 relative bg-gray-50 hover:bg-blue-50 transition-colors" onDragOver={(e) => e.preventDefault()} onDrop={(e) => handleGanttDrop(e, en === "Unassigned" ? "" : en)}>
                                                    <div className="absolute inset-0 flex pointer-events-none">{Array.from({length: 24}).map((_, i) => <div key={i} className={`flex-1 ${i % 2 === 0 ? 'border-l border-transparent' : 'border-l border-dashed border-gray-300'}`} />)}</div>
                                                    {tskList.map((tk: any) => {
                                                        const [dp] = tk.assignmentDateTime.split('T'), [y, mo, d] = dp.split('-').map(Number); let s = wsms, e = wsms + 3600000;
                                                        if (tk.startTime) { const [h, m] = tk.startTime.split(':').map(Number); s = new Date(y, mo - 1, d, h, m, 0).getTime(); }
                                                        if (tk.stopTime) { const [h, m] = tk.stopTime.split(':').map(Number); const end = new Date(y, mo - 1, d, h, m, 0); if (s && end.getTime() < s) end.setDate(end.getDate() + 1); e = end.getTime(); } else e = currentTime;
                                                        const cs = Math.max(wsms, s), ce = Math.min(wsms + wtm, e); if (cs >= wsms + wtm || ce <= wsms) return null;
                                                        const lp = ((cs - wsms) / wtm) * 100, wp = ((ce - cs) / wtm) * 100;
                                                        return (
                                                            <div key={tk.id} draggable={tk.isNew} onDragStart={(e) => { if (!tk.isNew) return; e.dataTransfer.setData("taskId", tk.id); e.dataTransfer.effectAllowed = "move"; }} className={`absolute top-1 bottom-1 rounded shadow-sm flex items-center px-1 overflow-hidden z-[5] ${tk.isComplete ? 'bg-green-100 border border-green-700' : 'bg-blue-100 border border-blue-600'} ${tk.isNew ? 'cursor-grab' : 'cursor-default'}`} style={{ left: `${lp}%`, width: `${Math.max(0.5, wp)}%` }} title={`${renderSafe(tk.area)}\n${tk.startTime} to ${tk.stopTime || 'Now'}`}>
                                                                <span className={`text-[10px] font-bold whitespace-nowrap overflow-hidden text-ellipsis ${tk.isComplete ? 'text-green-800' : 'text-blue-800'}`}>{renderSafe(tk.area)}</span>
                                                            </div>
                                                        );
                                                    })}
                                                </div>
                                            </div>
                                        ))}
                                    </div>
                                </div>
                                <div className="flex-1 overflow-auto border border-gray-300 rounded-lg custom-scrollbar">
                                    <table className="min-w-full border-collapse text-[13px] text-left">
                                        <thead className="sticky top-0 bg-gray-100 z-10 shadow-sm">
                                            <tr>{["Date/Time", "Lead", "ID / Employee Name", "Area", "Start Time", "Complete", "End Time", "Actions"].map(h => <th key={h} className={`p-3 font-semibold border-b border-gray-300 ${/Complete|Actions/.test(h) ? 'text-center' : 'text-left'}`}>{h}</th>)}</tr>
                                        </thead>
                                        <tbody className="bg-white">
                                            {finalizeTasks.map((r, i) => (
                                                <tr key={r.id} className={`border-b border-gray-100 ${r.isComplete ? 'bg-green-50/30' : 'bg-transparent'}`}>
                                                    <td className="p-2"><input type="datetime-local" value={r.assignmentDateTime} onChange={(e) => setFinalizeTasks(p => { const x=[...p]; x[i].assignmentDateTime = e.target.value; return x; })} className="w-full border border-gray-300 rounded p-1.5" /></td>
                                                    <td className="p-2"><input list="lead-list" value={r.leadName} onChange={(e) => setFinalizeTasks(p => { const x=[...p]; x[i].leadName = e.target.value; return x; })} className="w-full border border-gray-300 rounded p-1.5" placeholder="Lead" /></td>
                                                    <td className="p-2"><input list="emp-list" value={r.empName} onChange={(e) => setFinalizeTasks(p => { const x=[...p]; x[i].empName = e.target.value; return x; })} className="w-full border border-gray-300 rounded p-1.5" placeholder="Employee Name" /></td>
                                                    <td className="p-2"><input list="area-list" value={r.area} onChange={(e) => setFinalizeTasks(p => { const x=[...p]; x[i].area = e.target.value; return x; })} className="w-full border border-gray-300 rounded p-1.5" placeholder="Area" /></td>
                                                    <td className="p-2"><input type="time" value={r.startTime} disabled={!r.isNew} onChange={(e) => setFinalizeTasks(p => { const x=[...p]; x[i].startTime = e.target.value; return x; })} className={`w-full border border-gray-300 rounded p-1.5 ${r.isNew ? 'bg-white' : 'bg-gray-100 text-gray-500'}`} /></td>
                                                    <td className="p-2 text-center">
                                                        <label className="relative inline-flex items-center cursor-pointer">
                                                            <input type="checkbox" className="sr-only peer" checked={r.isComplete} onChange={(e) => setFinalizeTasks(p => { const x=[...p]; x[i].isComplete = e.target.checked; return x; })} />
                                                            <div className={`w-9 h-5 rounded-full relative transition-colors ${r.isComplete ? 'bg-blue-600' : 'bg-gray-300'}`}><div className={`absolute top-[2px] w-4 h-4 bg-white rounded-full transition-all shadow-sm ${r.isComplete ? 'left-[18px]' : 'left-[2px]'}`}></div></div>
                                                        </label>
                                                    </td>
                                                    <td className="p-2"><input type="time" value={r.stopTime} onChange={(e) => setFinalizeTasks(p => { const x=[...p]; x[i].stopTime = e.target.value; return x; })} className="w-full border border-gray-300 rounded p-1.5" /></td>
                                                    <td className="p-2 text-center whitespace-nowrap"><Button appearance="transparent" size="small" className="text-red-600 min-w-0 px-1 mr-1" onClick={() => handleDeleteFinalizeRow(i)}>✖</Button><Button appearance={r.isComplete ? "primary" : "outline"} size="small" className={r.isComplete ? "bg-blue-600 text-white min-w-0 px-2" : "min-w-0 px-2"} onClick={() => handleUpdateFinalizeRow(i)}>{r.isNew ? "Save" : "Update UID"}</Button></td>
                                                </tr>
                                            ))}
                                        </tbody>
                                    </table>
                                </div>
                            </>
                        )}
                    </div>
                );
                break;
        }
    }

    return (
        <div style={{ width: "100%", height: `${appHeight}px`, display: "flex", flexDirection: "column", background: "#FAFAFA", overflow: "hidden", position: 'relative' }}>
            {(isAuthenticating || isLoading) && (
                <div style={{ position: 'absolute', inset: 0, display: 'flex', flexDirection: 'column', alignItems: 'center', justifyContent: 'center', background: '#F3F2F1', zIndex: 9999, padding: '20px' }}>
                    <Spinner size="large" label={isAuthenticating ? "Authenticating..." : "Updating Dataverse..."} />
                    <div className="custom-scrollbar" style={{ width: '100%', maxWidth: '600px', height: '220px', background: '#1e1e1e', borderRadius: '8px', border: '1px solid #333', display: 'flex', flexDirection: 'column', overflow: 'hidden', marginTop: '24px' }}>
                        <div style={{ padding: '8px 16px', background: '#2d2d2d', borderBottom: '1px solid #333' }}><Text style={{ color: '#fff', fontSize: '13px', fontWeight: 'bold' }}>🚀 System Boot Logs</Text></div>
                        <div className="custom-scrollbar" style={{ flex: 1, padding: '12px 16px', overflowY: 'auto' }}>
                            {devLogs.length === 0 && <Text style={{ color: '#888', fontSize: '12px', fontStyle: 'italic' }}>Awaiting initialization...</Text>}
                            {devLogs.filter(l => l.category === 'payload' || l.category === 'error').map((l, i) => <div key={i} style={{ color: l.category === 'error' ? '#f48771' : '#4fc1ff', fontSize: '11px', fontFamily: 'monospace', marginBottom: '4px' }}><span style={{ color: '#888', marginRight: '8px' }}>[{l.timestamp.toLocaleTimeString()}]</span>{l.message}</div>)}
                        </div>
                    </div>
                    <Button appearance="secondary" style={{ marginTop: '24px', backgroundColor: '#fee', color: '#a00' }} onClick={() => { GLOBAL_INIT_STATUS = 'COMPLETE'; setIsAuthenticating(false); setIsLoading(false); setAdminMode(true); setIsDevConsoleOpen(true); }}>Emergency Force Unlock</Button>
                </div>
            )}
            
            <header style={{ flexShrink: 0, background: "#fff", padding: "0", zIndex: 100 }}>
                <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", padding: "12px 20px", borderBottom: "1px solid #E1DFDD" }}>
                    <div style={{ display: 'flex', gap: '4px', alignItems: 'center', background: '#F3F2F1', padding: '4px', borderRadius: '8px' }}>
                        {selectedSupervisorId && steps.map((l, i) => <Button key={l} appearance={currentStep === i ? "primary" : "subtle"} size="small" onClick={() => setCurrentStep(i)} style={{ borderRadius: '4px' }}>{l}</Button>)}
                    </div>
                    <div style={{ display: "flex", alignItems: "center", gap: "16px" }}>
                        {selectedSupervisorId && currentStep >= 2 && (
                            <div style={{ display: 'flex', alignItems: 'center', gap: '8px', background: '#F3F2F1', padding: '4px 8px', borderRadius: '6px' }}>
                                <select value={clipboardFormat} onChange={(e) => setClipboardFormat(e.target.value as any)} style={{ padding: '4px 8px', borderRadius: '4px', border: '1px solid #D1D1D1', fontSize: '12px', outline: 'none' }}><option value="headcount">Headcount</option><option value="initials">Initials</option><option value="fullname">Full Name</option></select>
                                <Button appearance="secondary" size="small" onClick={handleCopyToClipboard}>Copy</Button><div style={{ width: '1px', height: '16px', background: '#D1D1D1', margin: '0 4px' }} /><Button appearance="primary" size="small" onClick={handleSubmission}>{currentStep === 4 ? "Save Progress" : "Submit Assignments"}</Button>
                            </div>
                        )}
                        <div style={{ display: 'flex', alignItems: 'center', gap: '12px' }}>
                            {adminMode && (
                                <div style={{ display: 'flex', alignItems: 'center', background: '#FDE7E9', padding: '2px 8px', borderRadius: '4px', border: '1px solid #FBCED2' }}>
                                    <Text size={200} weight="semibold" style={{ color: '#A80000', marginRight: '6px' }}>View As:</Text>
                                    <select value={selectedSupervisorId || ""} onChange={(e) => setSelectedSupervisorId(e.target.value)} style={{ padding: '2px', borderRadius: '4px', border: '1px solid #FBCED2', fontSize: '12px', outline: 'none' }}><option value="" disabled>-- Select Supervisor --</option>{supervisors.map(s => <option key={getField(s, 'craa5__aa_employeeid')} value={getField(s, 'craa5__aa_employeeid')}>{formatFullName(getField(s, 'craa5_name'))}</option>)}</select>
                                </div>
                            )}
                            <div style={{ display: 'flex', alignItems: 'center', background: adminMode ? '#DFF6DD' : 'transparent', padding: '2px 8px', borderRadius: '4px', transition: 'background 0.2s', border: adminMode ? '1px solid #C3E6CB' : '1px solid transparent', gap: '4px' }}>
                                <Checkbox checked={adminMode} onChange={(e, d) => setAdminMode(!!d.checked)} /><Text size={200} weight={adminMode ? "semibold" : "regular"} style={{ color: adminMode ? '#107C10' : 'inherit', cursor: 'pointer' }} onClick={() => setAdminMode(!adminMode)}>Acting Sup.</Text>
                            </div><div style={{ width: '1px', height: '24px', background: '#E1DFDD' }} />
                            
                            {isTrueDev && (
                                <Button appearance={isDevConsoleOpen ? "primary" : "subtle"} size="small" onClick={() => setIsDevConsoleOpen(!isDevConsoleOpen)} style={{ fontWeight: 'bold' }}>
                                    <TerminalIcon style={{ width: 14, height: 14, marginRight: 4 }} /> Terminal
                                </Button>
                            )}

                            <Button appearance="transparent" size="small" style={{ cursor: 'default' }}>{selectedSupervisorId && msUser?.id !== selectedSupervisorId ? <Text size={200} weight="semibold">🕵️ {formatFullName(getField(activeSupervisorObj, 'craa5_name'))}</Text> : <Text size={200}>👤 {msUser ? msUser.name : "Booting..."}</Text>}</Button>
                            <Badge appearance="filled" color="informative">Shift {currentShift}</Badge>
                        </div>
                    </div>
                </div>
                {selectedSupervisorId && <ProgressBar value={(currentStep + 1) / steps.length} color={currentStep === steps.length - 1 ? "success" : "brand"} />}
            </header>
            
            <div style={{ flex: 1, display: 'flex', flexDirection: 'column', overflow: 'hidden', paddingBottom: '0px', transition: isResizing.current ? 'none' : 'padding-bottom 0.2s' }}>
                <main style={{ flex: 1, overflow: "hidden", display: "flex", flexDirection: "column", position: 'relative' }}>{SC}</main>
                
                {isDevConsoleOpen && (
                    <BottomDevConsole 
                        devLogs={devLogs} 
                        tableMetrics={tableMetrics} 
                        activeMemoryState={activeMemoryState} 
                        onClose={() => setIsDevConsoleOpen(false)} 
                        isMockMode={isMockMode} 
                        setIsMockMode={setIsMockMode} 
                        height={consoleHeight} 
                        startResize={() => { isResizing.current = true; }} 
                        clearLogs={() => { GLOBAL_LOGS = []; setDevLogs([]); }} 
                    />
                )}
            </div>
            
            {showMovePrompt && (
                <Dialog open={showMovePrompt} onOpenChange={(_, data) => setShowMovePrompt(data.open)}>
                    <DialogSurface style={{ maxWidth: '600px' }}>
                        <DialogTitle>Task Reassignment</DialogTitle>
                        <DialogBody>
                            <Text block style={{ marginBottom: 16 }}>The following employees have been moved to a new assignment. Please indicate if their previous task was completed, or log what work remains.</Text>
                            <div className="max-h-[400px] overflow-y-auto flex flex-col gap-4 custom-scrollbar">
                                {movedEmployeesList.map(m => (
                                    <div key={m.emp.craa5__aa_employeeid} className="p-3 bg-gray-100 rounded-lg border border-gray-200">
                                        <Text weight="bold" block>{formatFullName(getField(m.emp, 'craa5_name'))}</Text>
                                        <Text size={200} block color="neutralSecondary">Moved from: {m.oldArea} to {m.newArea}</Text>
                                        <div className="flex gap-4 mt-2 items-center">
                                            <div className="flex items-center gap-2"><Checkbox checked={movePromptForm[m.emp.craa5__aa_employeeid]?.isComplete} onChange={(e, d) => setMovePromptForm(p => ({...p, [m.emp.craa5__aa_employeeid]: { ...p[m.emp.craa5__aa_employeeid], isComplete: !!d.checked }}))} /><Text className="cursor-pointer text-sm" onClick={() => setMovePromptForm(p => ({...p, [m.emp.craa5__aa_employeeid]: { ...p[m.emp.craa5__aa_employeeid], isComplete: !p[m.emp.craa5__aa_employeeid]?.isComplete }}))}>Task Complete?</Text></div>
                                            <Input placeholder="What work remains?" disabled={movePromptForm[m.emp.craa5__aa_employeeid]?.isComplete} value={movePromptForm[m.emp.craa5__aa_employeeid]?.workRemains || ""} onChange={(e, d) => setMovePromptForm(p => ({...p, [m.emp.craa5__aa_employeeid]: { ...p[m.emp.craa5__aa_employeeid], workRemains: String(d.value) }}))} className="flex-1" />
                                        </div>
                                    </div>
                                ))}
                            </div>
                        </DialogBody>
                        <DialogActions>
                            <Button appearance="secondary" onClick={() => { setShowMovePrompt(false); setIsLoading(false); }}>Cancel</Button>
                            <Button appearance="primary" onClick={() => executeSubmission(movedEmployeesList, newEmployeesList, unchangedEmployeesList, movePromptForm)}>Confirm & Submit</Button>
                        </DialogActions>
                    </DialogSurface>
                </Dialog>
            )}
        </div>
    );
}

const App = (props: any) => <MainComponent {...props} />;
export default App;
