function copyTextToClipboard(text: string) { if (navigator.clipboard && window.isSecureContext) navigator.clipboard.writeText(text).catch(() => fallbackCopy(text)); else fallbackCopy(text); }
function fallbackCopy(text: string) { const ta = document.createElement("textarea"); ta.value = text; ta.style.cssText = "top:0;left:0;position:fixed;"; document.body.appendChild(ta); ta.focus(); ta.select(); try { document.execCommand('copy'); } catch (err) { globalAddLog('error', 'Fallback copy failed', err); } document.body.removeChild(ta); }
const asyncRace = async (p: any, ms: number, l: string) => { if (!p) return Promise.reject(new Error(`No query for ${l}`)); return Promise.race([Promise.resolve(p), new Promise((_, r) => setTimeout(() => r(new Error(`TIMEOUT: ${l}`)), ms))]); };
function safeGetXrm() { if (typeof window === 'undefined') return null; if ((window as any).Xrm) return (window as any).Xrm; try { if (window.parent && (window.parent as any).Xrm) return (window.parent as any).Xrm; } catch (e) {} return null; }
function getWebApi(props: any) { const xrm = safeGetXrm(); if (xrm?.WebApi) return xrm.WebApi; if (props?.context?.webAPI) return props.context.webAPI; return props?.webAPI || null; }
const getLocalYMD = (d: Date) => `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
const getLocalYMDHM = (d: Date) => `${getLocalYMD(d)}T${String(d.getHours()).padStart(2, '0')}:${String(d.getMinutes()).padStart(2, '0')}`;
const formatFullName = (n?: string | null) => { if (!n) return ""; const p = n.split(","); return p.length > 1 ? `${p.slice(1).join(",").trim()} ${p[0].trim()}` : n.trim(); };
const renderSafe = (v: any) => v === null || v === undefined ? "" : typeof v === 'object' ? String(v.Label || v.Value || v.name || JSON.stringify(v)) : String(v);

function normalizeShift(val: any): string {
    const s = String(val?.Label || val?.Value || val?.name || val || "").toUpperCase();
    if (/256000000|A/.test(s) || s === "A") return "A";
    if (/256000001|B/.test(s) || s === "B") return "B";
    if (/256000002|C/.test(s) || s === "C") return "C";
    if (/256000003|D/.test(s) || s === "D") return "D";
    return "";
}

function determineCurrentShift(): string {
    const d = new Date().getDay(), h = new Date().getHours();
    if (h >= 6 && h < 18) return (d === 0 || d <= 2 || (d === 3 && h < 12)) ? "A" : "C";
    // Shift B (Nights) aligns with Shift A (Days). 
    // B starts Sun (0), Mon (1), Tue (2) at 18:00+ 
    // and finishes Mon (1), Tue (2), Wed (3) at < 06:00
    return ((d >= 0 && d <= 2 && h >= 18) || (d >= 1 && d <= 3 && h < 6)) ? "B" : "D";
}

function getField(obj: any, fn: string) {
    if (!obj) return undefined; if (obj[fn] !== undefined) return obj[fn];
    const lf = fn.toLowerCase(), k = Object.keys(obj).find(x => x.toLowerCase() === lf);
    return k ? obj[k] : undefined;
}

const getFormattedField = (obj: any, fn: string) => getField(obj, `${fn}@OData.Community.Display.V1.FormattedValue`);
const isBoolTrue = (v: any) => v === true || v === 1 || String(v).toLowerCase() === "yes" || String(v).toLowerCase() === "true";
const isEmployeeUtilized = (e: any) => isBoolTrue(getField(e, 'craa5_utilized') ?? getFormattedField(e, 'craa5_Utilized'));
const isProductionArea = (a: any) => isBoolTrue(getField(a, 'craa5_production') ?? getFormattedField(a, 'craa5_production'));
const isEverydayArea = (a: any) => isBoolTrue(getField(a, 'craa5_everyday') ?? getFormattedField(a, 'craa5_everyday'));
const isStatusArea = (n?: string) => /pto|sick|late|left early/.test(String(n || "").toLowerCase().trim());
const getEmployeeEmail = (e: any) => getField(e, 'craa5_email') || getField(e, 'emailaddress1') || getField(e, 'internalemailaddress') || "";
const getEmployeeBadge = (e: any) => getField(e, 'craa5_badgenumber') || "";
const getShiftStartMs = (s: string) => { const d = new Date(), h = /A|C/.test(s) ? 6 : 18; d.setHours(h, 0, 0, 0); if (h >= 12 && new Date().getHours() < 12) d.setDate(d.getDate() - 1); return d.getTime(); };
const calculateCustomDuration = (start: string, stop: string) => {
    if (!start || !stop) return null; const [sh, sm] = start.split(':').map(Number), [eh, em] = stop.split(':').map(Number);
    let dm = (eh * 60 + em) - (sh * 60 + sm); if (dm < 0) dm += 24 * 60;
    return dm >= 60 ? `${Math.floor(dm/60)}h ${dm%60}m` : `${dm%60}m`;
};
const formatMsToDurationStr = (ms: number) => ms < 0 ? "0m" : `${Math.floor(ms/3600000) > 0 ? Math.floor(ms/3600000)+'h ' : ''}${Math.floor((ms%3600000)/60000)}m`;
const getInputValue = (e: any, d: any) => typeof d === 'string' ? d : d?.value ?? e?.target?.value ?? "";
const getSelectionValue = (e: any, d: any): Set<any> => d?.selectedItems ?? e?.target?.selectedItems ?? new Set();
const getCheckboxValue = (e: any, d: any) => typeof d === 'boolean' ? d : !!(d?.checked ?? e?.target?.checked);

// Dynamic Emoji Extractor
const getAreaEmoji = (areaObj: any) => { if (!areaObj) return ""; const em = getField(areaObj, 'craa5_emoji') || getFormattedField(areaObj, 'craa5_emoji'); return em ? ` ${em}` : ""; };

async function fetchFallbackRecords(entityNames: string | string[], dataApi: any, props: any, addLog?: any): Promise<any[]> {
    const webApi = getWebApi(props); const names = Array.isArray(entityNames) ? entityNames : [entityNames]; let lastError = null;
    for (const en of names) {
        if (addLog) addLog('payload', `[FETCH XML/ODATA] Requesting: ${en}`);
        if (webApi && !DEAD_APIS.has('WebApi')) {
            try { const res: any = await asyncRace(webApi.retrieveMultipleRecords(en, `?$filter=statecode eq 0&$top=5000`), 5000, `WebApi ${en}`); if (res?.entities) { if (addLog) addLog('payload', `[SUCCESS] Loaded ${res.entities.length} records for ${en} (WebApi)`); return res.entities; } } catch (e: any) { lastError = e; if (e.message.includes('TIMEOUT')) DEAD_APIS.add('WebApi'); }
        }
        if (dataApi?.queryTable && !DEAD_APIS.has('queryTable')) {
            try { const res: any = await asyncRace(dataApi.queryTable(en, { filter: "statecode eq 0", top: 5000 }), 5000, `queryTable ${en}`); if (res?.rows) { if (addLog) addLog('payload', `[SUCCESS] Loaded ${res.rows.length} records for ${en} (queryTable)`); return res.rows; } } catch (e: any) { lastError = e; if (e.message.includes('TIMEOUT')) DEAD_APIS.add('queryTable'); }
        }
    }
    if (lastError && addLog) addLog('error', `[FATAL] All fetch permutations failed for ${names[0]}`); return [];
}

