function AreaSelectionScreen({ areas, selectedAreaIds, onSelectChange, onAddCustomArea, onMarkNonEverydayComplete }: any) {
    const [searchText, setSearchText] = useState("");
    const [customText, setCustomText] = useState("");
    const filtered = areas.filter((a: any) => renderSafe(getField(a, 'craa5_area')).toLowerCase().includes(searchText.toLowerCase()));

    const assignedList = filtered.filter((a: any) => selectedAreaIds.has(getField(a, 'craa5_aa_mss_areaid')));
    const unassignedList = filtered.filter((a: any) => !selectedAreaIds.has(getField(a, 'craa5_aa_mss_areaid')));
    
    const productionList = unassignedList.filter((a: any) => isProductionArea(a));
    const supportingList = unassignedList.filter((a: any) => !isProductionArea(a));

    const handleDrop = (e: React.DragEvent, action: 'ASSIGN' | 'UNASSIGN') => {
        const areaId = e.dataTransfer?.getData("areaId") || GLOBAL_DRAG_PAYLOAD;
        if (!areaId) return;

        const newSelected = new Set(selectedAreaIds);
        if (action === 'ASSIGN') newSelected.add(areaId);
        else newSelected.delete(areaId);
        onSelectChange(newSelected);
        GLOBAL_DRAG_PAYLOAD = null;
    };

    const renderDraggableArea = (a: any) => {
        const aId = getField(a, 'craa5_aa_mss_areaid');
        return (
