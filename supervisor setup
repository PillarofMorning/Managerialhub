function normalizeShift(val: any): string {
    if (val === null || val === undefined) return "";
    let str = typeof val === 'object' ? String(val.Label || val.Value || val.name || "") : String(val);
    const upper = str.toUpperCase();
    if (upper.includes("256000000") || upper === "A" || upper.includes("SHIFT A")) return "A";
    if (upper.includes("256000001") || upper === "B" || upper.includes("SHIFT B")) return "B";
    if (upper.includes("256000002") || upper === "C" || upper.includes("SHIFT C")) return "C";
    if (upper.includes("256000003") || upper === "D" || upper.includes("SHIFT D")) return "D";
    
    if (upper.includes("A")) return "A";
    if (upper.includes("B")) return "B";
    if (upper.includes("C")) return "C";
    if (upper.includes("D")) return "D";
    return "";
}

function determineCurrentShift(): string {
    const now = new Date();
    const day = now.getDay(); 
    const hour = now.getHours();
    if (hour >= 6 && hour < 18) {
        if (day === 0 || day === 1 || day === 2) return "A";
        if (day === 4 || day === 5 || day === 6) return "C";
        if (day === 3) return hour < 12 ? "A" : "C"; 
    } else {
        if (hour >= 18) {
            if (day === 0 || day === 1 || day === 2 || day === 3) return "B"; 
            if (day === 4 || day === 5 || day === 6) return "D";              
        } else {
            if (day === 1 || day === 2 || day === 3) return "B";              
            if (day === 4 || day === 5 || day === 6 || day === 0) return "D"; 
        }
    }
    return "A";
}

function safeGetXrm() {
    if (typeof window === 'undefined') return null;
    if ((window as any).Xrm) return (window as any).Xrm;
    try { if (window.parent && window.parent !== window && (window.parent as any).Xrm) return (window.parent as any).Xrm; } catch (e) {}
    try { if (window.top && window.top !== window && (window.top as any).Xrm) return (window.top as any).Xrm; } catch (e) {}
    return null;
}

async function fetchAllActiveRecords(entityName: string, dataApi: any): Promise<any[]> {
    const xrm = safeGetXrm();
    
    if (xrm?.WebApi) {
        try {
            const fetchXml = `<fetch top='5000'><entity name='${entityName}'><all-attributes/><filter><condition attribute='statecode' operator='eq' value='0'/></filter></entity></fetch>`;
            const res = await xrm.WebApi.retrieveMultipleRecords(entityName, "?fetchXml=" + encodeURIComponent(fetchXml));
            if (res && res.entities) return res.entities;
        } catch (e) {
            console.warn(`FetchXML failed for ${entityName}, falling back...`, e);
        }
    }
    
    if (dataApi?.queryTable) {
        try {
            const res = await dataApi.queryTable(entityName, { filter: "statecode eq 0", top: 5000 });
            if (res && res.rows) return res.rows;
        } catch (e) {
            console.warn(`queryTable failed for ${entityName}`, e);
        }
    }
    
    return [];
}

function isEmployeeUtilized(e: any): boolean {
    if (!e) return false;
    const u = e.craa5_utilized ?? e.craa5_Utilized ?? e.Utilized ?? e.utilized ?? e["craa5_Utilized@OData.Community.Display.V1.FormattedValue"] ?? e["craa5_utilized@OData.Community.Display.V1.FormattedValue"];
    if (u === true || u === 1) return true;
    const str = String(typeof u === 'object' ? (u?.Label || u?.Value || "") : (u || "")).toLowerCase();
    return str === "yes" || str === "true" || str === "1";
}

function isEverydayArea(area: any): boolean {
    if (!area) return false;
    const val = area.craa5_everyday ?? area.craa5_Everyday ?? area.Everyday ?? area.everyday ?? area["craa5_everyday@OData.Community.Display.V1.FormattedValue"] ?? area["craa5_Everyday@OData.Community.Display.V1.FormattedValue"];
    if (val === true || val === 1) return true;
    const str = String(typeof val === 'object' ? (val?.Label || val?.Value || "") : (val || "")).toLowerCase();
    return str === "yes" || str === "true" || str === "1";
}

function isProductionArea(area: any): boolean {
    if (!area) return false;
    const val = area.craa5_production ?? area.craa5_Production ?? area.production ?? area["craa5_production@OData.Community.Display.V1.FormattedValue"] ?? area["craa5_Production@OData.Community.Display.V1.FormattedValue"];
    if (val === true || val === 1) return true;
    const str = String(typeof val === 'object' ? (val?.Label || val?.Value || "") : (val || "")).toLowerCase();
    return str === "yes" || str === "true" || str === "1";
}

function isStatusArea(areaName?: string): boolean {
    if (!areaName) return false;
    const lower = String(areaName).toLowerCase().trim();
    return ["pto", "sick", "late", "left early"].includes(lower);
}

function getEmployeeEmail(e: any): string {
    if (!e) return "";
    return e.craa5_email || e.craa5_Email || e.email || e.emailaddress1 || e.internalemailaddress || "";
}

function isAssetInArea(asset: any, areaName: string): boolean {
    if (!asset || !areaName) return false;
    const aName = (asset["_craa5_area_lookup_value@OData.Community.Display.V1.FormattedValue"] 
                || asset["craa5_areaname@OData.Community.Display.V1.FormattedValue"] 
                || asset.craa5_areaname 
                || asset.craa5_Area_Lookup 
                || "").toString().toLowerCase();
    return aName.includes(areaName.toLowerCase()) || areaName.toLowerCase().includes(aName);
}


