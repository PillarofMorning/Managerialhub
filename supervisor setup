function SupervisorDashboard({ currentUser, tasks, supervisorTasks, users, equipment, updateTask, updateSupervisorTask, createTasks, createSupervisorTask, logDebug }) {
    const { t } = useTranslation();
    const [activeTab, setActiveTab] = useState('team'); 
    useEffect(() => { logDebug(`[NAV] Supervisor Dashboard Tab Switched to: ${activeTab}`); }, [activeTab]);

    const todaysTasks = tasks.filter(taskObj => taskObj.logicalDate === currentUser.logicalDateContext && taskObj.shift === currentUser.shift);
    const shiftStaff = users.filter(u => u.shift === currentUser.shift && (u.role === 'employee' || u.role === 'lead'));
    const allLeads = shiftStaff.filter(u => u.role === 'lead');
    const allEmployees = shiftStaff.filter(u => u.role === 'employee');
    
    const staffLatestLead = {};
    shiftStaff.forEach(emp => {
        const empTasksToday = todaysTasks.filter(taskObj => taskObj.empId === emp.id);
        if (empTasksToday.length > 0) {
            empTasksToday.sort((a,b) => new Date(b.startTime).getTime() - new Date(a.startTime).getTime());
            staffLatestLead[emp.id] = empTasksToday[0].leadId;
        }
    });

    const activeLeads = allLeads.filter(lead => {
        const hasTeam = allEmployees.some(emp => staffLatestLead[emp.id] === lead.id);
        const hasSelfTask = todaysTasks.some(tTask => tTask.empId === lead.id);
        return hasTeam || hasSelfTask;
    });

    const unallocatedLeads = allLeads.filter(l => !activeLeads.includes(l));
    const unallocatedEmployees = allEmployees.filter(emp => !staffLatestLead[emp.id]);
    const totalUnallocated = unallocatedLeads.length + unallocatedEmployees.length;

    const activeTodos = supervisorTasks.filter(todo => !todo.isComplete && (!todo.assignedTo || todo.assignedTo.trim().toLowerCase() === (currentUser.email || '').trim().toLowerCase()));

    const handleAllocateToLead = (empId, leadId) => {
        createTasks([{ id: `task_${Date.now()}_${Math.random()}`, empId, leadId, equipId: null, equipNameFallback: "", area: "", status: 'assigned', startTime: new Date().toISOString(), beforePicture: null, afterPicture: null }]);
    };

    const handleAssignLeadSelfTask = (leadId, existingTask, type, val) => {
        const updates = type === 'custom' ? { equipId: null, equipNameFallback: val, area: 'Custom Task', status: 'working', startTime: new Date().toISOString() } : { equipId: val, equipNameFallback: equipment.find(e => e.id === val)?.name || "", area: equipment.find(e => e.id === val)?.area || "", status: 'working', startTime: new Date().toISOString() };
        if (existingTask && !['done', 'not_applicable', 'ended_incomplete'].includes(existingTask.status)) {
            if (!existingTask.equipId && !existingTask.equipNameFallback) updateTask(existingTask.id, updates);
            else {
                updateTask(existingTask.id, { status: 'done', isCompleteBool: true, inspectionTime: new Date().toISOString(), endTime: new Date().toISOString() });
                createTasks([{ id: `task_${Date.now()}_${Math.random()}`, empId: leadId, leadId: leadId, beforePicture: null, afterPicture: null, ...updates }]);
            }
        } else {
            createTasks([{ id: `task_${Date.now()}_${Math.random()}`, empId: leadId, leadId: leadId, beforePicture: null, afterPicture: null, ...updates }]);
        }
    };

    const allEquipByArea = equipment.reduce((acc, eq) => { const area = eq.area || 'Other Areas'; if (!acc[area]) acc[area] = []; acc[area].push(eq); return acc; }, {});

    return (
        <div className="flex flex-col h-full max-h-[calc(100vh-120px)]">
            <div className="flex space-x-1 bg-white p-1 rounded-lg shadow-sm border border-gray-200 mb-6 max-w-fit flex-shrink-0 overflow-x-auto">
                <button className={`px-6 py-2 rounded-md font-bold text-sm transition-colors flex items-center whitespace-nowrap ${activeTab === 'team' ? 'bg-blue-600 text-white' : 'text-gray-600 hover:bg-gray-100'}`} onClick={() => setActiveTab('team')}><Users className="w-4 h-4 mr-2" /> {t("My Team Allocation")}</button>
                <button className={`px-6 py-2 rounded-md font-bold text-sm transition-colors flex items-center whitespace-nowrap ${activeTab === 'todo' ? 'bg-purple-600 text-white' : 'text-gray-600 hover:bg-gray-100'}`} onClick={() => setActiveTab('todo')}><ClipboardList className="w-4 h-4 mr-2" /> {t("My To-Do")} {activeTodos.length > 0 && <span className="ml-2 bg-white/20 px-2 py-0.5 rounded-full text-xs">{activeTodos.length}</span>}</button>
                <button className={`px-6 py-2 rounded-md font-bold text-sm transition-colors flex items-center whitespace-nowrap ${activeTab === 'assign' ? 'bg-orange-600 text-white' : 'text-gray-600 hover:bg-gray-100'}`} onClick={() => setActiveTab('assign')}><PlusCircle className="w-4 h-4 mr-2" /> {t("Assign To-Do")}</button>
            </div>
            <div className="flex-1 overflow-y-auto custom-scrollbar pr-2 pb-6">
                {activeTab === 'team' && (
                    <div className="grid grid-cols-1 xl:grid-cols-3 gap-6">
                        <div className="xl:col-span-1">
                            <div className="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden sticky top-0">
                                <div className="bg-gray-800 px-6 py-4 text-white"><h2 className="text-lg font-semibold flex items-center"><Users className="w-5 h-5 mr-2" /> {t("Unallocated Staff")} ({totalUnallocated})</h2></div>
                                <div className="p-4 space-y-3 max-h-[400px] overflow-y-auto pr-2 custom-scrollbar">
                                    {totalUnallocated === 0 ? <p className="text-center text-gray-500 py-4">{t("All staff allocated for today!")}</p> : (
                                        <>
                                            {unallocatedLeads.length > 0 && (
                                                <div className="mb-4">
                                                    <h4 className="text-xs font-bold text-gray-400 uppercase tracking-wider mb-2 border-b border-gray-100 pb-1">{t("Leads")}</h4>
                                                    {unallocatedLeads.map(emp => (
                                                        <div key={emp.id} className="p-3 mb-2 border border-gray-200 rounded-lg bg-white shadow-sm hover:border-blue-300 transition-colors">
                                                            <p className="font-semibold text-gray-800 text-sm mb-2">{formatFullName(emp.name)}</p>
                                                            <select className="w-full text-xs border-gray-300 rounded-md p-1.5 border outline-none cursor-pointer bg-gray-50" onChange={(e) => { if (e.target.value) { handleAllocateToLead(emp.id, e.target.value); } e.target.value = ''; }} defaultValue="">
                                                                <option value="" disabled>{t("Assign to Lead...")}</option>
                                                                {allLeads.map(l => <option key={l.id} value={l.id}>{formatFullName(l.name)}</option>)}
                                                            </select>
                                                        </div>
                                                    ))}
                                                </div>
                                            )}
                                            {unallocatedEmployees.length > 0 && (
                                                <div>
                                                    <h4 className="text-xs font-bold text-gray-400 uppercase tracking-wider mb-2 border-b border-gray-100 pb-1">{t("Employees")}</h4>
                                                    {unallocatedEmployees.map(emp => (
                                                        <div key={emp.id} className="p-3 mb-2 border border-gray-200 rounded-lg bg-white shadow-sm hover:border-blue-300 transition-colors">
                                                            <p className="font-semibold text-gray-800 text-sm mb-2">{formatFullName(emp.name)}</p>
                                                            <select className="w-full text-xs border-gray-300 rounded-md p-1.5 border outline-none cursor-pointer bg-gray-50" onChange={(e) => { if (e.target.value) { handleAllocateToLead(emp.id, e.target.value); } e.target.value = ''; }} defaultValue="">
                                                                <option value="" disabled>{t("Assign to Lead...")}</option>
                                                                {allLeads.map(l => <option key={l.id} value={l.id}>{formatFullName(l.name)}</option>)}
                                                            </select>
                                                        </div>
                                                    ))}
                                                </div>
                                            )}
                                        </>
                                    )}
                                </div>
                            </div>
                        </div>
                        <div className="xl:col-span-2 space-y-6">
                            {activeLeads.length === 0 && (
                                <div className="flex flex-col items-center justify-center p-12 bg-white rounded-xl border border-gray-200 shadow-sm">
                                    <AlertCircle className="w-16 h-16 text-gray-300 mb-4" />
                                    <h3 className="text-xl font-bold text-gray-800">No Active Teams</h3>
                                    <p className="text-gray-500 mt-2">Assign employees to a lead to build a team.</p>
                                </div>
                            )}
                            {activeLeads.map(lead => {
                                const myTeamIds = allEmployees.filter(emp => staffLatestLead[emp.id] === lead.id).map(e => e.id);
                                const teamTasks = myTeamIds.map(empId => todaysTasks.filter(taskObj => taskObj.empId === empId).sort((a,b) => new Date(b.startTime).getTime() - new Date(a.startTime).getTime())[0]).filter(taskObj => taskObj && taskObj.isActiveQueue && !['done', 'not_applicable', 'ended_incomplete'].includes(taskObj.status));
                                const leadSelfTaskTasks = todaysTasks.filter(taskObj => taskObj.empId === lead.id && taskObj.leadId === lead.id && taskObj.isActiveQueue && !['done', 'not_applicable', 'ended_incomplete'].includes(taskObj.status));
                                const leadSelfTask = leadSelfTaskTasks.length > 0 ? leadSelfTaskTasks[0] : null;

                                return (
                                    <div key={lead.id} className="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
                                        <div className="border-b border-gray-100 bg-gray-50 px-6 py-4 flex justify-between items-center">
                                            <h3 className="font-bold text-gray-800 flex items-center text-lg"><UserCircle className="w-6 h-6 mr-2 text-blue-600" /> {formatFullName(lead.name)}{t("'s Team")}</h3>
                                            <Badge status="working">{teamTasks.length} {t("Assigned Today")}</Badge>
                                        </div>
                                        <div className="p-6">
                                            <div className="mb-6 p-4 bg-blue-50 border border-blue-100 rounded-lg flex flex-col sm:flex-row justify-between items-center gap-4">
                                                <div className="flex items-center w-full sm:w-auto">
                                                    <div className="w-10 h-10 bg-white rounded-full flex items-center justify-center text-blue-600 font-bold mr-3 flex-shrink-0 shadow-sm">{lead.name.charAt(0)}</div>
                                                    <div><h3 className="font-bold text-gray-800 text-sm leading-tight">{t("Lead")}</h3><p className="text-xs text-gray-500 mt-0.5">{leadSelfTask?.equipNameFallback ? `Working on: ${leadSelfTask.equipNameFallback}` : t("No active task")}</p></div>
