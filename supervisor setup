                {activeTab === 'todo' && (
                    <>{activeTodos.length === 0 ? <div className="flex flex-col items-center justify-center p-12 bg-white rounded-xl border border-gray-200 shadow-sm mt-6"><CheckCircle2 className="w-16 h-16 text-green-400 mb-4" /><h3 className="text-2xl font-bold text-gray-800">{t("You're all caught up!")}</h3><p className="text-gray-500 mt-2 text-lg">{t("No pending tasks or escalations assigned to you right now.")}</p></div> : <div className="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">{activeTodos.map(todo => <SupervisorTodoCard key={todo.id} todo={todo} updateTask={updateSupervisorTask} />)}</div>}</>
                )}
