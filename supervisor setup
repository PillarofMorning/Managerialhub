function AuthBox({ users, systemShift, onLogin, onCancel, isModal, debugLog }) {
    const { t } = useTranslation();
    const [badgeInput, setBadgeInput] = useState('');
    const [error, setError] = useState(false);
    const inputRef = useRef(null);

    useEffect(() => { if (inputRef.current) inputRef.current.focus(); }, []);

    const handleBadge = (e) => {
        e.preventDefault();
        const bNum = badgeInput.trim();
        if (!bNum) return;
        const user = users.find(u => u.badgeNumber && String(u.badgeNumber).trim() === bNum);
        if (user) { 
            onLogin(user); 
        } else { 
            setError(true); 
            setBadgeInput(''); 
            if (inputRef.current) inputRef.current.focus(); 
        }
    };

    if (users.length === 0 && !isModal) {
        return (
            <div className="p-6 bg-red-50 text-red-900 border-t border-red-200 flex-1 flex flex-col">
                <h3 className="font-bold text-lg mb-2 flex items-center"><AlertTriangle className="w-5 h-5 mr-2" /> Connection Diagnostic</h3>
                <p className="text-sm font-medium mb-3">0 Employees loaded. The Dataverse query failed or returned no results. See logs below to debug the WebAPI schema:</p>
                <div className="bg-black text-green-400 font-mono text-[10px] p-3 rounded-md overflow-y-auto whitespace-pre-wrap shadow-inner relative flex-1">
                    <button type="button" onClick={(e) => { e.stopPropagation(); copyToClipboard(debugLog); }} className="absolute top-2 right-2 text-[9px] bg-gray-800 hover:bg-gray-700 text-gray-300 px-2 py-0.5 rounded">Copy</button>
                    {debugLog || "Initializing Dataverse Connection..."}
                </div>
            </div>
        );
    }

    return (
        <div className="p-8">
            <form onSubmit={handleBadge} className="space-y-6">
                <div>
                    <label className="flex items-center justify-center text-sm font-bold text-gray-700 mb-2 uppercase tracking-wider"><BadgeIcon className="w-4 h-4 mr-2 text-blue-600" />{t("Scan or Type Badge Number")}</label>
                    <input ref={inputRef} type="password" inputMode="numeric" className={`w-full text-center text-3xl tracking-widest p-4 border rounded-xl focus:ring-4 outline-none transition-all ${error ? 'border-red-500 focus:ring-red-200 bg-red-50 text-red-700' : 'border-gray-300 focus:border-blue-500 focus:ring-blue-200'}`} value={badgeInput} onChange={e => { setBadgeInput(e.target.value); setError(false); }} placeholder="•••••" />
                </div>
                {error && <p className="text-red-500 text-sm font-bold text-center">{t("Invalid Badge Number. Please try again.")}</p>}
                <Button type="submit" variant="primary" size="lg" className="w-full shadow-md font-bold text-lg py-3">{t("Login")}</Button>
            </form>
            <div className="mt-8 relative flex items-center justify-center"><div className="border-t border-gray-200 w-full absolute"></div><span className="bg-white px-4 text-xs font-bold text-gray-400 uppercase tracking-widest relative z-10">{t("OR")}</span></div>
            <div className="mt-8">
                <label className="block text-sm font-bold text-gray-700 mb-2 text-center">{t("Select Manually (For Now)")}</label>
                <select className="w-full p-3 border border-gray-300 rounded-lg outline-none focus:ring-2 focus:ring-blue-500 font-medium bg-gray-50" onChange={(e) => { const user = users.find(u => u.id === e.target.value); if (user) onLogin(user); }} value="">
                    <option value="" disabled>{t("-- Select Profile --")}</option>
                    {[systemShift, ...['A', 'B', 'C', 'D', 'Unassigned'].filter(s => s !== systemShift)].map(shift => {
                        const shiftUsers = users.filter(u => u.shift === shift);
                        if(shiftUsers.length === 0) return null;
                        const roleOrder = { manager: 1, supervisor: 2, lead: 3, employee: 4 };
                        const sortedUsers = [...shiftUsers].sort((a, b) => (roleOrder[a.role] || 5) - (roleOrder[b.role] || 5));
                        return (
                            <optgroup key={shift} label={`${t("Shift")} ${shift} ${shift === systemShift ? `(${t("Current Shift")})` : ''}`}>
                                {sortedUsers.map(u => <option key={u.id} value={u.id}>{formatFullName(u.name)} - {t(u.role).toUpperCase()}</option>)}
                            </optgroup>
                        );
                    })}
                </select>
            </div>
            {isModal && onCancel && <div className="mt-6 pt-6 border-t border-gray-100 flex justify-center"><Button variant="secondary" onClick={onCancel}>{t("Cancel")}</Button></div>}
        </div>
    );
}

