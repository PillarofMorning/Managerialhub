    const [isLoadingData, setIsLoadingData] = useState(true);
    const [adminMode, setAdminMode] = useState(false);
    const [isSaving, setIsSaving] = useState(false);
    const [showSwitchUserModal, setShowSwitchUserModal] = useState(false);
    const [hasAutoLogged, setHasAutoLogged] = useState(false);

    const logDebug = (msg) => { setDebugLog(prev => prev + msg + "\n"); };

    const recordDataCall = (action, table, payload, status, details = '') => {
        const safePayload = { ...payload };
        if (safePayload.craa5_beforepicture) safePayload.craa5_beforepicture = '<BASE64_IMAGE_DATA_TRUNCATED>';
        if (safePayload.craa5_afterpicture) safePayload.craa5_afterpicture = '<BASE64_IMAGE_DATA_TRUNCATED>';
        if (safePayload.craa5_photoofcompletion) safePayload.craa5_photoofcompletion = '<BASE64_IMAGE_DATA_TRUNCATED>';
        setCallLogs(prev => [{ id: Date.now() + Math.random(), time: new Date().toLocaleTimeString(), action, table, payload: safePayload, status, details }, ...prev]);
    };

    useEffect(() => {
        if (msUser) return;
        const fetchUserProfile = async () => {
            logDebug(`--- AUTHENTICATION CHECK ---`);
            const xrmGlobal = safeGetXrm()?.Utility?.getGlobalContext?.()?.userSettings || {};
            const userSettings = props?.context?.userSettings || xrmGlobal || {};
            
            let uName = userSettings.userName || props?.userName;
            let uId = userSettings.userId || props?.userId;
            let actualEmail = props?.userEmail || null; 

            if (uName && actualEmail) {
                logDebug(`Auth Resolved Immediately: ${actualEmail}`);
                setMsUser({ name: uName, email: actualEmail, id: uId });
                return;
            }

            const globalXrm = safeGetXrm();
            if (uName) {
                if (!actualEmail && uId && globalXrm?.WebApi) {
                    try {
                        const cleanUserId = uId.replace(/[{}]/g, '');
                        const fetchSysUser = globalXrm.WebApi.retrieveRecord("systemuser", cleanUserId, "?$select=internalemailaddress");
                        const sysUser = await Promise.race([ fetchSysUser, new Promise((_, r) => setTimeout(() => r(new Error('Xrm Timeout')), 4000)) ]);
                        if (sysUser && sysUser.internalemailaddress) actualEmail = sysUser.internalemailaddress;
                        logDebug(`Auth: Retrieved email: ${actualEmail}`);
                    } catch (error) {}
                }
                setMsUser({ name: uName, email: actualEmail || "", id: uId });
            } else {
                logDebug("Auth: No user info found. Using fallback DEV identity.");
                setMsUser({ name: "Local Developer", email: "dev@localhost", id: "DEV" });
            }
        };
        fetchUserProfile();
    }, [props, msUser]);

    useEffect(() => {
        async function loadDataverse() {
            logDebug("--- STARTING DATAVERSE MOUNT ---");
            const metrics = {};
            const updateMetric = (key, data) => {
                metrics[key] = { status: data.rows.length > 0 ? 'green' : (data.source !== 'Failed' ? 'yellow' : 'red'), name: data.tableName || 'FAILED_TO_CONNECT', count: data.rows.length || 0, source: data.source || 'None' };
            };

            try {
                const empsData = await fetchFallbackRecords(['craa5__aa_employee', 'craa5_aa_employee', 'craa5__aa_Employee'], props, logDebug);
                updateMetric('Employees', empsData);
                const dvEmps = empsData.rows;
                
                const assetsData = await fetchFallbackRecords(['craa5_aa_assets'], props, logDebug);
                updateMetric('Equipment', assetsData);
                const dvAssets = assetsData.rows;
                
                const shiftsData = await fetchFallbackRecords(['craa5_workshift'], props, logDebug);
                updateMetric('Shifts', shiftsData);
                const dvShifts = shiftsData.rows;
                
                const areasData = await fetchFallbackRecords(['craa5_aa_mss_area'], props, logDebug);
                updateMetric('Areas', areasData);
                const dvAreas = areasData.rows;

                const todosData = await fetchFallbackRecords(['craa5__supervisor_todo', 'craa5_supervisor_todo'], props, logDebug);
                updateMetric('To-Dos', todosData);

                setShiftsTable(dvShifts || []);
                const calculatedCurrentShift = getCurrentShiftLogic(dvShifts);

                logDebug("Fetching recent tasks (unfiltered by shift to avoid OData choice type mismatch)...");
                let tasksData = await fetchFallbackRecords(['craa5_taskassignment', 'craa5_Taskassignment'], props, logDebug, "?$top=3000&$orderby=createdon desc");

                updateMetric('Task Assignments', tasksData);
                const dvTasks = tasksData.rows;

                setTableMetrics(metrics);
                setActiveTableNames({ tasks: tasksData.tableName || 'craa5_taskassignment', assets: assetsData.tableName || 'craa5_aa_assets', todos: todosData.tableName || 'craa5__supervisor_todo' });

                const parsedAreas = (dvAreas || []).map(a => ({
                    id: getField(a, 'craa5_aa_mss_areaid') || Math.random().toString(),
                    name: String(getField(a, 'craa5_area') || "Unknown Area").trim(),
                    runsProduct: getField(a, 'craa5_runsproduct') === true || getField(a, 'craa5_runsproduct') === 1 || String(getField(a, 'craa5_runsproduct')).toLowerCase() === 'true',
                })).filter(a => a.name !== "Unknown Area");
                setAreas(parsedAreas);

                let resolvedUsers = [];
                if (dvEmps && dvEmps.length > 0) {
                    resolvedUsers = dvEmps.map(e => {
                        let mappedRole = 'employee';
                        const rawRole = getField(e, 'craa5_Role') || getField(e, 'craa5_role');
                        const roleFormatted = getFormattedField(e, 'craa5_Role') || getFormattedField(e, 'craa5_role') || '';
                        const roleStr = String(rawRole || roleFormatted).toLowerCase();

                        const numericRole = Number(rawRole);
                        if (numericRole === 256000003 || roleStr.includes('manager')) mappedRole = 'manager';
                        else if (numericRole === 256000002 || roleStr.includes('supervisor')) mappedRole = 'supervisor';
                        else if (numericRole === 256000001 || roleStr.includes('lead')) mappedRole = 'lead';
                        else mappedRole = 'employee'; 
                        
                        return {
                            id: safeId(getField(e, 'craa5_aa_EmployeeId') || getField(e, 'craa5__aa_employeeid') || e.id) || `temp_${Math.random()}`,
                            uidm: getField(e, 'craa5_uidm') || "", 
                            badgeNumber: String(getField(e, 'craa5_badgenumber') || "").trim(),
                            name: getField(e, 'craa5_Name') || getField(e, 'craa5_name') || 'Unknown',
                            email: getField(e, 'craa5_email') || getField(e, 'emailaddress1') || "",
                            role: mappedRole,
                            shift: normalizeShift(getFormattedField(e, 'craa5_Shift') || getField(e, 'craa5_shift')),
                            leadershipTeamId: getField(e, '_craa5_leadershipteamid_value') || getField(e, 'craa5_leadershipteamid'),
                            _raw: e
                        };
                    });
                    setUsers(resolvedUsers);
                } else { logDebug("WARNING: users array generated length 0. Fallback Mocks applied."); resolvedUsers = MOCK_USERS; setUsers(resolvedUsers); }

                let resolvedEquip = [];
                if (dvAssets && dvAssets.length > 0) {
                    resolvedEquip = dvAssets.map(a => ({
                        id: safeId(getField(a, 'craa5_aa_assetsid') || a.id),
                        name: getField(a, 'craa5_equipmentidentifier') || 'Unnamed Equipment',
                        area: getField(a, 'craa5_areaname') || 'Unknown Area',
                        esName: getField(a, 'craa5_esequipment') || null,
                        _raw: a
                    }));
                }
                
                parsedAreas.forEach(area => {
                    if (area.runsProduct) {
                        const existing = resolvedEquip.find(e => (e.area || '').toLowerCase() === area.name.toLowerCase() && e.name.toLowerCase() === 'general');
                        if (!existing) resolvedEquip.push({ id: `gen_equip_${area.id}`, name: 'General', esName: 'General', area: area.name, isSynthetic: true });
                    }
                });
                setEquipment(resolvedEquip);

                const findEquipIdByName = (name, lookupId, contextArea) => {
                    const safeLookup = safeId(lookupId);
                    if (safeLookup && resolvedEquip.find(e => e.id === safeLookup)) return safeLookup;
                    if (!name) return null;
                    const cleanName = name.trim().toLowerCase();
                    if (cleanName === 'general' && contextArea) {
                        const areaGen = resolvedEquip.find(e => e.isSynthetic && (e.area || '').toLowerCase() === contextArea.toLowerCase());
                        if (areaGen) return areaGen.id;
                    }
                    const found = resolvedEquip.find(e => e.name.toLowerCase() === cleanName && (!contextArea || !e.area || e.area.toLowerCase() === contextArea.toLowerCase()));
                    if (found) return found.id;
                    return resolvedEquip.find(e => e.name.toLowerCase() === cleanName)?.id || null;
                };

                const parsedTasks = [];
                let orphanedCount = 0;

                for (const taskObj of dvTasks) {
                    const taskTimeStrRaw = getField(taskObj, 'craa5_starttime') || getField(taskObj, 'craa5_datetimeofassignment') || getField(taskObj, 'createdon');
                    if (!taskTimeStrRaw) { logDebug(`[SKIP] Task skipped due to missing start time.`); continue; }

                    const tShiftRaw = getFormattedField(taskObj, 'craa5_shift') || getField(taskObj, 'craa5_shift');
                    const tShift = tShiftRaw ? normalizeShift(tShiftRaw) : calculatedCurrentShift;
                    const logicalDate = getShiftLogicalDate(taskTimeStrRaw, tShift, dvShifts);

                    const empNameText = getField(taskObj, 'craa5_id');
                    
                    const empId = resolveUser(taskObj, false, resolvedUsers, logDebug);
                    if (!empId) { 
                        orphanedCount++; 
                        logDebug(`[ORPHAN TASK DROPPED] Task ID: ${getField(taskObj, 'craa5_taskassignmentid')}. Unresolved Emp Name: ${empNameText}`);
                        continue; 
                    }
                    
                    const leadId = resolveUser(taskObj, true, resolvedUsers, logDebug);

                    let equipName = String(getField(taskObj, 'craa5_equip') || getField(taskObj, 'craa5_equipment') || "").trim();
                    let areaName = String(getField(taskObj, 'craa5_area') || "").trim();
                    let equipIdRaw = getField(taskObj, '_craa5_equipment_value') || getField(taskObj, '_craa5_equip_value');
                    let equipId = findEquipIdByName(equipName, equipIdRaw, areaName);

                    if (!equipId && (!equipName || equipName.toLowerCase() === 'general') && areaName) {
                        const areaRecord = parsedAreas.find(a => a.name.toLowerCase() === areaName.toLowerCase());
                        if (areaRecord && areaRecord.runsProduct) {
                            const genEquip = resolvedEquip.find(e => e.area.toLowerCase() === areaName.toLowerCase() && e.name === 'General' && e.isSynthetic);
                            if (genEquip) { equipId = genEquip.id; equipName = 'General'; }
                        }
                    }

                    let localStatus = 'assigned';
                    const s = String(getField(taskObj, 'craa5_whatisbeingdone') || '').toLowerCase();
                    const isCompDb = getField(taskObj, 'craa5_complete') === true || getField(taskObj, 'craa5_complete') === 1;
                    const percentComplete = getField(taskObj, 'craa5_percentagecomplete') || 0;
                    
                    if (s.includes('not applicable') || s.includes('n/a')) localStatus = 'not_applicable';
                    else if (isCompDb || s.includes('done') || s.includes('complete') || percentComplete === 100) localStatus = 'done';
                    else if (s.includes('ended incomplete') || s.includes('incomplete')) localStatus = 'ended_incomplete';
                    else if (s.includes('pending')) localStatus = 'pending_inspection';
                    else if (s.includes('reclean')) localStatus = 'reclean';
                    else if (s.includes('working') || s.includes('in progress') || s.includes('started') || equipId) localStatus = 'working';

                    parsedTasks.push({
                        id: safeId(getField(taskObj, 'craa5_taskassignmentid')) || `local_task_${Date.now()}_${Math.random()}`,
                        dvId: safeId(getField(taskObj, 'craa5_taskassignmentid')),
                        empId: empId,
                        leadId: leadId,
                        equipId: equipId,
                        equipNameFallback: equipName,
                        area: areaName,
                        shift: tShift,
                        logicalDate: logicalDate,
                        status: localStatus,
                        startTime: taskTimeStrRaw,
                        endTime: getField(taskObj, 'craa5_endtime') || null,
                        inspectionTime: getField(taskObj, 'craa5_inspection') || null,
                        whatIsLeftToDo: getField(taskObj, 'craa5_whatislefttodo') || "",
                        futureOrNotes: getField(taskObj, 'craa5__future_or_notes') || "",
                        percent: percentComplete,
                        beforePicture: getField(taskObj, 'craa5_beforepicture') ? `data:image/jpeg;base64,${getField(taskObj, 'craa5_beforepicture')}` : null,
                        afterPicture: getField(taskObj, 'craa5_afterpicture') ? `data:image/jpeg;base64,${getField(taskObj, 'craa5_afterpicture')}` : null,
                        isCompleteBool: isCompDb,
                        isActiveQueue: !(localStatus === 'done' || localStatus === 'not_applicable' || localStatus === 'ended_incomplete'),
                        _raw: taskObj
                    });
                }
                setTasks(parsedTasks);
                if (orphanedCount > 0) logDebug(`[DATA METRIC] ${orphanedCount} tasks were dropped as ORPHANS (Could not map to an existing Employee Name/Email/ID).`);

                const parsedTodos = (todosData.rows || []).map(tSup => {
                    const isComp = getField(tSup, 'craa5_complete') === true || getField(tSup, 'craa5_complete') === 1 || String(getField(tSup, 'craa5_complete')).toLowerCase() === 'true';
                    return {
                        id: safeId(getField(tSup, 'craa5_supervisor_todoid')) || safeId(getField(tSup, 'craa5__supervisor_todoid')) || `todo_${Date.now()}_${Math.random()}`,
                        dvId: safeId(getField(tSup, 'craa5_supervisor_todoid')) || safeId(getField(tSup, 'craa5__supervisor_todoid')),
                        taskName: getField(tSup, 'craa5_Task') || getField(tSup, 'craa5_task') || 'Unnamed Task',
                        description: getField(tSup, 'craa5_taskdescription') || getField(tSup, 'craa5_Taskdescription') || '',
                        assignedTo: getField(tSup, 'craa5_assignedto') || getField(tSup, 'craa5_Assignedto') || '',
                        isComplete: isComp,
                        photo: getField(tSup, 'craa5_photoofcompletion') ? `data:image/jpeg;base64,${getField(tSup, 'craa5_photoofcompletion')}` : null,
                        dueDate: getField(tSup, 'craa5_Expectationfortimeframe') || getField(tSup, 'craa5_expectationfortimeframe') || '',
                        _raw: tSup
                    };
                });
                setSupervisorTasks(parsedTodos);

            } catch (e) {
                logDebug(`FATAL ERROR in loadDataverse: ${e.message}`);
                console.error("Dataverse load failed", e);
            } finally {
                setIsLoadingData(false);
            }
        }
        loadDataverse();
    }, [props.dataApi]);

    useEffect(() => {
        if (hasAutoLogged || showSwitchUserModal) return;
        if (!msUser || isLoadingData) return;
        
        logDebug(`--- AUTO LOGIN RESOLUTION ---`);
        const msEmailLower = (msUser.email || "").toLowerCase();
        const msNameLower = (msUser.name || "").toLowerCase();

        let matchedUser = users.find(u => {
            const uEmail = (u.email || "").toLowerCase();
            const uName = (u.name || "").toLowerCase();
            return (msEmailLower && uEmail === msEmailLower) || (msNameLower && uName === msNameLower);
        });

        if (matchedUser && (matchedUser.role === 'manager' || matchedUser.role === 'supervisor')) {
            setCurrentUser({...matchedUser, logicalDateContext: getShiftLogicalDate(new Date(), matchedUser.shift, shiftsTable)});
            logDebug(`[SUCCESS] Auto-logged in as ${matchedUser.name} (${matchedUser.role})`);
        } else {
            logDebug(`[SKIPPED] No matching manager/supervisor found for Email: '${msEmailLower}'`);
        }
        
        setHasAutoLogged(true);
        setIsAuthenticating(false);
    }, [msUser, users, hasAutoLogged, showSwitchUserModal, isLoadingData, shiftsTable]);

    const saveTaskToDataverse = async (task, action) => {
        setIsSaving(true);
        const writeApi = getWebApi(props) || props.dataApi;

        const emp = users.find(u => u.id === task.empId);
        const lead = users.find(u => u.id === task.leadId);
        const equip = equipment.find(e => e.id === task.equipId);
        const supervisor = users.find(u => u.role === 'supervisor' && u.shift === lead?.shift);

        let currentStatusStr = 'In Progress', percent = task.percent || 0;
        if (task.status === 'done') { currentStatusStr = 'Complete'; percent = 100; } 
        else if (task.status === 'ended_incomplete') { currentStatusStr = 'Incomplete'; percent = 50; }
        else if (task.status === 'not_applicable') { currentStatusStr = 'Not Applicable'; percent = 100; } 
        else if (task.status === 'pending_inspection') { currentStatusStr = 'Pending Inspection'; } 
        else if (task.status === 'reclean') { currentStatusStr = 'Reclean'; }
        else if (task.status === 'assigned') { currentStatusStr = 'Started'; }
        else if (task.status === 'working' || task.status === 'incomplete') { currentStatusStr = task.status === 'working' ? 'In Progress' : 'Incomplete'; percent = 50; }

        let targetShiftStr = task.shift || lead?.shift || emp?.shift || currentUser?.shift || getCurrentShiftLogic(shiftsTable);
        let shiftInt = null;
        if (targetShiftStr === 'A') shiftInt = 1;
        else if (targetShiftStr === 'B') shiftInt = 2;
        else if (targetShiftStr === 'C') shiftInt = 3;
        else if (targetShiftStr === 'D') shiftInt = 4;

        const payload = {
            craa5_id: emp?.name || "", 
            craa5_email: emp?.email || "", 
            craa5_badgenumber: String(emp?.badgeNumber || ""),
            craa5_lead: lead?.name || "", 
            craa5_leademail: lead?.email || "",
            craa5_team: supervisor?.name || "", 
            craa5_supervisoremail: supervisor?.email || "", 
            craa5_area: equip?.area || task.area || "",
            craa5_equip: equip?.name || task.equipNameFallback || "",
            craa5_whatisbeingdone: currentStatusStr,
            craa5_percentagecomplete: percent, 
            craa5_complete: task.isCompleteBool !== undefined ? task.isCompleteBool : (task.status === 'done' || task.status === 'not_applicable'), 
        };

        if (task.whatIsLeftToDo !== undefined) payload.craa5_whatislefttodo = task.whatIsLeftToDo;
        if (task.futureOrNotes !== undefined) payload.craa5__future_or_notes = task.futureOrNotes;
        if (shiftInt !== null) payload.craa5_shift = shiftInt; 
        
        if (action === 'create') { 
            payload.craa5_starttime = task.startTime || new Date().toISOString(); 
        }
        
        if (task.endTime) { payload.craa5_endtime = task.endTime; } else if (['done', 'not_applicable', 'ended_incomplete', 'incomplete'].includes(task.status)) { payload.craa5_endtime = task.inspectionTime || new Date().toISOString(); }
        if (task.inspectionTime) { payload.craa5_inspection = task.inspectionTime; payload.craa5_endtime = task.inspectionTime; }
        
        if (task.beforePicture) payload.craa5_beforepicture = getCleanBase64(task.beforePicture);
        if (task.afterPicture) payload.craa5_afterpicture = getCleanBase64(task.afterPicture);

        if (isMockMode) {
            if (action === 'create') {
                const mockId = `mock_assigned_${Date.now()}`;
                recordDataCall('CREATE (MOCK)', activeTableNames.tasks, payload, 'MOCK', `Simulated Dataverse Insert. Would return ID: ${mockId}`);
                setTimeout(() => setIsSaving(false), 500);
                return mockId;
            } else {
                recordDataCall('UPDATE (MOCK)', activeTableNames.tasks, payload, 'MOCK', `Simulated Dataverse Update to ${task.dvId}`);
                if (task.status === 'done' && task.equipId && !task.equipId.startsWith('custom_') && !task.equipId.startsWith('gen_equip_')) {
                    recordDataCall('UPDATE (MOCK)', activeTableNames.assets, { craa5_lastcleaneddate: new Date().toISOString() }, 'MOCK', `Simulated cascading update for asset ${task.equipId}`);
                }
                setTimeout(() => setIsSaving(false), 500);
                return;
            }
        }

        if (!writeApi) { setTimeout(() => setIsSaving(false), 500); return; }

        recordDataCall(action.toUpperCase(), activeTableNames.tasks, payload, 'PENDING');
        try {
            if (action === 'create') {
                const res = await writeApi.createRecord(activeTableNames.tasks, payload);
                recordDataCall('CREATE', activeTableNames.tasks, payload, 'SUCCESS', `Returned ID: ${res?.id}`);
                return res?.id;
            } else if (action === 'update' && task.dvId) {
                await writeApi.updateRecord(activeTableNames.tasks, task.dvId, payload);
                recordDataCall('UPDATE', activeTableNames.tasks, payload, 'SUCCESS');
                
                if (task.status === 'done' && task.equipId && !task.equipId.startsWith('custom_') && !task.equipId.startsWith('gen_equip_')) {
                    try { 
                        await writeApi.updateRecord(activeTableNames.assets, task.equipId, { craa5_lastcleaneddate: new Date().toISOString() }); 
                        recordDataCall('UPDATE', activeTableNames.assets, { craa5_lastcleaneddate: new Date().toISOString() }, 'SUCCESS');
                    } catch(err){
                        recordDataCall('UPDATE', activeTableNames.assets, { craa5_lastcleaneddate: new Date().toISOString() }, 'ERROR', err.message);
                    }
                }
            }
        } catch (e) {
            recordDataCall(action.toUpperCase(), activeTableNames.tasks, payload, 'ERROR', e.message);
            console.error("Dataverse Save Error:", e);
            alert("Network Error: Changes could not be saved to Dataverse. The application will reload to resync state.");
            window.location.reload(); 
        } finally { setTimeout(() => setIsSaving(false), 500); }
    };

    const deleteTaskFromDataverse = async (taskId) => {
        setIsSaving(true);
        const taskToDelete = tasks.find(t => t.id === taskId);
        setTasks(prev => prev.filter(t => t.id !== taskId));
        
        if (isMockMode) {
            recordDataCall('DELETE (MOCK)', activeTableNames.tasks, { id: taskToDelete?.dvId }, 'MOCK', `Simulated deletion for row ${taskToDelete?.dvId}`);
            setTimeout(() => setIsSaving(false), 500);
            return;
        }

        const writeApi = getWebApi(props) || props.dataApi;
        if (writeApi && taskToDelete?.dvId) {
            recordDataCall('DELETE', activeTableNames.tasks, { id: taskToDelete.dvId }, 'PENDING');
            try {
                if (writeApi.deleteRecord) {
                    await writeApi.deleteRecord(activeTableNames.tasks, taskToDelete.dvId);
                    recordDataCall('DELETE', activeTableNames.tasks, { id: taskToDelete.dvId }, 'SUCCESS');
                } else {
                    await writeApi.updateRecord(activeTableNames.tasks, taskToDelete.dvId, { statecode: 1, craa5_whatisbeingdone: 'Removed' });
                    recordDataCall('SOFT DELETE', activeTableNames.tasks, { statecode: 1 }, 'SUCCESS');
                }
            } catch (e) {
                recordDataCall('DELETE', activeTableNames.tasks, { id: taskToDelete.dvId }, 'ERROR', e.message);
                console.error("Dataverse Delete Error:", e);
                alert("Network Error: Task could not be removed. Reloading state.");
                window.location.reload();
            }
        }
        setTimeout(() => setIsSaving(false), 500);
    };

    const updateTask = (taskId, updates) => {
        setTasks(prev => {
            const newTasks = prev.map(t => {
                if (t.id === taskId) {
                    let merged = { ...t, ...updates };
                    if (updates.area && !merged.equipId && !merged.equipNameFallback) {
                        const genEquip = equipment.find(e => e.area === updates.area && e.id === `gen_equip_${updates.area}`);
                        if (genEquip) { merged.equipId = genEquip.id; merged.equipNameFallback = genEquip.name; if (merged.status === 'assigned') merged.status = 'working'; }
                    }
                    if (updates.status !== undefined || updates.isCompleteBool !== undefined) {
                        merged.isActiveQueue = !(merged.status === 'done' || merged.status === 'not_applicable' || merged.status === 'ended_incomplete' || merged.status === 'incomplete' || merged.isCompleteBool);
                    }
                    if (updates.startTime) merged.logicalDate = getShiftLogicalDate(updates.startTime, merged.shift, shiftsTable);
                    return merged;
                }
                return t;
            });
            const updatedTask = newTasks.find(t => t.id === taskId);
            saveTaskToDataverse(updatedTask, 'update');
            return newTasks;
        });
    };

    const createTasks = async (newTasks) => {
        const newEmpIds = newTasks.map(t => t.empId);
        
        setTasks(prev => {
            const updatedPrev = prev.map(t => newEmpIds.includes(t.empId) ? { ...t, isAbsoluteLatestForEmp: false } : t);
            const preparedNewTasks = newTasks.map(t => {
                const shiftUser = users.find(u => u.id === t.leadId) || currentUser;
                const effectiveShift = t.shift || shiftUser?.shift || getCurrentShiftLogic(shiftsTable);
                const logDate = getShiftLogicalDate(t.startTime || new Date(), effectiveShift, shiftsTable);
                
                let finalEquipId = t.equipId;
                let finalEquipName = t.equipNameFallback;
                let finalStatus = ['done', 'not_applicable', 'ended_incomplete', 'incomplete'].includes(t.status) ? t.status : 'assigned';
                
                if (!finalEquipId && (!finalEquipName || finalEquipName.toLowerCase() === 'general') && t.area) {
                    const genEquip = equipment.find(e => e.isSynthetic && (e.area || '').toLowerCase() === t.area.toLowerCase());
                    if (genEquip) { finalEquipId = genEquip.id; finalEquipName = genEquip.name; if (finalStatus === 'assigned') finalStatus = 'working'; }
                }
                return { ...t, shift: effectiveShift, logicalDate: logDate, equipId: finalEquipId, equipNameFallback: finalEquipName, status: finalStatus, isCompleteBool: false, isAbsoluteLatestForEmp: true, isActiveQueue: !['done', 'not_applicable', 'ended_incomplete', 'incomplete'].includes(finalStatus) };
            });
            return [...updatedPrev, ...preparedNewTasks];
        });

        for (const t of newTasks) {
            const taskToSave = { ...t, shift: t.shift || getCurrentShiftLogic(shiftsTable), equipId: t.equipId, equipNameFallback: t.equipNameFallback, status: t.status };
            if (!taskToSave.equipId && (!taskToSave.equipNameFallback || taskToSave.equipNameFallback.toLowerCase() === 'general') && taskToSave.area) {
                const genEquip = equipment.find(e => e.isSynthetic && (e.area || '').toLowerCase() === taskToSave.area.toLowerCase());
                if (genEquip) { taskToSave.equipId = genEquip.id; taskToSave.equipNameFallback = genEquip.name; if (taskToSave.status === 'assigned') taskToSave.status = 'working'; }
            }
            const dvId = await saveTaskToDataverse(taskToSave, 'create');
            if (dvId) setTasks(prev => prev.map(task => task.id === t.id ? { ...task, dvId } : task));
        }
    };

    const createSupervisorTask = async (taskData) => {
        setIsSaving(true);
        const writeApi = getWebApi(props) || props.dataApi;
        const payload = { craa5_task: taskData.title, craa5_taskdescription: taskData.instructions, craa5_assignedto: taskData.assignTo, craa5_dateassigned: new Date().toISOString() };
        if (taskData.timeframe) payload.craa5_expectationfortimeframe = taskData.timeframe; 
        
        const tableName = activeTableNames.todos || 'craa5__supervisor_todo';
        
        if (isMockMode) {
            recordDataCall('CREATE (MOCK)', tableName, payload, 'MOCK', `Simulated Escalation. Would return ID: mock_todo_${Date.now()}`);
            setSupervisorTasks(prev => [...prev, { id: `mock_todo_${Date.now()}`, dvId: `mock_todo_${Date.now()}`, taskName: taskData.title, description: taskData.instructions, assignedTo: taskData.assignTo, isComplete: false, photo: null, dueDate: taskData.timeframe }]);
            setTimeout(() => setIsSaving(false), 500);
            return;
        }

        recordDataCall('CREATE', tableName, payload, 'PENDING');
        try {
            if (writeApi) {
                const res = await writeApi.createRecord(tableName, payload);
                recordDataCall('CREATE', tableName, payload, 'SUCCESS', `Returned ID: ${res?.id}`);
                setSupervisorTasks(prev => [...prev, { id: res?.id || `todo_${Date.now()}`, dvId: res?.id, taskName: taskData.title, description: taskData.instructions, assignedTo: taskData.assignTo, isComplete: false, photo: null, dueDate: taskData.timeframe }]);
            }
        } catch (e) {
            recordDataCall('CREATE', tableName, payload, 'ERROR', e.message);
            console.error("Dataverse Save Error:", e);
        } finally { setIsSaving(false); }
    };

    const updateSupervisorTask = async (taskId, updates) => {
        setIsSaving(true);
        setSupervisorTasks(prev => prev.map(t => t.id === taskId ? { ...t, ...updates } : t));
        const task = supervisorTasks.find(t => t.id === taskId);
        const writeApi = getWebApi(props) || props.dataApi;

        const payload = {};
        if (updates.isComplete !== undefined) { payload.craa5_complete = updates.isComplete; payload.statecode = 0; }
        if (updates.completionDate) payload.craa5_completiondate = updates.completionDate;
        if (updates.photo !== undefined) payload.craa5_photoofcompletion = getCleanBase64(updates.photo);

        const tableName = activeTableNames.todos || 'craa5__supervisor_todo';
        
        if (isMockMode) {
            recordDataCall('UPDATE (MOCK)', tableName, payload, 'MOCK', `Simulated Escalation Update to ${task?.dvId}`);
            setTimeout(() => setIsSaving(false), 500);
            return;
        }

        if (!writeApi || !task?.dvId) { setTimeout(() => setIsSaving(false), 500); return; }

        recordDataCall('UPDATE', tableName, payload, 'PENDING');
        try {
            await writeApi.updateRecord(tableName, task.dvId, payload);
            recordDataCall('UPDATE', tableName, payload, 'SUCCESS');
        } catch (e) {
            recordDataCall('UPDATE', tableName, payload, 'ERROR', e.message);
        } finally { setTimeout(() => setIsSaving(false), 500); }
    };

    const diagnosticsProps = { tableMetrics, callLogs, debugLog, users, tasks, equipment, areas, currentUser };

    return (
        <TranslationContext.Provider value={{t, lang, setLang}}>
            <div className="flex flex-col min-h-screen w-full bg-gray-50 overflow-hidden relative">
                
                <TopDebugBar 
                    msUser={msUser} adminMode={adminMode} tableMetrics={tableMetrics} 
                    callLogs={callLogs} debugLog={debugLog} users={users} tasks={tasks} 
                    equipment={equipment} areas={areas} currentUser={currentUser} 
                    isMockMode={isMockMode} setIsMockMode={setIsMockMode}
                />
                
                <div className="flex-1 flex flex-col overflow-y-auto relative">
                    {isLoadingData || isAuthenticating ? (
                        <div className="min-h-full bg-gray-50 flex flex-col items-center justify-center p-4">
                            <Loader2 className="w-12 h-12 text-blue-600 animate-spin mb-4" />
                            <h2 className="text-xl font-semibold text-gray-700">{t("Connecting to Supervisor Hub...")}</h2>
                            <p className="text-gray-500">{!msUser ? t("Verifying Microsoft Credentials...") : t("Retrieving environment data...")}</p>
                            
                            {(!msUser || debugLog.includes('FATAL')) && (
                                <div className="mt-8 bg-gray-900 text-green-400 p-4 rounded-lg text-xs font-mono w-full max-w-2xl h-48 overflow-y-auto shadow-inner whitespace-pre-wrap relative">
                                    <button type="button" onClick={(e) => { e.stopPropagation(); copyToClipboard(debugLog); }} className="absolute top-2 right-2 text-[9px] bg-gray-800 hover:bg-gray-700 text-gray-300 px-2 py-0.5 rounded">Copy</button>
                                    {debugLog || "Initializing Dataverse Mount..."}
                                </div>
                            )}
                        </div>
                    ) : !currentUser ? (
                        <div className="min-h-full bg-gray-50 flex flex-col items-center justify-center p-4 font-sans relative">
                            <div className="absolute top-4 left-4 flex items-center gap-2 bg-white p-2.5 rounded-lg border border-gray-200 shadow-sm z-50">
                                <UserCircle className="w-6 h-6 text-gray-500" />
                                <div className="text-left leading-tight">
                                    <p className="text-[10px] font-bold text-gray-400 uppercase tracking-wider">Active Windows User</p>
                                    <p className="text-sm font-semibold text-gray-800">{msUser?.name || "Loading..."}</p>
                                </div>
                            </div>

                            <div className="absolute top-4 right-4 flex items-center gap-1 bg-white p-1 rounded-lg border border-gray-200 shadow-sm z-50">
                                <button onClick={() => setLang('en')} className={`px-3 py-1 text-xs font-bold rounded ${lang === 'en' ? 'bg-white shadow-sm text-blue-600' : 'text-gray-500 hover:bg-gray-100'}`}>EN</button>
                                <button onClick={() => setLang('es')} className={`px-3 py-1 text-xs font-bold rounded ${lang === 'es' ? 'bg-white shadow-sm text-blue-600' : 'text-gray-500 hover:bg-gray-100'}`}>ES</button>
                            </div>

                            <div className="max-w-md w-full bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden flex flex-col max-h-[90vh]">
                                <div className="bg-blue-600 px-6 py-8 text-center relative flex-shrink-0">
                                    {adminMode && <button onClick={() => setAdminMode(false)} className="absolute top-4 left-4 text-blue-200 hover:text-white"><ArrowRightLeft className="w-6 h-6 rotate-180" /></button>}
                                    <CheckCircle2 className="w-12 h-12 text-white mx-auto mb-3 opacity-90" />
                                    <h1 className="text-2xl font-bold text-white">{t("Supervisor Hub")}</h1>
                                    <p className="text-blue-100 mt-1 text-sm">{t("Scan badge or select profile to log in")}</p>
                                </div>
                                
                                {!adminMode ? (
                                    <div className="overflow-y-auto custom-scrollbar flex-1 bg-white">
                                        <AuthBox users={users} systemShift={getCurrentShiftLogic(shiftsTable)} onLogin={user => setCurrentUser({...user, logicalDateContext: getShiftLogicalDate(new Date(), user.shift, shiftsTable)})} debugLog={debugLog} />
                                        <div className="pb-6 pt-2 text-center">
                                            <button onClick={() => setAdminMode(true)} className="text-xs font-bold text-gray-400 hover:text-blue-600 transition-colors uppercase tracking-widest">Admin Login</button>
                                        </div>
                                    </div>
                                ) : (
                                    <div className="p-6 space-y-8 max-h-[60vh] overflow-y-auto custom-scrollbar bg-gray-50">
                                        {[getCurrentShiftLogic(shiftsTable), ...['A', 'B', 'C', 'D', 'Unassigned'].filter(s => s !== getCurrentShiftLogic(shiftsTable))].map(shift => {
                                            const shiftUsers = users.filter(u => u.shift === shift);
                                            if (shiftUsers.length === 0) return null;
                                            
                                            return (
                                                <div key={shift} className="space-y-4">
                                                    <div className="flex items-center gap-3 border-b border-gray-200 pb-2">
                                                        <h2 className="text-lg font-bold text-gray-800">{t("Shift")} {shift}</h2>
                                                        {shift === getCurrentShiftLogic(shiftsTable) && <Badge status="done" className="!bg-green-100 !text-green-800">{t("Current Shift")}</Badge>}
                                                    </div>
                                                    
                                                    {['manager', 'supervisor', 'lead', 'employee'].map(role => {
                                                        const roleUsers = shiftUsers.filter(u => u.role === role);
                                                        if (roleUsers.length === 0) return null;
                                                        return (
                                                            <div key={role} className="pl-2 border-l-2 border-gray-200">
                                                                <h3 className="text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-2 pl-2">{t(role + "s")}</h3>
                                                                <div className="space-y-2 pl-2">
                                                                    {roleUsers.map(u => (
                                                                        <button key={u.id} onClick={() => { setCurrentUser({...u, logicalDateContext: getShiftLogicalDate(new Date(), u.shift, shiftsTable)}); setAdminMode(false); }} className="w-full text-left px-4 py-2.5 rounded-lg bg-white hover:bg-blue-50 border border-gray-200 font-medium text-gray-700 transition-colors flex items-center justify-between text-sm shadow-sm">
                                                                            {formatFullName(u.name)} <ArrowRightLeft className="w-4 h-4 text-gray-400" />
                                                                        </button>
                                                                    ))}
                                                                </div>
                                                            </div>
                                                        );
                                                    })}
                                                </div>
                                            );
                                        })}
                                    </div>
                                )}
                            </div>
                        </div>
                    ) : (
                        <div className="min-h-full bg-[#F3F4F6] font-sans text-gray-900 flex flex-col overflow-hidden relative">
                            
                            {showSwitchUserModal && (
                                <div className="fixed inset-0 bg-black/60 flex items-center justify-center z-[150] p-4 backdrop-blur-sm">
                                    <div className="max-w-md w-full bg-white rounded-2xl shadow-2xl border border-gray-100 overflow-hidden">
                                        <div className="bg-blue-600 px-6 py-6 text-center">
                                            <h2 className="text-xl font-bold text-white">{t("Switch User")}</h2>
                                            <p className="text-blue-100 mt-1 text-sm">Log in to a different profile</p>
                                        </div>
                                        <AuthBox 
                                            users={users} 
                                            systemShift={getCurrentShiftLogic(shiftsTable)}
                                            onLogin={u => { setCurrentUser({...u, logicalDateContext: getShiftLogicalDate(new Date(), u.shift, shiftsTable)}); setShowSwitchUserModal(false); }} 
                                            onCancel={() => setShowSwitchUserModal(false)} 
                                            isModal={true} 
                                            debugLog={debugLog}
                                        />
                                    </div>
                                </div>
                            )}

                            <header className="bg-white border-b border-gray-200 flex-shrink-0 z-10 shadow-sm relative">
                                <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
                                    <div className="flex items-center gap-3">
                                        <div className="bg-blue-600 p-2 rounded-lg"><CheckCircle2 className="w-6 h-6 text-white" /></div>
                                        <h1 className="text-xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-blue-700 to-blue-500 hidden sm:block">{t("Supervisor Hub")}</h1>
                                        <span className="ml-0 sm:ml-4 px-2.5 py-1 bg-gray-100 text-gray-600 rounded-md text-xs font-bold uppercase tracking-wide border border-gray-200">
                                            {t(currentUser.role).toUpperCase()} {t("View").toUpperCase()}
                                        </span>
                                    </div>
                                    
                                    <div className="flex items-center gap-4">
                                        <div className="flex items-center gap-1 bg-gray-100 p-1 rounded-md border border-gray-200 mr-2">
                                            <button onClick={() => setLang('en')} className={`px-2 py-1 text-[10px] font-bold rounded ${lang === 'en' ? 'bg-white shadow-sm text-blue-600' : 'text-gray-500 hover:bg-gray-200'}`}>EN</button>
                                            <button onClick={() => setLang('es')} className={`px-2 py-1 text-[10px] font-bold rounded ${lang === 'es' ? 'bg-white shadow-sm text-blue-600' : 'text-gray-500 hover:bg-gray-200'}`}>ES</button>
                                        </div>

                                        <Button variant="success" size="sm" onClick={() => { setIsSaving(true); setTimeout(() => setIsSaving(false), 800); }} disabled={isSaving} className="shadow-sm font-bold bg-green-500 hover:bg-green-600 text-white" >
                                            {isSaving ? <Loader2 className="w-4 h-4 mr-2 animate-spin" /> : <Save className="w-4 h-4 mr-2" />}
                                            <span className="hidden sm:inline">{isSaving ? t("Saving...") : t("Save Changes")}</span>
                                        </Button>

                                        <div className="hidden md:block text-right border-l border-gray-200 pl-4">
                                            <p className="text-sm font-bold text-gray-800">{formatFullName(currentUser.name)}</p>
                                            <p className="text-xs text-gray-500">{currentUser.email || currentUser.badgeNumber}</p>
                                        </div>
                                        
                                        <div className="flex items-center gap-3 border-l border-gray-200 pl-4">
                                           {adminMode && <Badge status="pending_inspection" className="hidden sm:inline-block">Admin Impersonation</Badge>}
                                           <Button variant="secondary" size="sm" onClick={() => setShowSwitchUserModal(true)}>
                                             <LogOut className="w-4 h-4 sm:mr-2" /> <span className="hidden sm:inline">{t("Switch User")}</span>
                                           </Button>
                                        </div>
                                    </div>
                                </div>
                            </header>

                            <div className="flex flex-col z-20 flex-shrink-0 w-full">
                               {supervisorTasks.filter(task => !task.isComplete && task.assignedTo?.trim().toLowerCase() === currentUser.email?.trim().toLowerCase() && (currentUser.role === 'employee' || currentUser.role === 'lead' || task.taskName?.toLowerCase().includes('ping'))).map(ping => (
                                  <div key={ping.id} className="bg-blue-600 text-white px-4 py-3 flex justify-between items-center shadow-md">
                                     <div className="flex items-center gap-3">
                                        <AlertCircle className="w-5 h-5 flex-shrink-0" />
                                        <div>
                                           <p className="font-bold text-sm">{ping.taskName}</p>
                                           {ping.description && <p className="text-xs text-blue-100">{ping.description}</p>}
                                        </div>
                                     </div>
                                     <Button size="sm" variant="secondary" className="bg-white text-blue-600 hover:bg-gray-100 border-none shadow-sm flex-shrink-0" onClick={() => updateSupervisorTask(ping.id, { isComplete: true, completionDate: new Date().toISOString() })}>
                                        {t("Acknowledge")}
                                     </Button>
                                  </div>
                               ))}
                            </div>

                            <main className="flex-1 w-full mx-auto px-4 sm:px-6 lg:px-8 py-8 overflow-hidden flex flex-col max-w-7xl">
                                {currentUser.role === 'employee' && <EmployeeDashboard currentUser={currentUser} tasks={tasks} equipment={equipment} users={users} updateTask={updateTask} logDebug={logDebug} />}
                                {currentUser.role === 'lead' && <LeadDashboard currentUser={currentUser} tasks={tasks} users={users} equipment={equipment} areas={areas} updateTask={updateTask} createTasks={createTasks} deleteTask={deleteTaskFromDataverse} logDebug={logDebug} />}
                                {currentUser.role === 'supervisor' && <SupervisorDashboard currentUser={currentUser} tasks={tasks} supervisorTasks={supervisorTasks} users={users} equipment={equipment} updateTask={updateTask} updateSupervisorTask={updateSupervisorTask} createTasks={createTasks} createSupervisorTask={createSupervisorTask} logDebug={logDebug} />}
                                {currentUser.role === 'manager' && <ManagerDashboard currentUser={currentUser} supervisorTasks={supervisorTasks} users={users} updateSupervisorTask={updateSupervisorTask} createSupervisorTask={createSupervisorTask} diagnosticsProps={diagnosticsProps} logDebug={logDebug} />}
                            </main>
                        </div>
                    )}
                </div>
            </div>
        </TranslationContext.Provider>
    );
}
