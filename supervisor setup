function TaskTimer({ startTime, inspectionTime, status }) {
    const [nowMs, setNowMs] = useState(Date.now());
    useEffect(() => {
        if (status === 'working' || status === 'assigned' || status === 'reclean') {
            const interval = setInterval(() => setNowMs(Date.now()), 60000);
            return () => clearInterval(interval);
        }
    }, [status]);
    return <span>{formatDuration(startTime, status === 'pending_inspection' ? inspectionTime : null, nowMs)}</span>;
}

function SupervisorEquipmentSelector({ currentEquipId, currentEquipNameFallback, equipmentList, equipByArea, onAssign }) {
