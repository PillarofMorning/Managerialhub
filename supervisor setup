function copyToClipboard(text) {
    const textArea = document.createElement("textarea");
    textArea.value = text; document.body.appendChild(textArea); textArea.select();
    try { document.execCommand('copy'); alert("Log copied to clipboard!"); } 
    catch (err) { console.error('Copy failed', err); alert("Failed to copy log."); }
    document.body.removeChild(textArea);
}

function getField(obj, fieldName) {
    if (!obj) return undefined;
    if (obj[fieldName] !== undefined) return obj[fieldName];
    const lowerField = fieldName.toLowerCase();
    const key = Object.keys(obj).find(k => k.toLowerCase() === lowerField);
    return key ? obj[key] : undefined;
}

function getFormattedField(obj, fieldName) {
    if (!obj) return undefined;
    const exactFormatted = obj[`${fieldName}@OData.Community.Display.V1.FormattedValue`];
    if (exactFormatted !== undefined) return exactFormatted;
    const lowerField = fieldName.toLowerCase();
    const key = Object.keys(obj).find(k => k.toLowerCase() === lowerField);
    return key ? obj[`${key}@OData.Community.Display.V1.FormattedValue`] : undefined;
}

function safeGetXrm() {
    if (typeof window === 'undefined') return null;
    if (window.Xrm) return window.Xrm;
    try { if (window.parent && window.parent !== window && window.parent.Xrm) return window.parent.Xrm; } catch (e) {}
    try { if (window.top && window.top !== window && window.top.Xrm) return window.top.Xrm; } catch (e) {}
    return null;
}

function getWebApi(props) {
    if (props?.context?.webAPI) return props.context.webAPI;
    if (props?.webAPI) return props.webAPI;
    const xrm = safeGetXrm();
    if (xrm?.WebApi) return xrm.WebApi;
    return null;
}

// [HUNTER SEEKER ENGINE] Rapid fire failover logic to guarantee data loads
async function fetchFallbackRecords(entityNames, props, logDebug, filterQuery = "?$top=3000&$orderby=createdon desc") {
    const webApi = getWebApi(props);
    let bestResult = { rows: [], tableName: entityNames[0], source: 'Failed' };

    for (const entityName of entityNames) {
        logDebug(`[Fetch Attempt]: Target -> ${entityName} | Query -> ${filterQuery}`);
        if (webApi) {
            try {
                const fetchReq = webApi.retrieveMultipleRecords(entityName, filterQuery);
                const res = await Promise.race([ fetchReq, new Promise((_, r) => setTimeout(() => r(new Error('WebAPI OData Timeout')), 5000)) ]);
                if (res && Array.isArray(res.entities)) {
                    logDebug(`[SUCCESS]: Connected to ${entityName} via WebAPI OData (${res.entities.length} rows)`);
                    if (res.entities.length > 0) return { rows: res.entities, tableName: entityName, source: 'WebAPI-OData' };
                    bestResult = { rows: res.entities, tableName: entityName, source: 'WebAPI-OData' };
                }
            } catch (e) { logDebug(`[WARNING]: WebAPI OData rejected ${entityName}. (${e.message})`); }
            
            try {
                const fetchXml = `<fetch top='3000'><entity name='${entityName}'><all-attributes/><order attribute='createdon' descending='true'/></entity></fetch>`;
                const fetchReq2 = webApi.retrieveMultipleRecords(entityName, "?fetchXml=" + encodeURIComponent(fetchXml));
                const res2 = await Promise.race([ fetchReq2, new Promise((_, r) => setTimeout(() => r(new Error('WebAPI FetchXML Timeout')), 5000)) ]);
                if (res2 && Array.isArray(res2.entities)) {
                    logDebug(`[SUCCESS]: Connected to ${entityName} via WebAPI FetchXML (${res2.entities.length} rows)`);
                    if (res2.entities.length > 0) return { rows: res2.entities, tableName: entityName, source: 'WebAPI-FetchXML' };
                    if (bestResult.rows.length === 0) bestResult = { rows: res2.entities, tableName: entityName, source: 'WebAPI-FetchXML' };
                }
            } catch (e) { logDebug(`[WARNING]: FetchXML rejected ${entityName}. (${e.message})`); }
        }
        
        if (props?.dataApi?.queryTable) {
            try {
                const fetchReq = props.dataApi.queryTable(entityName, { top: 3000 });
                const res = await Promise.race([ fetchReq, new Promise((_, r) => setTimeout(() => r(new Error('DataApi Timeout')), 5000)) ]);
                if (res && Array.isArray(res.rows)) {
                    if (res.rows.length > 0) {
                        logDebug(`[SUCCESS]: Connected to ${entityName} via DataApi (${res.rows.length} rows)`);
                        return { rows: res.rows, tableName: entityName, source: 'DataAPI' };
                    } else {
                        bestEmptyResponse = { rows: [], tableName: entityName, source: 'DataAPI (0 Rows)' };
                    }
                }
            } catch (e) { logDebug(`[FAILED]: DataApi rejected ${entityName}. (${e.message})`); }
        }
    }
    return bestResult;
}

// [DYNAMIC SHIFT ENGINE]
function getCurrentShiftLogic(workShifts) {
    if (!workShifts || workShifts.length === 0) return "Unassigned";
    const now = new Date(), dayNumber = now.getDay() + 1, hour = now.getHours() + 1;
    const activeShift = workShifts.find(s => {
        const dNum = getField(s, 'craa5_daynumber');
        if (dNum !== dayNumber) return false;
        const start = getField(s, 'craa5_shiftstarthour');
        const end = getField(s, 'craa5_shiftendhour');
        return start <= end ? (hour >= start && hour < end) : (hour >= start || hour < end);
    });
    if (activeShift) return normalizeShift(getField(activeShift, 'craa5_shiftcode'));
    
    const prevDayNumber = dayNumber === 1 ? 7 : dayNumber - 1;
    const prevShift = workShifts.find(s => {
        const pNum = getField(s, 'craa5_daynumber');
        const start = getField(s, 'craa5_shiftstarthour');
        const end = getField(s, 'craa5_shiftendhour');
        return pNum === prevDayNumber && start > end;
    });
    if (prevShift && hour < getField(prevShift, 'craa5_shiftendhour')) return normalizeShift(getField(prevShift, 'craa5_shiftcode'));
    return "Unassigned";
}

function getShiftLogicalDate(dateObj, shiftLabel, workShifts = []) {
    if (!dateObj) return "";
    const d = new Date(dateObj);
    if (isNaN(d.getTime())) return "";
    const hours = d.getHours() + 1, calcDate = new Date(d);
    
    const shiftDef = workShifts.find(s => normalizeShift(getField(s, 'craa5_shiftcode')) === shiftLabel);
    if (shiftDef) {
        const startHour = getField(shiftDef, 'craa5_shiftstarthour');
        const endHour = getField(shiftDef, 'craa5_shiftendhour');
        if (startHour > endHour && hours < endHour) calcDate.setDate(calcDate.getDate() - 1);
    } else {
        if ((shiftLabel === 'B' || shiftLabel === 'D') && hours < 14) calcDate.setDate(calcDate.getDate() - 1);
    }
    return `${calcDate.getFullYear()}-${String(calcDate.getMonth() + 1).padStart(2, '0')}-${String(calcDate.getDate()).padStart(2, '0')}`;
}

function normalizeShift(val) {
    if (val === null || val === undefined) return "Unassigned";
    let str = typeof val === 'object' ? String(val.Label || val.Value || "") : String(val);
    const upper = str.toUpperCase();
    if (upper === "1" || upper.includes("256000000") || upper === "A") return "A";
    if (upper === "2" || upper.includes("256000001") || upper === "B") return "B";
    if (upper === "3" || upper.includes("256000002") || upper === "C") return "C";
    if (upper === "4" || upper.includes("256000003") || upper === "D") return "D";
    return "Unassigned";
}

function formatFullName(name) {
    if (!name) return "";
    const parts = name.split(",");
    return parts.length > 1 ? `${parts.slice(1).join(",").trim()} ${parts[0].trim()}` : name.trim();
}

function formatDuration(startTimeIso, endTimeIso = null, currentNowMs = Date.now()) {
    if (!startTimeIso) return "0m";
    const startMs = new Date(startTimeIso).getTime(), endMs = endTimeIso ? new Date(endTimeIso).getTime() : currentNowMs;
    const diffMs = Math.max(0, endMs - startMs), diffMins = Math.floor(diffMs / 60000);
    const hrs = Math.floor(diffMins / 60), mins = diffMins % 60;
    return hrs > 0 ? `${hrs}h ${mins}m` : `${mins}m`;
}

function getLocalTimeString() { const now = new Date(); return `${String(now.getHours()).padStart(2, '0')}:${String(now.getMinutes()).padStart(2, '0')}`; }
function getCleanBase64(dataUrl) { return dataUrl ? (dataUrl.split(',').length > 1 ? dataUrl.split(',')[1] : dataUrl) : null; }

function handleFileUpload(e, type, taskId, updateTask) {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onloadend = () => updateTask(taskId, { [type]: reader.result });
    reader.readAsDataURL(file);
}

// Resolves a name/ID against the employee table
function resolveUser(taskObj, isLead, resolvedUsers, logDebug) {
    const emailField = isLead ? 'craa5_leademail' : 'craa5_email';
    const nameField = isLead ? 'craa5_lead' : 'craa5_id';
    
    if (!isLead) {
        const uid = getField(taskObj, 'craa5_uid_associated');
        if (uid) { const u = resolvedUsers.find(x => x.id === uid || x.uidm === uid); if (u) return u.id; }
    }

    const email = getField(taskObj, emailField);
    if (email) {
        const cleanEmail = String(email).toLowerCase().trim();
        const u = resolvedUsers.find(x => x.email.toLowerCase() === cleanEmail);
        if (u) return u.id;
    }

    if (!isLead) {
        const badge = getField(taskObj, 'craa5_badgenumber');
        if (badge) {
            const cleanBadge = String(badge).trim();
            const u = resolvedUsers.find(x => x.badgeNumber === cleanBadge);
            if (u) return u.id;
        }
    }

    const name = getField(taskObj, nameField);
    if (name) {
        const cleanName = String(name).toLowerCase().trim();
        const noComma = cleanName.replace(/,/g, '');
        let u = resolvedUsers.find(x => x.name.toLowerCase().trim() === cleanName || x.name.toLowerCase().replace(/,/g, '').trim() === noComma);
        if (!u) { u = resolvedUsers.find(x => formatFullName(x.name).toLowerCase() === cleanName); }
        if (!u) {
            const parts = cleanName.split(/[\s,]+/).filter(p => p.length > 2);
            if (parts.length > 0) { u = resolvedUsers.find(x => { const dbName = x.name.toLowerCase(); return parts.every(p => dbName.includes(p)); }); }
        }
        if (u) return u.id;
    }
    
    const lookupGuid = getField(taskObj, isLead ? '_craa5_lead_value' : '_craa5_id_value');
    if (lookupGuid) { const u = resolvedUsers.find(x => x.id === lookupGuid); if (u) return u.id; }

    return null;
}

