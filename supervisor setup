function EmployeeDashboard({ currentUser, tasks, equipment, users, updateTask, logDebug }) {
    const { t, lang } = useTranslation();
    useEffect(() => { logDebug(`[NAV] Employee Dashboard Mounted for ${currentUser?.name}`); }, []);
    
    const todaysTasks = tasks.filter(tTask => tTask.logicalDate === currentUser.logicalDateContext && tTask.shift === currentUser.shift);
    const myActiveTasks = todaysTasks.filter(tTask => tTask.empId === currentUser.id && tTask.isActiveQueue);

    const handleRequestInspection = (taskId) => updateTask(taskId, { status: 'pending_inspection', inspectionTime: new Date().toISOString() });
    const handleMarkComplete = (taskId) => updateTask(taskId, { status: 'done', isCompleteBool: true, inspectionTime: new Date().toISOString(), endTime: new Date().toISOString() });

    if (myActiveTasks.length === 0) return (
        <div className="flex flex-col items-center justify-center h-64 bg-white rounded-xl shadow-sm border border-gray-200 p-6 text-center"><AlertCircle className="w-12 h-12 text-gray-400 mb-4" /><h3 className="text-xl font-bold text-gray-800">{t("No Active Assignments")}</h3><p className="text-gray-500 mt-2">{t("You have no active tasks assigned to you for today's shift.")}</p></div>
    );

    if (myActiveTasks.length === 1 && !myActiveTasks[0].equipId && !myActiveTasks[0].equipNameFallback) {
        const lead = users.find(u => u.id === myActiveTasks[0].leadId);
        return (
            <div className="flex flex-col items-center justify-center h-64 bg-white rounded-xl shadow-sm border border-gray-200 p-6 text-center">
                <UserCircle className="w-16 h-16 text-blue-500 mb-4" /><h3 className="text-xl font-bold text-gray-800">{t("Team:")} {formatFullName(lead?.name)}</h3>
                {myActiveTasks[0].area && <p className="text-gray-600 mt-1 font-medium bg-gray-100 px-3 py-1 rounded-full inline-block">{t("Assigned Area:")} {t(myActiveTasks[0].area)}</p>}
                <p className="text-gray-500 mt-4">{t("You are assigned to this team, but no equipment has been allocated yet.")}</p><Badge status="working" className="mt-6 px-4 py-1.5 text-sm shadow-sm">{t("Standby - Awaiting Lead")}</Badge>
            </div>
        );
    }

    const workingTasks = myActiveTasks.filter(tTask => tTask.equipId || tTask.equipNameFallback);
    return (
        <div className="max-w-4xl mx-auto space-y-6">
            <h2 className="text-2xl font-bold text-gray-800 mb-2 px-2">{t("My Assigned Queue")} ({workingTasks.length})</h2>
            {workingTasks.map(myTask => {
                const myEquip = equipment.find(e => e.id === myTask.equipId);
                const equipNameDisplay = (lang === 'es' && myEquip?.esName) ? myEquip.esName : t(myEquip?.name || myTask.equipNameFallback);
                return (
                    <div key={myTask.id} className="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden mb-6">
                        <div className="bg-blue-600 px-6 py-6 text-white text-center flex flex-col justify-center items-center relative">
                            <h2 className="text-2xl font-bold">{t(equipNameDisplay)} {myEquip?.isSynthetic && <span className="text-xs bg-blue-700 px-2 py-0.5 rounded ml-2 align-middle">{t("Auto-Generated")}</span>}</h2>
                            <p className="text-blue-100 mt-1 text-sm">{t(myEquip?.area || myTask.area || 'Unspecified Area')}</p>
                        </div>
                        <div className="p-6 space-y-6">
                            <div className="flex justify-between items-center p-4 bg-gray-50 rounded-lg border border-gray-100">
                                <div><p className="text-sm text-gray-500 font-medium mb-1">{t("Current Status")}</p><Badge status={myTask.status} /></div>
                                <div className="text-right"><p className="text-sm text-gray-500 font-medium mb-1 flex items-center justify-end gap-1"><Clock className="w-4 h-4" /> {t("Time on Task")}</p><p className="text-xl font-bold text-gray-800"><TaskTimer startTime={myTask.startTime} inspectionTime={myTask.inspectionTime} status={myTask.status} /></p></div>
                            </div>
                            {myTask.whatIsLeftToDo && (
                                <div className="bg-orange-50 p-4 rounded-lg border border-orange-200"><p className="text-xs font-bold text-orange-800 uppercase tracking-wider mb-1">{t("What is left to do?")}</p><p className="text-sm text-orange-900">{myTask.whatIsLeftToDo}</p></div>
                            )}
                            <div>
                                <h3 className="text-[15px] font-semibold text-gray-800 flex items-center gap-2 mb-3"><Camera className="w-4 h-4 text-gray-500" /> {t("Verification Photos")}</h3>
                                <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                    <PhotoUploader label="Before Cleaning" imageBase64={myTask.beforePicture} onUpload={(e) => handleFileUpload(e, 'beforePicture', myTask.id, updateTask)} />
                                    <PhotoUploader label="After Cleaning" imageBase64={myTask.afterPicture} onUpload={(e) => handleFileUpload(e, 'afterPicture', myTask.id, updateTask)} />
                                </div>
                            </div>
                            <div className="pt-2 flex flex-col sm:flex-row gap-3">
                                {myTask.status === 'working' || myTask.status === 'reclean' ? (
                                    <><Button size="lg" variant="success" className="w-full flex-1 shadow-sm font-bold" onClick={() => handleMarkComplete(myTask.id)}><CheckCircle2 className="w-5 h-5 mr-2 flex-shrink-0" /> {t("Mark Complete")}</Button>
                                    <Button size="lg" variant="outline" className="w-full flex-1 shadow-sm bg-white" onClick={() => handleRequestInspection(myTask.id)}><ShieldCheck className="w-5 h-5 mr-2 flex-shrink-0" /> {t("Request Inspection")}</Button></>
                                ) : myTask.status === 'pending_inspection' ? (
                                    <><Button size="lg" variant="success" className="w-full shadow-sm font-bold" onClick={() => handleMarkComplete(myTask.id)}><CheckCircle2 className="w-5 h-5 mr-2 flex-shrink-0" /> {t("Mark Complete")}</Button>
                                    <div className="w-full text-center p-3 bg-yellow-50 text-yellow-800 rounded-lg border border-yellow-200 flex-1"><p className="font-medium flex items-center justify-center"><AlertCircle className="w-4 h-4 mr-2" /> {t("Inspection Requested")}</p></div></>
                                ) : null}
                            </div>
                        </div>
                    </div>
                );
            })}
        </div>
    );
}

function LeadDashboard({ currentUser, tasks, users, equipment, areas, updateTask, createTasks, deleteTask, logDebug }) {
    const { t, lang } = useTranslation();
    useEffect(() => { logDebug(`[NAV] Lead Dashboard Mounted for ${currentUser?.name}`); }, []);

    const [customEquipment, setCustomEquipment] = useState([]);
    const [newCustomTaskName, setNewCustomTaskName] = useState('');
    const [manualAreas, setManualAreas] = useState([]);
    const [activeTouchMove, setActiveTouchMove] = useState(null);
    const [reassignFlow, setReassignFlow] = useState(null); 
    const [reassignModalOpen, setReassignModalOpen] = useState(false);
    const [selectedEmpForReassign, setSelectedEmpForReassign] = useState(null);
    const [selectedNewLead, setSelectedNewLead] = useState('');

    const allEquipment = [...equipment, ...customEquipment];
    
    const todaysTasks = tasks.filter(tTask => tTask.logicalDate === currentUser.logicalDateContext && tTask.shift === currentUser.shift);
    const myTasks = todaysTasks.filter(tTask => tTask.leadId === currentUser.id);
    const activeTasks = myTasks.filter(tTask => tTask.isActiveQueue);
    const doneTasks = myTasks.filter(tTask => tTask.status === 'done' || tTask.status === 'incomplete' || tTask.status === 'ended_incomplete');

    const employeeLatestLead = {};
    users.forEach(emp => {
        const empTasksToday = todaysTasks.filter(tTask => tTask.empId === emp.id);
        if (empTasksToday.length > 0) {
            empTasksToday.sort((a,b) => new Date(b.startTime).getTime() - new Date(a.startTime).getTime());
            employeeLatestLead[emp.id] = empTasksToday[0].leadId;
        }
    });

    const myTeamEmps = users.filter(u => employeeLatestLead[u.id] === currentUser.id && u.id !== currentUser.id);
    const dbAssignedAreas = new Set(myTasks.filter(tTask => tTask.area && tTask.area.trim() !== "").map(tTask => tTask.area.trim()));
    const activeAreasList = Array.from(new Set([...Array.from(dbAssignedAreas), ...manualAreas])).sort();
    
    const equipByArea = {};
    activeAreasList.forEach(area => equipByArea[area] = []);
    allEquipment.forEach(eq => { if (equipByArea[eq.area ? eq.area.trim() : "Other Area"] !== undefined) equipByArea[eq.area ? eq.area.trim() : "Other Area"].push(eq); });

    const allGlobalAreas = Array.from(new Set([...allEquipment.map(e => e.area ? e.area.trim() : "Other Area"), ...areas.map(a => a.name)])).filter(Boolean).sort();
    const allLeads = users.filter(u => u.role === 'lead' && u.id !== currentUser.id && u.shift === currentUser.shift);

    const triggerInterceptor = (empId, targetArea, targetEquipId, targetEquipName) => {
        logDebug(`[INTERACTION] Lead reassigning Emp ID: ${empId} to Area: ${targetArea}, Equip: ${targetEquipName}`);
        const currentWorkingTask = activeTasks.find(task => task.empId === empId && (task.equipId || task.equipNameFallback));
        
        if (currentWorkingTask) {
            if (currentWorkingTask.equipId === targetEquipId && currentWorkingTask.area === targetArea && currentWorkingTask.equipNameFallback === targetEquipName) {
                logDebug(`[INTERCEPTOR] 1:1 Match found. Ignored duplicate drop.`);
                return; 
            }
            logDebug(`[INTERCEPTOR] New 1:1 assignment detected. Triggering completion prompt for previous task.`);
            setReassignFlow({ oldTask: currentWorkingTask, newTaskPayload: { id: `task_${Date.now()}_${Math.random()}`, empId, leadId: currentUser.id, equipId: targetEquipId, equipNameFallback: targetEquipName, area: targetArea, status: 'working', startTime: new Date().toISOString() }, isComplete: true, leftText: '' });
        } else {
            const standbyTask = activeTasks.find(task => task.empId === empId && !task.equipId && !task.equipNameFallback);
            if (standbyTask) updateTask(standbyTask.id, { equipId: targetEquipId, equipNameFallback: targetEquipName, area: targetArea, status: 'working' });
            else createTasks([{ id: `task_${Date.now()}_${Math.random()}`, empId, leadId: currentUser.id, equipId: targetEquipId, equipNameFallback: targetEquipName, area: targetArea, status: 'working', startTime: new Date().toISOString() }]);
        }
    };

    const processMoveToArea = (empId, targetArea) => {
        const areaGenEquip = allEquipment.find(eq => eq.isSynthetic && (eq.area || '').toLowerCase() === targetArea.toLowerCase());
        triggerInterceptor(empId, targetArea, areaGenEquip ? areaGenEquip.id : null, areaGenEquip ? 'General' : '');
    };
    const processMoveToEquipment = (empId, equipObj) => triggerInterceptor(empId, equipObj.area, equipObj.id.startsWith('custom_') ? null : equipObj.id, equipObj.name);

    const handleReassignLead = () => {
        if (selectedEmpForReassign && selectedNewLead) {
            const userActiveTasks = activeTasks.filter(tTask => tTask.empId === selectedEmpForReassign.id);
            userActiveTasks.forEach(tTask => updateTask(tTask.id, { status: 'done', isCompleteBool: true, inspectionTime: new Date().toISOString(), endTime: new Date().toISOString() }));
            createTasks([{ id: `task_${Date.now()}_${Math.random()}`, empId: selectedEmpForReassign.id, leadId: selectedNewLead, equipId: null, equipNameFallback: "", area: "", status: 'assigned', startTime: new Date().toISOString() }]);
            setReassignModalOpen(false);
            setSelectedEmpForReassign(null);
            setSelectedNewLead('');
        }
    };

    return (
        <div className="flex flex-col lg:flex-row gap-6 items-start h-[calc(100vh-140px)] relative">
            {activeTouchMove && !reassignFlow && (
                <div className="fixed bottom-0 left-0 right-0 bg-blue-700 text-white p-4 z-40 flex justify-between items-center shadow-[0_-10px_40px_rgba(0,0,0,0.2)] animate-in slide-in-from-bottom-5">
                    <div><p className="font-bold text-base">{t("Select a destination for")} {activeTouchMove.empName}</p><p className="text-sm text-blue-200">{t("Tap any Area or Equipment to assign them.")}</p></div>
                    <Button size="md" variant="secondary" className="bg-white text-blue-700 hover:bg-gray-100 border-none" onClick={() => setActiveTouchMove(null)}>{t("Cancel Move")}</Button>
                </div>
            )}
            
            {/* REASSIGNMENT MODAL */}
            {reassignFlow && (
                <div className="fixed inset-0 bg-black/70 flex items-center justify-center z-50 p-4 backdrop-blur-sm">
                    <div className="max-w-lg w-full bg-white rounded-2xl shadow-2xl border border-gray-100 overflow-hidden animate-in zoom-in-95">
                        <div className="px-6 py-5 bg-blue-600 text-white flex items-center gap-3"><ArrowRightLeft className="w-6 h-6" /><div><h3 className="text-xl font-bold">{t("Task Reassignment")}</h3><p className="text-blue-100 text-sm">{t("Ending previous task on")} <strong>{t(reassignFlow.oldTask.equipNameFallback || "General")}</strong></p></div></div>
                        <div className="p-6 space-y-6">
                            <div>
                                <label className="block text-base font-bold text-gray-800 mb-3">{t("Is this task completely finished?")}</label>
                                <div className="flex gap-3">
                                    <button className={`flex-1 py-3 px-4 rounded-xl border-2 font-bold transition-all ${reassignFlow.isComplete ? 'bg-green-50 border-green-500 text-green-700' : 'bg-white border-gray-200 text-gray-500 hover:border-gray-300'}`} onClick={() => setReassignFlow({...reassignFlow, isComplete: true})}><CheckCircle2 className={`w-5 h-5 mx-auto mb-1 ${reassignFlow.isComplete ? 'text-green-500' : 'text-gray-400'}`} />{t("Yes, it is complete")}</button>
                                    <button className={`flex-1 py-3 px-4 rounded-xl border-2 font-bold transition-all ${!reassignFlow.isComplete ? 'bg-orange-50 border-orange-500 text-orange-700' : 'bg-white border-gray-200 text-gray-500 hover:border-gray-300'}`} onClick={() => setReassignFlow({...reassignFlow, isComplete: false})}><AlertCircle className={`w-5 h-5 mx-auto mb-1 ${!reassignFlow.isComplete ? 'text-orange-500' : 'text-gray-400'}`} />{t("No, it is incomplete")}</button>
                                </div>
                            </div>
                            {!reassignFlow.isComplete && (
                                <div className="animate-in fade-in slide-in-from-top-2"><label className="block text-sm font-bold text-gray-700 mb-2">{t("What is left to do?")} *</label><textarea className="w-full p-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none" rows="3" placeholder={t("Provide details...")} value={reassignFlow.leftText} onChange={(e) => setReassignFlow({...reassignFlow, leftText: e.target.value})} autoFocus /></div>
                            )}
                        </div>
                        <div className="bg-gray-50 px-6 py-4 flex justify-end gap-3 border-t border-gray-100">
                            <Button variant="secondary" onClick={() => setReassignFlow(null)}>{t("Cancel")}</Button>
                            <Button variant="primary" disabled={!reassignFlow.isComplete && !reassignFlow.leftText.trim()} onClick={() => {
                                if (reassignFlow.isComplete) updateTask(reassignFlow.oldTask.id, { status: 'done', isCompleteBool: true, inspectionTime: new Date().toISOString(), endTime: new Date().toISOString() });
                                else updateTask(reassignFlow.oldTask.id, { endTime: new Date().toISOString(), whatIsLeftToDo: reassignFlow.leftText, status: 'ended_incomplete', isCompleteBool: false });
                                createTasks([reassignFlow.newTaskPayload]);
                                setReassignFlow(null);
                            }}>{t("Save & Move Employee")}</Button>
                        </div>
                    </div>
                </div>
            )}

            <div className="w-full lg:w-1/4 bg-white p-5 rounded-xl border border-gray-200 shadow-sm flex flex-col h-full flex-shrink-0">
                <div className="flex justify-between items-center mb-4 border-b border-gray-100 pb-3"><h3 className="font-bold text-lg text-gray-800 flex items-center"><Users className="w-5 h-5 mr-2 text-blue-600" /> {t("My Team Roster")}</h3><Badge status="working" className="!bg-blue-100 !text-blue-800">{myTeamEmps.length}</Badge></div>
                <div className="space-y-3 overflow-y-auto custom-scrollbar flex-1 pr-1">
                    {myTeamEmps.map(emp => {
                        const empActiveTasks = activeTasks.filter(task => task.empId === emp.id);
                        const equipCount = empActiveTasks.filter(task => task.equipId || task.equipNameFallback).length;
                        const isWorking = equipCount > 0;
                        const isSelected = activeTouchMove?.empId === emp.id;

                        return (
                            <div key={emp.id} className={`p-3 hover:bg-gray-50 border rounded-lg flex items-center justify-between shadow-sm transition-all ${isSelected ? 'border-blue-500 bg-blue-50 ring-2 ring-blue-200' : 'border-gray-200 bg-white'}`}>
                                <div draggable onDragStart={(e) => { e.dataTransfer.setData('empId', emp.id); e.dataTransfer.setData('source', 'roster'); }} onClick={() => setActiveTouchMove(isSelected ? null : { empId: emp.id, source: 'roster', empName: formatFullName(emp.name) })} className="flex flex-col cursor-pointer flex-1" style={{ touchAction: 'none' }}>
                                    <div className="flex items-center"><UserCircle className={`w-5 h-5 mr-2 ${isWorking ? 'text-green-500' : 'text-blue-500'}`} /> <span className="font-medium text-sm text-gray-800">{formatFullName(emp.name)}</span></div>
                                    {isWorking ? (
                                        <span className="ml-7 mt-1 text-[10px] font-bold uppercase tracking-wider text-green-700 bg-green-100 px-2 py-0.5 rounded w-fit border shadow-sm border-green-200">{t("Queued Tasks:")} {equipCount}</span>
                                    ) : (
                                        <span className="ml-7 mt-1 text-[10px] font-bold uppercase tracking-wider text-blue-700 bg-blue-100 px-2 py-0.5 rounded w-fit border shadow-sm border-blue-200">{t("Standby")}</span>
                                    )}
                                </div>
                                <Button size="sm" variant="secondary" className="px-2 py-1 bg-white border border-gray-200 ml-2" onClick={() => { setSelectedEmpForReassign({ id: emp.id }); setReassignModalOpen(true); }}><ArrowRightLeft className="w-3 h-3 text-gray-500 hover:text-blue-600" /></Button>
                            </div>
                        );
                    })}
                    {myTeamEmps.length === 0 && <div className="text-center py-10 px-4 border-2 border-dashed border-gray-200 rounded-xl"><CheckCircle2 className="w-8 h-8 mx-auto text-gray-300 mb-2" /><p className="text-gray-500 text-sm">{t("No team members assigned today.")}</p></div>}
                </div>
            </div>
            <div className="w-full lg:w-3/4 flex flex-col h-full overflow-hidden">
                <div className="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-4 bg-white p-3 rounded-xl border border-gray-200 shadow-sm flex-shrink-0 gap-3">
                    <div><h2 className="font-bold text-gray-800 text-lg">{t("Assigned Areas")}</h2><p className="text-xs text-gray-500">{t("Managing")} {activeAreasList.length} {t("areas for today's shift.")}</p></div>
                    <div className="flex items-center gap-2 w-full sm:w-auto">
                        <select className="text-sm border-gray-300 rounded-md p-2 border outline-none bg-gray-50 hover:bg-white focus:ring-2 focus:ring-blue-500 font-medium" onChange={(e) => { if(e.target.value && !manualAreas.includes(e.target.value)) setManualAreas([...manualAreas, e.target.value]); e.target.value = ""; }} defaultValue="">
                            <option value="" disabled>{t("+ Manually Open Area")}</option>
                            {allGlobalAreas.filter(a => !activeAreasList.includes(a)).map(a => <option key={a} value={a}>{t(a)}</option>)}
                        </select>
                    </div>
                </div>
                <div className="flex-1 space-y-6 overflow-y-auto pr-2 pb-12 custom-scrollbar">
                    {activeAreasList.length === 0 && <div className="flex flex-col items-center justify-center h-64 bg-white rounded-xl shadow-sm border border-gray-200 p-6 text-center border-dashed border-2"><PlusCircle className="w-12 h-12 text-gray-300 mb-4" /><h3 className="text-lg font-bold text-gray-800">{t("No Areas Active")}</h3><p className="text-gray-500 mt-1 text-sm max-w-md">{t("You have no tasks assigned to specific areas today. Use the dropdown above to manually open an area from the master list.")}</p></div>}
                    {activeAreasList.map(area => {
                        const equips = equipByArea[area] || [];
                        const partitionedEquips = equips.map(eq => {
                            const eqActiveTasks = activeTasks.filter(task => task.equipId === eq.id || task.equipNameFallback?.toLowerCase() === eq.name?.toLowerCase());
                            const eqDoneTasks = doneTasks.filter(task => task.equipId === eq.id || task.equipNameFallback?.toLowerCase() === eq.name?.toLowerCase());
                            const eqNATasks = myTasks.filter(task => task.status === 'not_applicable' && (task.equipId === eq.id || task.equipNameFallback?.toLowerCase() === eq.name?.toLowerCase()));
                            return { eq, eqActiveTasks, eqDoneTasks, eqNATasks, isDone: eqDoneTasks.length > 0 && eqActiveTasks.length === 0, isNA: eqNATasks.length > 0 && eqActiveTasks.length === 0 && !(eqDoneTasks.length > 0 && eqActiveTasks.length === 0) };
                        });
                        const activeOrPending = partitionedEquips.filter(x => !x.isDone && !x.isNA), completedOrNA = partitionedEquips.filter(x => x.isDone || x.isNA);
                        return (
                            <div key={area} className="bg-white rounded-xl border border-gray-200 overflow-hidden shadow-sm">
                                <div className={`px-5 py-4 flex justify-between items-center transition-colors cursor-pointer ${activeTouchMove ? 'bg-blue-800 ring-4 ring-inset ring-blue-400 animate-pulse' : 'bg-gray-800 text-white'}`} onClick={() => { if (activeTouchMove) { processMoveToArea(activeTouchMove.empId, area); setActiveTouchMove(null); } }} onDragOver={e => { e.preventDefault(); e.currentTarget.classList.add('bg-gray-700'); }} onDragLeave={e => e.currentTarget.classList.remove('bg-gray-700')} onDrop={e => { e.currentTarget.classList.remove('bg-gray-700'); e.preventDefault(); const empId = e.dataTransfer.getData('empId'); if (empId) processMoveToArea(empId, area); }}>
                                    <h3 className="font-bold text-lg tracking-wide uppercase text-white">{t(area)} {activeTouchMove && <span className="ml-2 text-xs bg-white text-blue-800 px-2 py-1 rounded-full">{t("Tap here to assign to area")}</span>}</h3>
                                    <Button size="sm" variant="secondary" className="text-xs py-1.5 px-3 bg-white/10 hover:bg-white/20 text-white border-white/20 shadow-none font-bold" onClick={(e) => { e.stopPropagation(); const name = prompt(t("Enter custom task name:")); if (name && name.trim()) setCustomEquipment([...customEquipment, { id: `custom_${Date.now()}`, name: name.trim(), area }]); }}>{t("+ Custom Task")}</Button>
                                </div>
                                <div className="divide-y divide-gray-100">
                                    {equips.length === 0 ? <p className="text-center py-6 text-gray-500 text-sm bg-gray-50 border-dashed border-2 m-4 rounded-lg">{t("No equipment generated for this area.")}</p> : (
                                        <>{activeOrPending.map(item => <EquipmentNode key={item.eq.id} {...item} users={users} lang={lang} activeTouchMove={activeTouchMove} onDropEquipment={(e) => { e.preventDefault(); const empId = e.dataTransfer.getData('empId'); if (empId) processMoveToEquipment(empId, item.eq); }} onTapEquipment={() => { if (activeTouchMove) { processMoveToEquipment(activeTouchMove.empId, item.eq); setActiveTouchMove(null); } }} updateTask={updateTask} createTasks={createTasks} deleteTask={deleteTask} />)}
                                        {activeOrPending.length > 0 && completedOrNA.length > 0 && <div className="bg-gray-100 text-gray-500 text-xs font-bold uppercase tracking-wider px-5 py-2 border-y border-gray-200">{t("Completed / Not Applicable")}</div>}
                                        {completedOrNA.map(item => <EquipmentNode key={item.eq.id} {...item} users={users} lang={lang} activeTouchMove={activeTouchMove} onDropEquipment={(e) => { e.preventDefault(); const empId = e.dataTransfer.getData('empId'); if (empId) processMoveToEquipment(empId, item.eq); }} onTapEquipment={() => { if (activeTouchMove) { processMoveToEquipment(activeTouchMove.empId, item.eq); setActiveTouchMove(null); } }} updateTask={updateTask} createTasks={createTasks} deleteTask={deleteTask} />)}</>
                                    )}
                                </div>
                            </div>
                        );
                    })}
                </div>
            </div>
        </div>
    );
}

function EquipmentNode({ eq, eqActiveTasks, eqDoneTasks, eqNATasks, isDone, isNA, users, lang, activeTouchMove, onDropEquipment, onTapEquipment, updateTask, createTasks, deleteTask }) {
    const { t } = useTranslation();
    const [completeTime, setCompleteTime] = useState(getLocalTimeString());
    const primaryDoneTask = eqDoneTasks?.[0];
    const doneTimeValue = primaryDoneTask?.inspectionTime ? `${String(new Date(primaryDoneTask.inspectionTime).getHours()).padStart(2, '0')}:${String(new Date(primaryDoneTask.inspectionTime).getMinutes()).padStart(2, '0')}` : getLocalTimeString();

    return (
