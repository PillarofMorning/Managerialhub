                                                <div className="w-full sm:w-1/2">
                                                    <SupervisorEquipmentSelector currentEquipId={leadSelfTask?.equipId} currentEquipNameFallback={leadSelfTask?.equipNameFallback} equipmentList={equipment} equipByArea={allEquipByArea} onAssign={(type, val) => handleAssignLeadSelfTask(lead.id, leadSelfTask, type, val)} />
