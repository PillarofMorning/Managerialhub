                                />
                            )}
                        </div>

                        <div style={{ display: 'flex', flexDirection: 'column' }}>
                            <Text size={200} weight="semibold">Area (Req)</Text>
                            {row.isNewAsset || row.overrideAssetDetails ? (
                                <Select 
                                    value={row.new_area} 
                                    onChange={(e, data) => handleInputChange(index, 'new_area', data.value)}
                                    required
                                    style={{ minWidth: '120px' }}
                                >
                                    <option value="">-- Select --</option>
                                    {areaOptions.map(lbl => (
                                        <option key={lbl} value={lbl}>{lbl}</option>
                                    ))}
                                </Select>
                            ) : (
                                <Input 
                                    value={row.new_area} 
                                    readOnly 
                                    disabled 
                                    placeholder={row.craa5_title ? "Auto-filled" : ""}
                                    style={{ minWidth: '120px' }} 
                                />
                            )}
                        </div>

                        <div style={{ display: 'flex', flexDirection: 'column' }}>
                            <Text size={200} weight="semibold">Equipment (Req)</Text>
                            <Input
                                placeholder={row.isNewAsset || row.overrideAssetDetails ? "Equipment Name" : (row.craa5_title ? "Auto-filled" : "")}
                                value={row.new_equipment}
                                onChange={(e, d) => handleInputChange(index, 'new_equipment', d.value)}
                                readOnly={!row.isNewAsset && !row.overrideAssetDetails}
                                disabled={!row.isNewAsset && !row.overrideAssetDetails}
                                required
                                style={{ minWidth: '150px' }}
                            />
                        </div>
                        
                        <div style={{ display: 'flex', flexDirection: 'column' }}>
                            <Text size={200} weight="semibold">Date (Req)</Text>
                            <Input
                                type="date"
                                value={toDateString(row.craa5_field_1)}
                                onChange={(e, d) => handleInputChange(index, 'craa5_field_1', fromDateString(d.value))}
                                min={minDateStr}
                                max={maxDateStr}
                                style={{ minWidth: '140px' }}
                                required
                            />
                        </div>

                        <div style={{ display: 'flex', flexDirection: 'column' }}>
                            <Text size={200} weight="semibold">Hours (Req)</Text>
                            <Input
                                type="number"
                                placeholder="Ex: 2.5"
                                value={row.craa5_hoursworked?.toString() || ''}
                                onChange={(e, d) => handleInputChange(index, 'craa5_hoursworked', parseFloat(d.value))}
                                style={{ width: '90px' }}
                                required
                            />
                        </div>

                        <div style={{ display: 'flex', flexDirection: 'column' }}>
                            <Text size={200} weight="semibold">Initials (Req)</Text>
                            <Input
                                placeholder="Ex: JD"
                                value={row.craa5_field_2}
                                onChange={(e, d) => handleInputChange(index, 'craa5_field_2', d.value)}
                                style={{ minWidth: '80px' }}
                                required
                            />
                        </div>

                        <div style={{ display: 'flex', flexDirection: 'column' }}>
                            <Text size={200} weight="semibold">Paperwork Picture (Req)</Text>
                            <input
                                type="file"
                                accept="image/*"
                                onChange={(e) => handleFileUpload(index, e.target.files ? e.target.files[0] : null)}
                                style={{ minWidth: '150px', padding: '4px' }}
                                required={!row.craa5_pictureofpaperwork}
                            />
                        </div>

                        <Button appearance="subtle" style={{ alignSelf: 'flex-start', marginTop: '16px' }} onClick={() => handleDeleteFormRow(index)}>
                            Remove
                        </Button>
                    </div>
                </div>
            ))}

            {errorMessage && (
                <Text className={styles.errorText}>{errorMessage}</Text>
            )}

            <div style={{ display: 'flex', gap: '8px', alignItems: 'center', marginTop: '8px' }}>
                <Input
                    type="number"
                    min={1}
                    value={addRowCount.toString()}
                    onChange={(e, d) => setAddRowCount(parseInt(d.value) || 1)}
                    style={{ width: '60px' }}
                />
                <Button appearance="secondary" onClick={() => addRow(addRowCount)}>Add More Rows</Button>
            </div>
            
            <Button appearance="primary" size="large" onClick={handleSubmit} style={{ marginTop: '8px', maxWidth: '300px' }}>
                Submit All Records
            </Button>
        </div>
    );

    const renderCalendar = () => {
        const monthStart = new Date(currentMonth.getFullYear(), currentMonth.getMonth(), 1);
        const monthEnd = new Date(currentMonth.getFullYear(), currentMonth.getMonth() + 1, 0);
        const startDay = monthStart.getDay();
        const daysInMonth = monthEnd.getDate();

        const prevMonthDays = Array.from({ length: startDay }, (_, i) => null);
        const currentMonthDays = Array.from({ length: daysInMonth }, (_, i) => new Date(currentMonth.getFullYear(), currentMonth.getMonth(), i + 1));
        const allDays = [...prevMonthDays, ...currentMonthDays];

        const weeks: (Date | null)[][] = [];
        for (let i = 0; i < allDays.length; i += 7) {
            weeks.push(allDays.slice(i, i + 7));
        }

        const weekdays = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];

        const entriesByDate: Record<string, WeeklyEntry[]> = {};
        weeklyEntries.forEach(entry => {
            if (entry.craa5_field_1) {
                const key = entry.craa5_field_1.toDateString();
                if (!entriesByDate[key]) entriesByDate[key] = [];
                entriesByDate[key].push(entry);
            }
        });

        return (
            <div>
                <div className={styles.calendarHeader}>
                    <Button onClick={() => setCurrentMonth(new Date(currentMonth.getFullYear(), currentMonth.getMonth() - 1, 1))}>Previous</Button>
                    <Text weight="semibold">{currentMonth.toLocaleString('default', { month: 'long', year: 'numeric' })}</Text>
                    <Button onClick={() => setCurrentMonth(new Date(currentMonth.getFullYear(), currentMonth.getMonth() + 1, 1))}>Next</Button>
                </div>
                <div className={styles.calendarGrid}>
                    {weekdays.map(day => (
                        <div key={day} className={styles.weekdayHeader}>{day}</div>
                    ))}
                    {weeks.flat().map((day, idx) => {
                        const key = day ? day.toDateString() : `empty-${idx}`;
                        const entries = day ? entriesByDate[key] || [] : [];
                        return (
                            <div key={key} className={styles.dayCell}>
                                {day && <div className={styles.dayNumber}>{day.getDate()}</div>}
                                {entries.map((entry, i) => (
                                    <div key={i} className={styles.entryText}>{entry.craa5_title} - {entry.craa5_field_2}</div>
                                ))}
                            </div>
                        );
                    })}
                </div>
            </div>
        );
    };

    return (
        <div className={styles.container}>
            <TabList
                selectedValue={activeTab}
                onTabSelect={(_, data) => setActiveTab(data.value as any)}
                className={styles.navBar}
            >
                <Tab value="add" className={mergeClasses(styles.tabLightRed, activeTab === 'add' && styles.activeTab)}>Add Log Entries</Tab>
                <Tab value="table" className={mergeClasses(styles.tabLightRed, activeTab === 'table' && styles.activeTab)}>Log Table</Tab>
                <Tab value="dashboard" className={mergeClasses(styles.tabLightRed, activeTab === 'dashboard' && styles.activeTab)}>Dashboard</Tab>
                <Tab value="calendar" className={mergeClasses(styles.tabLightRed, activeTab === 'calendar' && styles.activeTab)}>Calendar</Tab>
            </TabList>

            <div className={styles.mainContent}>
                {activeTab === 'add' && (
                    <>
                        <div className={styles.sidebar}>
                            <Text size={500} weight="semibold" block style={{ marginBottom: '8px' }}>Recent Log Entries</Text>
                            <ul style={{ paddingLeft: '20px' }}>
                                {weeklyEntries.slice(0, 10).map(entry => (
                                    <li key={entry.craa5_logid} style={{ marginBottom: '4px' }}>
                                        {entry.craa5_field_1?.toLocaleDateString()} - <strong>{entry.craa5_title}</strong> (Initials: {entry.craa5_field_2})
                                    </li>
                                ))}
                            </ul>
                        </div>
                        <div className={styles.contentArea}>
                            <Text size={600} weight="semibold" block className={styles.sectionTitle}>Add Log Entries</Text>
                            {renderForm()}
                        </div>
                    </>
                )}
                {activeTab === 'table' && (
                    <div className={styles.contentArea}>
                        <Text size={600} weight="semibold" block className={styles.sectionTitle}>Log Table</Text>
                        {renderTable()}
                    </div>
                )}
                {activeTab === 'dashboard' && (
                    <div className={styles.contentArea}>
                        <Text size={600} weight="semibold" block className={styles.sectionTitle}>Dashboard Metrics</Text>
                        {renderDashboard()}
                    </div>
                )}
                {activeTab === 'calendar' && (
                    <div className={styles.contentArea}>
                        <Text size={600} weight="semibold" block className={styles.sectionTitle}>Calendar View</Text>
                        {renderCalendar()}
                    </div>
                )}
            </div>
        </div>
    );
};

export default GeneratedComponent;
