        updatedRows[index][field] = value as never; 
        
        if (field === 'overrideAssetDetails') {
            const isChecked = value as boolean;
            updatedRows[index].overrideAssetDetails = isChecked;
            
            // If they uncheck the box, reset the fields back to what the master list says
            if (!isChecked && updatedRows[index].craa5_title) {
                const matchedAsset = knownAssets.find(asset => 
                    asset.craa5_olduid === updatedRows[index].craa5_title || 
                    asset.craa5_sapdaily === updatedRows[index].craa5_title || 
                    asset.craa5_sapw === updatedRows[index].craa5_title
                );

                if (matchedAsset) {
                    updatedRows[index].new_room = matchedAsset.craa5_room ? String(matchedAsset.craa5_room) : "";
                    updatedRows[index].new_area = matchedAsset.craa5_area ? String(matchedAsset.craa5_area) : "";
                    updatedRows[index].new_equipment = matchedAsset.craa5_equipment || "";
                }
            }
        }

        if (field === 'craa5_title') {
            const uidValue = value as string;
            updatedRows[index].overrideAssetDetails = false; // Reset override state on UID change

            if (!uidValue.trim()) {
                updatedRows[index].isNewAsset = false;
                updatedRows[index].new_room = '';
                updatedRows[index].new_area = '';
                updatedRows[index].new_equipment = '';
            } else {
                const matchedAsset = knownAssets.find(asset => 
                    asset.craa5_olduid === uidValue || 
                    asset.craa5_sapdaily === uidValue || 
                    asset.craa5_sapw === uidValue
                );

                if (matchedAsset) {
                    updatedRows[index].isNewAsset = false;
                    updatedRows[index].new_room = matchedAsset.craa5_room ? String(matchedAsset.craa5_room) : "";
                    updatedRows[index].new_area = matchedAsset.craa5_area ? String(matchedAsset.craa5_area) : "";
                    updatedRows[index].new_equipment = matchedAsset.craa5_equipment || "";
                } else {
                    if (!rows[index].isNewAsset) {
                        updatedRows[index].new_room = '';
                        updatedRows[index].new_area = '';
                        updatedRows[index].new_equipment = '';
                    }
                    updatedRows[index].isNewAsset = true;
                }
            }
        }
        
        setRows(updatedRows);
    };

    const handleFileUpload = (index: number, file: File | null) => {
        if (!file) {
            handleInputChange(index, 'craa5_pictureofpaperwork', null);
            return;
        }
        
        const reader = new FileReader();
        reader.onload = (e) => {
            const img = new Image();
            img.onload = () => {
                const canvas = document.createElement('canvas');
                const MAX_WIDTH = 800;
                const MAX_HEIGHT = 800;
                let width = img.width;
                let height = img.height;

                if (width > height) {
                    if (width > MAX_WIDTH) {
                        height *= MAX_WIDTH / width;
                        width = MAX_WIDTH;
                    }
                } else {
                    if (height > MAX_HEIGHT) {
                        width *= MAX_HEIGHT / height;
                        height = MAX_HEIGHT;
                    }
                }

                canvas.width = width;
                canvas.height = height;
                const ctx = canvas.getContext('2d');
                ctx?.drawImage(img, 0, 0, width, height);
                
                const dataUrl = canvas.toDataURL('image/jpeg', 0.7); 
                const base64String = dataUrl.split(',')[1];
                handleInputChange(index, 'craa5_pictureofpaperwork', base64String);
            };
            img.src = e.target?.result as string;
        };
        reader.readAsDataURL(file);
    };

