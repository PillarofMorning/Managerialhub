            alert("Rows submitted successfully! (Simulated)");
            setRows([createEmptyRow()]);
            return;
        }

        const assetPromises: Promise<any>[] = [];
        
        rows.forEach(row => {
            if (row.isNewAsset) {
                const assetPayload: any = {
                    craa5_title: row.craa5_title, 
                    craa5_olduid: row.craa5_title, 
                    craa5_equipment: row.new_equipment,
                    craa5_room: row.new_room,
                    craa5_area: row.new_area
                };

                assetPromises.push(dataApi.createRow("craa5_aa_ms_assets", assetPayload));
            } else if (row.overrideAssetDetails) {
                const matchedAsset = knownAssets.find(asset => 
                    asset.craa5_olduid === row.craa5_title || 
                    asset.craa5_sapdaily === row.craa5_title || 
                    asset.craa5_sapw === row.craa5_title
                );
                
                if (matchedAsset && matchedAsset.craa5_aa_ms_assetsid) {
                    const assetPayload: any = {
                        craa5_equipment: row.new_equipment,
                        craa5_room: row.new_room,
                        craa5_area: row.new_area
                    };

                    assetPromises.push((dataApi as any).updateRow("craa5_aa_ms_assets", matchedAsset.craa5_aa_ms_assetsid, assetPayload));
                }
            }
        });

        if (assetPromises.length > 0) {
            try {
                await Promise.all(assetPromises);
            } catch (assetErr: any) {
                console.error("Failed to update Assets dynamically", assetErr);
                const parsedError = extractDetailedError(assetErr);
                setErrorMessage(`Failed to save one or more job profiles. Details: ${parsedError}`);
                return; 
            }
        }

        const logPromises = rows.map(row => {
            const payload: any = {
                craa5_title: row.craa5_title,
                craa5_field_1: row.craa5_field_1 ?? new Date(),
                craa5_field_2: row.craa5_field_2, 
                craa5_hoursworked: row.craa5_hoursworked ?? 0,
                craa5_room: row.new_room,
                craa5_area: row.new_area,
                craa5_equipment: row.new_equipment
            };

            if (row.craa5_pictureofpaperwork) {
                payload.craa5_PictureofPaperwork = row.craa5_pictureofpaperwork;
            }

            return dataApi.createRow("craa5_log", payload);
        });

        try {
            await Promise.all(logPromises);
        } catch (logErr: any) {
            console.error("Failed to create Log Entry", logErr);
            const parsedError = extractDetailedError(logErr);
            setErrorMessage(`Failed to save log entries. Details: ${parsedError}`);
            return;
        }
        
        alert("All entries and dynamic assets submitted successfully!");
        setRows([createEmptyRow()]);
        fetchAllEntries(buildFilterExpression());
        fetchKnownAssets(); 
    };

