// Helper to aggressively pull details out of a masked PowerApps error
const extractDetailedError = (err: any): string => {
    if (!err) return "Unknown error (null or undefined)";
    
    if (typeof err === 'string') {
        if (err.includes('<REDACTED>')) return "Error was redacted by host environment. Check network tab or PowerApps monitor.";
        return err;
    }

    let details: string[] = [];
    
    if (err.message && !err.message.includes('<REDACTED>')) details.push(`Message: ${err.message}`);
    if (err.name) details.push(`Name: ${err.name}`);
    if (err.status) details.push(`Status: ${err.status}`);
    if (err.statusText) details.push(`StatusText: ${err.statusText}`);
    
    if (err.error?.message && !err.error.message.includes('<REDACTED>')) details.push(`Inner Error: ${err.error.message}`);
    if (err.raw?.message && !err.raw.message.includes('<REDACTED>')) details.push(`Raw Error: ${err.raw.message}`);
    
    if (details.length === 0 || (err.message && err.message.includes('<REDACTED>'))) {
        try {
            const props = Object.getOwnPropertyNames(err);
            for (const prop of props) {
                const val = err[prop];
                if ((typeof val === 'string' && !val.includes('<REDACTED>')) || typeof val === 'number') {
                    details.push(`[${prop}]: ${val}`);
                }
            }
        } catch (e) {}
    }

    if (details.length === 0) {
        try {
            const str = JSON.stringify(err);
            if (str && str !== '{}') return str;
        } catch (e) {}
        return "Host environment completely redacted the error. Please check browser developer tools (Network Tab).";
    }

    return details.join(' | ');
};

const GeneratedComponent: React.FC<GeneratedComponentProps> = ({ dataApi }) => {
    const styles = useStyles();
    
    // Dynamic dropdown options state (Default fallbacks included)
    const [roomOptions, setRoomOptions] = useState<string[]>(["Bakery", "Creme", "Warehouse"]);
    const [areaOptions, setAreaOptions] = useState<string[]>(["Breading", "Highspeed", "Custard", "Dough Room"]);

    // Date Limit Logic (No future dates, no dates older than 1 year)
    const { maxDateStr, minDateStr } = useMemo(() => {
        const today = new Date();
        
        const y = today.getFullYear();
        const m = String(today.getMonth() + 1).padStart(2, '0');
        const d = String(today.getDate()).padStart(2, '0');
        const max = `${y}-${m}-${d}`;

        const oneYearAgo = new Date();
        oneYearAgo.setFullYear(today.getFullYear() - 1);
        const min_y = oneYearAgo.getFullYear();
        const min_m = String(oneYearAgo.getMonth() + 1).padStart(2, '0');
        const min_d = String(oneYearAgo.getDate()).padStart(2, '0');
        const min = `${min_y}-${min_m}-${min_d}`;

        return { maxDateStr: max, minDateStr: min };
    }, []);

    // State to hold the known assets/jobs from Dataverse (AA_MS_ASSETS)
    const [knownAssets, setKnownAssets] = useState<Asset[]>([]);

    const createEmptyRow = (date: Date | null = new Date()): LogRow => ({
        craa5_title: '', 
        craa5_field_2: '', 
        craa5_field_1: date, 
        craa5_hoursworked: null, 
        craa5_pictureofpaperwork: null,
        isNewAsset: false, 
        overrideAssetDetails: false,
        new_room: '',
        new_area: '',
        new_equipment: ''
    });

    const [rows, setRows] = useState<LogRow[]>([createEmptyRow()]);
    const [addRowCount, setAddRowCount] = useState<number>(1);
    
    // Optimized Pagination & Data Grid State
    const [logPageSize, setLogPageSize] = useState<number>(50);
    const [weeklyEntries, setWeeklyEntries] = useState<WeeklyEntry[]>([]);
    
    // Batch Edit States
    const [isTableEditMode, setIsTableEditMode] = useState<boolean>(false);
    const [tableEdits, setTableEdits] = useState<Record<string, Partial<WeeklyEntry>>>({});
    const [selectedLogIds, setSelectedLogIds] = useState<Set<string>>(new Set());

    const [errorMessage, setErrorMessage] = useState<string>('');
    const [activeTab, setActiveTab] = useState<'add' | 'table' | 'dashboard' | 'calendar'>('add');
    const containerRef = useRef<HTMLDivElement>(null);

    const [pendingSearchTerm, setPendingSearchTerm] = useState<string>('');
    const [pendingStartDate, setPendingStartDate] = useState<Date | null>(null);
    const [pendingEndDate, setPendingEndDate] = useState<Date | null>(null);

    const [currentMonth, setCurrentMonth] = useState<Date>(new Date());

    useEffect(() => {
        const savedFilters = localStorage.getItem('logFilters');
        if (savedFilters) {
            const parsed = JSON.parse(savedFilters);
            if (parsed.searchTerm) setPendingSearchTerm(parsed.searchTerm);
            if (parsed.startDate) setPendingStartDate(new Date(parsed.startDate));
            if (parsed.endDate) setPendingEndDate(new Date(parsed.endDate));
        }
        fetchAreaOptions(); // Fetch dynamic choice options from the new lookup table
        fetchAllEntries(); // Fetch historical logs
        fetchKnownAssets(); // Fetch known jobs for forecasting/autocomplete
    }, []);

    // Re-fetch when the page size is increased
    const isFirstRender = useRef(true);
    useEffect(() => {
        if (isFirstRender.current) {
            isFirstRender.current = false;
            return;
        }
        fetchAllEntries(buildFilterExpression());
    }, [logPageSize]);

    // ==========================================
    // DYNAMIC METADATA FETCH (Loads Area options from craa5_aa_mss_area)
    // ==========================================
    const fetchAreaOptions = async () => {
        if (!dataApi) return;
        try {
            // First try singular table name
            const result = await dataApi.queryTable("craa5_aa_mss_area", {
                select: ["craa5_area"] // Using common logical name casing
            });
            const areas = result?.rows?.map((r: any) => r.craa5_area || r.craa5_AREA).filter(Boolean) || [];
            if (areas.length > 0) {
                setAreaOptions(areas);
                return;
            }
        } catch (err) {
            console.warn("Could not dynamically fetch areas from 'craa5_aa_mss_area', trying plural...", err);
            // Fallback to plural table name if standard Dataverse pluralization applies
            try {
                const pluralResult = await dataApi.queryTable("craa5_aa_mss_areas", {
                    select: ["craa5_area"]
                });
                const pluralAreas = pluralResult?.rows?.map((r: any) => r.craa5_area || r.craa5_AREA).filter(Boolean) || [];
                if (pluralAreas.length > 0) {
                    setAreaOptions(pluralAreas);
                }
            } catch (err2) {
                console.error("Failed to dynamically fetch area options. Using defaults.", err2);
            }
        }
    };
    // ==========================================

    // ==========================================
    // BACKGROUND WORKER: Backfill Missing Asset Info in Logs
    // ==========================================
    useEffect(() => {
        if (knownAssets.length === 0 || weeklyEntries.length === 0) return;

        const updatesToPush: { id: string, payload: any }[] = [];

        weeklyEntries.forEach(entry => {
            // Check if the log entry is missing the dynamic asset fields
            if (!entry.craa5_room && !entry.craa5_area && !entry.craa5_equipment && entry.craa5_title) {
                const matchedAsset = knownAssets.find(asset => 
                    asset.craa5_olduid === entry.craa5_title || 
                    asset.craa5_sapdaily === entry.craa5_title || 
                    asset.craa5_sapw === entry.craa5_title
                );

                if (matchedAsset) {
                    const r_room = matchedAsset.craa5_room ? String(matchedAsset.craa5_room) : "";
                    const r_area = matchedAsset.craa5_area ? String(matchedAsset.craa5_area) : "";
                    const r_equip = matchedAsset.craa5_equipment || "";

                    if (r_room || r_area || r_equip) {
                        updatesToPush.push({
                            id: entry.craa5_logid,
                            payload: {
                                craa5_room: r_room,
                                craa5_area: r_area,
                                craa5_equipment: r_equip
                            }
                        });
                    }
                }
            }
        });

        if (updatesToPush.length > 0) {
            // 1. Instantly update UI so the user sees the backfilled data (and prevents infinite loop)
            setWeeklyEntries(prev => {
                const newEntries = [...prev];
                updatesToPush.forEach(update => {
                    const targetIdx = newEntries.findIndex(e => e.craa5_logid === update.id);
                    if (targetIdx > -1) {
                        newEntries[targetIdx] = { ...newEntries[targetIdx], ...update.payload };
                    }
                });
                return newEntries;
            });

            // 2. Fire background network requests silently to Dataverse
            if (dataApi) {
                const promises = updatesToPush.map(update => 
                    (dataApi as any).updateRow("craa5_log", update.id, update.payload)
                );
                Promise.all(promises)
                    .then(() => console.log(`Background sync successfully updated ${updatesToPush.length} log records with missing asset details.`))
                    .catch(err => console.error("Background sync failed:", err));
            }
        }
    }, [weeklyEntries, knownAssets, dataApi]);
    // ==========================================

    // Calculate Dashboard Metrics based on Loaded Entries
    const dashboardMetrics = useMemo(() => {
        let totalHours = 0;
        const uniqueJobs = new Set<string>();
        const hoursByInitials: Record<string, number> = {};

        weeklyEntries.forEach(entry => {
            const hours = entry.craa5_hoursworked || 0;
            totalHours += hours;
            
            if (entry.craa5_title) {
                uniqueJobs.add(entry.craa5_title);
            }

            const initials = (entry.craa5_field_2 || 'Unknown').toUpperCase().trim();
            if (!hoursByInitials[initials]) hoursByInitials[initials] = 0;
            hoursByInitials[initials] += hours;
        });

        // Sort initials by hours worked (descending)
        const sortedInitials = Object.entries(hoursByInitials)
            .sort((a, b) => b[1] - a[1])
            .map(([initials, hours]) => ({ initials, hours }));

        return {
            totalHours: totalHours.toFixed(1),
            totalJobs: uniqueJobs.size,
            totalEntries: weeklyEntries.length,
            hoursByInitials: sortedInitials
        };
    }, [weeklyEntries]);

    const fetchKnownAssets = async () => {
        if (!dataApi) return; 
        try {
            const result = await dataApi.queryTable("craa5_aa_ms_assets", {
                select: ["craa5_aa_ms_assetsid", "craa5_olduid", "craa5_sapdaily", "craa5_sapw", "craa5_room", "craa5_area", "craa5_equipment"],
                pageSize: 500
            });
            const mappedAssets: Asset[] = (result?.rows ?? []).map(r => ({
                craa5_aa_ms_assetsid: r.craa5_aa_ms_assetsid,
                craa5_olduid: r.craa5_olduid || '',
                craa5_sapdaily: r.craa5_sapdaily || '',
                craa5_sapw: r.craa5_sapw || '',
                craa5_room: r.craa5_room || '',
                craa5_area: r.craa5_area || '',
                craa5_equipment: r.craa5_equipment || ''
            }));
            setKnownAssets(mappedAssets);
        } catch (error) {
            console.error("Error fetching known assets:", error);
        }
    };

    const buildFilterExpression = (): string | undefined => {
        const filters: string[] = [];

        if (pendingSearchTerm) {
            const term = pendingSearchTerm.replace(/'/g, "''");
            // Native Optimization: Changed 'contains' to 'startswith' to prevent 500-record delegation limits.
            filters.push(`(startswith(craa5_title,'${term}') or startswith(craa5_field_2,'${term}'))`);
        }

        if (pendingStartDate && pendingEndDate) {
            const startIso = pendingStartDate.toISOString();
            const endIso = pendingEndDate.toISOString();
            filters.push(`craa5_field_1 ge ${startIso} and craa5_field_1 le ${endIso}`);
        } else if (pendingStartDate && !pendingEndDate) {
            const startIso = pendingStartDate.toISOString();
