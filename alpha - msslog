            e.preventDefault();
            if (index < rows.length - 1) {
                const nextInput = containerRef.current?.querySelector<HTMLInputElement>(
                    `[data-row="${index + 1}"][data-col="craa5_title"]`
                );
                nextInput?.focus();
            } else {
                addRow(1);
            }
        }
    };

    const validateRows = (): boolean => {
        const now = new Date();
        const oneYearAgo = new Date();
        oneYearAgo.setFullYear(now.getFullYear() - 1);
        
        now.setHours(23,59,59,999);
        oneYearAgo.setHours(0,0,0,0);

        for (const [index, row] of rows.entries()) {
            if (!row.craa5_title.trim() || !row.craa5_field_2.trim() || !row.craa5_field_1 || row.craa5_hoursworked === null || isNaN(row.craa5_hoursworked) || !row.craa5_pictureofpaperwork) {
                setErrorMessage(`Row ${index + 1} Error: UID, Date, Initials, Hours, and Picture are ALL strictly required.`);
                return false;
            }

            if (!row.new_room || !row.new_area || !row.new_equipment.trim()) {
                setErrorMessage(`Row ${index + 1} Error: Room, Area, and Equipment must be completed. Ensure your UID is valid or manually complete the dynamic fields.`);
                return false;
            }

            const inputDate = new Date(row.craa5_field_1);
            if (inputDate > now || inputDate < oneYearAgo) {
                setErrorMessage(`Row ${index + 1} Error: Date must be within the last year, and cannot be a future date.`);
                return false;
            }
        }
        setErrorMessage('');
        return true;
    };

