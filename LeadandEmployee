      return latestTask && latestTask.leadId === currentUser.id;
  });

  // Standby Employees (they are on our team, but their latest task is done, NA, or lacks equipment)
  const standbyEmps = myTeamEmps.filter(emp => {
      const latest = tasks.find(t => t.empId === emp.id && t.isLatestForEmp);
      if (!latest) return true;
      return latest.status === 'done' || latest.status === 'not_applicable' || (!latest.equipId && !latest.equipNameFallback);
  });

  // Extract designated areas for this lead
  const myAreasSet = new Set(myTasks.filter(t => t.area).map(t => t.area.trim()));
  if (myAreasSet.size === 0) myAreasSet.add("Default Area");

  const equipByArea = {};
  myAreasSet.forEach(area => equipByArea[area] = []);
  allEquipment.forEach(eq => {
      const area = eq.area ? eq.area.trim() : "Default Area";
      if (equipByArea[area]) {
          equipByArea[area].push(eq);
      } else if (myAreasSet.has(area)) { 
          equipByArea[area] = [eq];
      }
  });

  const handleDropOnEquipment = (e, equipObj) => {
      e.preventDefault();
      const empId = e.dataTransfer.getData('empId');
      if (!empId) return;

      const activeTask = activeTasks.find(t => t.empId === empId);
      const isCustom = equipObj.id.startsWith('custom_');
      
      if (activeTask) {
          updateTask(activeTask.id, { 
              equipId: isCustom ? null : equipObj.id, 
              equipNameFallback: equipObj.name,
              area: equipObj.area,
              status: 'working'
          });
      } else {
          createTasks([{
              id: `task_${Date.now()}_${Math.random()}`,
              empId,
              leadId: currentUser.id,
              equipId: isCustom ? null : equipObj.id,
              equipNameFallback: equipObj.name,
              area: equipObj.area,
              status: 'working',
              startTime: new Date().toISOString()
          }]);
      }
  };

  const handleMarkComplete = (equipObj, timeString) => {
      const [hours, minutes] = timeString.split(':');
      const d = new Date();
      d.setHours(parseInt(hours, 10), parseInt(minutes, 10), 0, 0);
      const isoTime = d.toISOString();

      const eqActiveTasks = activeTasks.filter(t => t.equipId === equipObj.id || t.equipNameFallback?.toLowerCase() === equipObj.name?.toLowerCase());
      eqActiveTasks.forEach(task => {
          updateTask(task.id, {
              status: 'done',
              inspectionTime: isoTime
          });
      });
  };

  const handleMarkNA = (equipObj) => {
      const eqActiveTasks = activeTasks.filter(t => t.equipId === equipObj.id || t.equipNameFallback?.toLowerCase() === equipObj.name?.toLowerCase());
      if (eqActiveTasks.length > 0) {
          eqActiveTasks.forEach(task => {
              updateTask(task.id, {
                  status: 'not_applicable',
                  inspectionTime: new Date().toISOString()
              });
          });
      } else {
          createTasks([{
              id: `task_${Date.now()}_${Math.random()}`,
              empId: currentUser.id, // assigned to lead for tracking
              leadId: currentUser.id,
              equipId: equipObj.id.startsWith('custom_') ? null : equipObj.id,
              equipNameFallback: equipObj.name,
              area: equipObj.area,
              status: 'not_applicable',
              startTime: new Date().toISOString(),
              inspectionTime: new Date().toISOString()
          }]);
      }
  };

  const handleChangeTime = (taskId, newTimeString) => {
      const [hours, minutes] = newTimeString.split(':');
      const d = new Date();
      d.setHours(parseInt(hours, 10), parseInt(minutes, 10), 0, 0);
      updateTask(taskId, { inspectionTime: d.toISOString() });
  };

  return (
    <div className="flex flex-col lg:flex-row gap-6 items-start h-[calc(100vh-140px)]">
      
      {/* LEFT SIDEBAR: STANDBY TEAM */}
      <div className="w-full lg:w-1/4 bg-white p-5 rounded-xl border border-gray-200 shadow-sm flex flex-col h-full flex-shrink-0">
          <div className="flex justify-between items-center mb-4 border-b border-gray-100 pb-3">
              <h3 className="font-bold text-lg text-gray-800 flex items-center"><Users className="w-5 h-5 mr-2 text-blue-600" /> My Standby Team</h3>
              <Badge status="working">{standbyEmps.length}</Badge>
          </div>
          <div className="space-y-3 overflow-y-auto custom-scrollbar flex-1 pr-1">
              {standbyEmps.map(emp => (
                  <div 
                      key={emp.id} 
                      draggable 
                      onDragStart={(e) => e.dataTransfer.setData('empId', emp.id)}
                      className="p-3 bg-blue-50 hover:bg-blue-100 text-blue-900 border border-blue-200 rounded-lg cursor-grab active:cursor-grabbing flex items-center shadow-sm transition-colors"
                      title="Drag to assign equipment"
                  >
                      <UserCircle className="w-5 h-5 mr-2 text-blue-500" /> 
                      <span className="font-medium text-sm">{formatFullName(emp.name)}</span>
                  </div>
              ))}
              {standbyEmps.length === 0 && (
                  <div className="text-center py-10 px-4 border-2 border-dashed border-gray-200 rounded-xl">
                      <CheckCircle2 className="w-8 h-8 mx-auto text-green-400 mb-2" />
                      <p className="text-gray-500 text-sm">All team members are assigned.</p>
                  </div>
              )}
          </div>
      </div>

      {/* RIGHT MAIN: EQUIPMENT TREE */}
      <div className="w-full lg:w-3/4 space-y-6 overflow-y-auto h-full pr-2 pb-12 custom-scrollbar">
          {Object.entries(equipByArea).map(([area, equips]) => {
              // Partition equipment into Active/Pending vs Completed/Not Applicable
              const partitionedEquips = equips.map(eq => {
                  const eqActiveTasks = activeTasks.filter(t => t.equipId === eq.id || t.equipNameFallback?.toLowerCase() === eq.name?.toLowerCase());
                  const eqDoneTasks = doneTasks.filter(t => t.equipId === eq.id || t.equipNameFallback?.toLowerCase() === eq.name?.toLowerCase());
                  const eqNATasks = tasks.filter(t => t.status === 'not_applicable' && (t.equipId === eq.id || t.equipNameFallback?.toLowerCase() === eq.name?.toLowerCase()));
                  
                  const isDone = eqDoneTasks.length > 0 && eqActiveTasks.length === 0;
                  const isNA = eqNATasks.length > 0 && eqActiveTasks.length === 0 && !isDone;

                  return { eq, eqActiveTasks, eqDoneTasks, eqNATasks, isDone, isNA };
              });

              const activeOrPending = partitionedEquips.filter(x => !x.isDone && !x.isNA);
              const completedOrNA = partitionedEquips.filter(x => x.isDone || x.isNA);

              return (
                  <div key={area} className="bg-white rounded-xl border border-gray-200 overflow-hidden shadow-sm">
                      {/* Area Header */}
                      <div className="bg-gray-800 px-5 py-4 text-white flex justify-between items-center">
                          <h3 className="font-bold text-lg tracking-wide uppercase">{area}</h3>
                          <Button size="sm" variant="secondary" className="text-xs py-1.5 px-3 bg-white/10 hover:bg-white/20 text-white border-white/20 shadow-none" onClick={() => setNewCustomTaskArea(area)}>
                              + Custom Task
                          </Button>
                      </div>
                      
                      {/* Inline Custom Task Generator */}
                      {newCustomTaskArea === area && (
                          <div className="p-4 bg-gray-50 border-b border-gray-200 flex flex-col sm:flex-row items-center gap-3">
                              <input 
                                  type="text" 
                                  autoFocus
                                  className="flex-1 p-2 text-sm border border-gray-300 rounded focus:ring-2 focus:ring-blue-500 outline-none w-full" 
                                  placeholder="Enter custom task or equipment name..." 
                                  value={newCustomTaskName} 
                                  onChange={e => setNewCustomTaskName(e.target.value)} 
                                  onKeyDown={e => {
                                      if (e.key === 'Enter' && newCustomTaskName.trim()) {
                                          setCustomEquipment([...customEquipment, { id: `custom_${Date.now()}`, name: newCustomTaskName.trim(), area }]);
                                          setNewCustomTaskName('');
                                          setNewCustomTaskArea(null);
                                      }
                                  }}
                              />
                              <div className="flex gap-2 w-full sm:w-auto">
                                  <Button size="sm" variant="success" className="flex-1 sm:flex-none" onClick={() => {
                                      if (newCustomTaskName.trim()) {
                                          setCustomEquipment([...customEquipment, { id: `custom_${Date.now()}`, name: newCustomTaskName.trim(), area }]);
                                          setNewCustomTaskName('');
                                          setNewCustomTaskArea(null);
                                      }
                                  }}>Add</Button>
                                  <Button size="sm" variant="secondary" className="flex-1 sm:flex-none" onClick={() => setNewCustomTaskArea(null)}>Cancel</Button>
                              </div>
                          </div>
                      )}

                      {/* Equipment Nodes */}
                      <div className="divide-y divide-gray-100">
                          {equips.length === 0 ? (
                              <p className="text-center py-6 text-gray-500 text-sm">No equipment found for this area.</p>
                          ) : (
                              <>
                                  {activeOrPending.map(item => (
                                      <EquipmentNode 
                                          key={item.eq.id} 
                                          {...item}
                                          users={users}
                                          onDropEquipment={(e) => handleDropOnEquipment(e, item.eq)}
                                          onMarkComplete={handleMarkComplete}
                                          onMarkNA={handleMarkNA}
                                          onChangeTime={handleChangeTime}
                                      />
                                  ))}
                                  
                                  {activeOrPending.length > 0 && completedOrNA.length > 0 && (
                                      <div className="bg-gray-100 text-gray-500 text-xs font-bold uppercase tracking-wider px-5 py-2 border-y border-gray-200">
                                          Completed / Not Applicable
                                      </div>
                                  )}

                                  {completedOrNA.map(item => (
                                      <EquipmentNode 
                                          key={item.eq.id} 
                                          {...item}
                                          users={users}
                                          onDropEquipment={(e) => handleDropOnEquipment(e, item.eq)}
                                          onMarkComplete={handleMarkComplete}
                                          onMarkNA={handleMarkNA}
                                          onChangeTime={handleChangeTime}
                                      />
                                  ))}
                              </>
                          )}
                      </div>
                  </div>
              );
          })}
      </div>
    </div>
  );
};

// Extracted Equipment Node for Lead View
const EquipmentNode = ({ eq, eqActiveTasks, eqDoneTasks, eqNATasks, isDone, isNA, users, onDropEquipment, onMarkComplete, onMarkNA, onChangeTime }) => {
  const [completeTime, setCompleteTime] = useState(getLocalTimeString());

  // Derive initial value for the editable completion time input from the task
  const primaryDoneTask = eqDoneTasks?.[0];
  const doneTimeValue = primaryDoneTask?.inspectionTime ? 
      `${String(new Date(primaryDoneTask.inspectionTime).getHours()).padStart(2, '0')}:${String(new Date(primaryDoneTask.inspectionTime).getMinutes()).padStart(2, '0')}`
      : getLocalTimeString();

  return (
      <div 
          onDragOver={(e) => { e.preventDefault(); e.currentTarget.classList.add('bg-blue-50'); }}
          onDragLeave={(e) => { e.currentTarget.classList.remove('bg-blue-50'); }}
          onDrop={(e) => {
              e.currentTarget.classList.remove('bg-blue-50');
              onDropEquipment(e);
          }}
          className={`p-5 transition-colors duration-200 ${isDone ? 'bg-green-50/30' : isNA ? 'bg-gray-50/50 opacity-80' : 'bg-white hover:bg-gray-50'}`}
      >
          <div className="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-3 gap-2">
              <div className="flex items-center gap-3">
                  <Wrench className={`w-5 h-5 ${isDone ? 'text-green-500' : isNA ? 'text-gray-400' : 'text-gray-400'}`} />
                  <h4 className={`font-bold text-base ${isDone ? 'text-green-900' : isNA ? 'text-gray-500 line-through' : 'text-gray-800'}`}>{eq.name}</h4>
              </div>
              <div className="flex items-center gap-2">
                  {isDone && primaryDoneTask && (
                      <div className="flex items-center gap-2 bg-green-100 px-3 py-1 rounded-md border border-green-200 shadow-sm transition-all focus-within:ring-2 focus-within:ring-green-400">
                          <CheckCircle2 className="w-4 h-4 text-green-600"/>
                          <span className="text-xs font-bold text-green-800">Completed:</span>
                          <input 
                              type="time" 
                              value={doneTimeValue} 
                              onChange={(e) => onChangeTime(primaryDoneTask.id, e.target.value)}
                              className="bg-transparent border-none text-xs font-bold text-green-900 outline-none cursor-pointer"
                              title="Edit completion time"
                          />
                      </div>
                  )}
                  {isNA && <Badge status="not_applicable" className="px-3 py-1 border border-gray-200 shadow-sm">Not Applicable</Badge>}
                  
                  {!isDone && !isNA && (
                      <Button size="sm" variant="secondary" className="py-1 px-2 text-xs h-auto shadow-none hover:bg-gray-200 hover:text-gray-900" onClick={() => onMarkNA(eq)}>
                          Mark N/A
                      </Button>
                  )}
              </div>
          </div>

          {!isDone && !isNA && (
              <div className="flex flex-wrap gap-2 min-h-[50px] p-3 bg-gray-50 border-2 border-dashed border-gray-300 rounded-lg items-center relative">
                  {eqActiveTasks.length === 0 && <span className="text-gray-400 text-sm font-medium absolute left-4 pointer-events-none">Drag employees here to assign...</span>}
                  {eqActiveTasks.map(t => {
                      const emp = users.find(u => u.id === t.empId);
                      return (
                          <div 
                              key={t.id} 
                              draggable 
                              onDragStart={(e) => e.dataTransfer.setData('empId', emp.id)} 
                              className="px-3 py-1.5 bg-white border border-gray-200 rounded-md shadow-sm text-sm font-medium flex items-center cursor-grab active:cursor-grabbing text-gray-700 z-10"
                              title="Drag to reassign"
                          >
                              <UserCircle className="w-4 h-4 mr-2 text-blue-500" /> {formatFullName(emp?.name)}
                          </div>
                      );
                  })}
              </div>
          )}

          {eqActiveTasks.length > 0 && !isDone && !isNA && (
              <div className="mt-4 flex flex-col sm:flex-row items-end sm:items-center justify-end gap-3 bg-white p-3 rounded border border-gray-100 shadow-sm">
                  <div className="flex items-center gap-2 w-full sm:w-auto">
                      <label className="text-xs font-bold text-gray-500 uppercase tracking-wide">Time:</label>
                      <input 
                          type="time" 
                          className="border border-gray-300 rounded-md px-3 py-1.5 text-sm font-medium outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 flex-1 sm:flex-none bg-gray-50" 
                          value={completeTime} 
                          onChange={e => setCompleteTime(e.target.value)} 
                      />
                  </div>
                  <Button size="sm" variant="success" className="w-full sm:w-auto shadow-sm" onClick={() => onMarkComplete(eq, completeTime)}>
                      <CheckCircle2 className="w-4 h-4 mr-1.5" /> Mark Complete
                  </Button>
              </div>
          )}
      </div>
  );
};

