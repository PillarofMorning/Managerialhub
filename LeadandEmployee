              <Button size="lg" className="w-full" onClick={handleRequestInspection}><ShieldCheck className="w-5 h-5 mr-2" /> Request Inspection</Button>
            ) : myTask.status === 'pending_inspection' ? (
              <div className="text-center p-4 bg-yellow-50 text-yellow-800 rounded-lg border border-yellow-200">
                <AlertCircle className="w-6 h-6 mx-auto mb-2" />
                <p className="font-medium">Inspection Requested</p>
                <p className="text-sm mt-1">Waiting for your lead to review the equipment.</p>
              </div>
            ) : null}
          </div>
        </div>
      </div>
    </div>
  );
};

