const SupervisorDashboard = ({ currentUser, tasks, users, equipment, updateTask, createTasks }) => {
  const leads = users.filter(u => u.role === 'lead' && u.shift === currentUser.shift);
  const employees = users.filter(u => u.role === 'employee' && u.shift === currentUser.shift);
  
  // Unassigned = NO task today at all
  const unassignedEmployees = employees.filter(emp => !tasks.find(t => t.empId === emp.id));

  const handleAllocateToLead = (empId, leadId) => {
    createTasks([{ id: `task_${Date.now()}_${Math.random()}`, empId, leadId, equipId: null, equipNameFallback: "", area: "", status: 'assigned', startTime: new Date().toISOString(), beforePicture: null, afterPicture: null }]);
  };

  const handleAssignLeadSelfTask = (leadId, existingTask, type, val) => {
      const updates = type === 'custom' 
          ? { equipId: null, equipNameFallback: val, area: 'Custom Task', status: 'working', startTime: new Date().toISOString() }
          : { equipId: val, equipNameFallback: equipment.find(e => e.id === val)?.name || "", area: equipment.find(e => e.id === val)?.area || "", status: 'working', startTime: new Date().toISOString() };

      if (existingTask) {
          updateTask(existingTask.id, updates);
      } else {
          createTasks([{
              id: `task_${Date.now()}_${Math.random()}`,
              empId: leadId,
              leadId: leadId, 
              beforePicture: null,
              afterPicture: null,
              ...updates
          }]);
      }
  };

  const allEquipByArea = equipment.reduce((acc, eq) => {
    const area = eq.area || 'Other Areas';
    if (!acc[area]) acc[area] = [];
    acc[area].push(eq);
    return acc;
  }, {});

  return (
    <div className="grid grid-cols-1 xl:grid-cols-3 gap-6">
      <div className="xl:col-span-1">
        <div className="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden sticky top-6">
          <div className="bg-gray-800 px-6 py-4 text-white"><h2 className="text-lg font-semibold flex items-center"><Users className="w-5 h-5 mr-2" /> Unallocated Staff ({unassignedEmployees.length})</h2></div>
          <div className="p-4 space-y-3 max-h-[calc(100vh-220px)] overflow-y-auto pr-2 custom-scrollbar">
            {unassignedEmployees.length === 0 ? <p className="text-center text-gray-500 py-4">All staff allocated!</p> : (
              unassignedEmployees.map(emp => (
                <div key={emp.id} className="p-4 border border-gray-200 rounded-lg bg-white shadow-sm hover:border-blue-300 transition-colors">
                  <p className="font-semibold text-gray-800 mb-3">{formatFullName(emp.name)}</p>
                  <select className="w-full text-sm border-gray-300 rounded-md p-2 border outline-none cursor-pointer" onChange={(e) => { if (e.target.value) handleAllocateToLead(emp.id, e.target.value); e.target.value = ''; }} defaultValue="">
                    <option value="" disabled>Assign to Lead...</option>
                    {leads.map(l => <option key={l.id} value={l.id}>{formatFullName(l.name)}</option>)}
                  </select>
                </div>
              ))
            )}
          </div>
        </div>
      </div>
      
      <div className="xl:col-span-2 space-y-6 max-h-[calc(100vh-140px)] overflow-y-auto pr-4 pb-12 custom-scrollbar">
        {leads.map(lead => {
          // Team members for this lead based on absolute latest state
          const teamTasks = tasks.filter(t => t.leadId === lead.id && t.empId !== lead.id && t.isLatestForEmp && t.status !== 'done' && t.status !== 'not_applicable');
          const hasTeam = teamTasks.length > 0;
          const leadSelfTask = tasks.find(t => t.empId === lead.id && t.isLatestForEmp && t.status !== 'done' && t.status !== 'not_applicable');

          if (!hasTeam) {
             return (
               <div key={lead.id} className="bg-white rounded-xl shadow-sm border border-gray-200 p-5 flex flex-col sm:flex-row justify-between items-center gap-4">
                  <div className="flex items-center w-full sm:w-auto">
                      <div className="w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center text-gray-500 font-bold mr-3 flex-shrink-0">
                          {lead.name.charAt(0)}
                      </div>
                      <div>
                          <h3 className="font-bold text-gray-800 text-lg leading-tight">{formatFullName(lead.name)}</h3>
                          <p className="text-sm text-gray-500 mt-0.5">Lead • No team assigned</p>
                      </div>
                  </div>
                  <div className="w-full sm:w-1/2">
                      <SupervisorEquipmentSelector 
                          currentEquipId={leadSelfTask?.equipId}
                          currentEquipNameFallback={leadSelfTask?.equipNameFallback}
                          equipmentList={equipment}
                          equipByArea={allEquipByArea}
                          onAssign={(type, val) => handleAssignLeadSelfTask(lead.id, leadSelfTask, type, val)}
                      />
                  </div>
               </div>
             );
          }

          return (
            <div key={lead.id} className="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
              <div className="border-b border-gray-100 bg-gray-50 px-6 py-4 flex justify-between items-center">
                <h3 className="font-bold text-gray-800 flex items-center text-lg"><UserCircle className="w-6 h-6 mr-2 text-blue-600" /> {formatFullName(lead.name)}'s Team</h3>
                <Badge status="working">{teamTasks.length} Assigned</Badge>
              </div>
              <div className="p-6">
                <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  {teamTasks.map(task => {
                      const emp = employees.find(e => e.id === task.empId) || users.find(e => e.id === task.empId);
                      return (
                        <div key={task.id} className="flex items-center p-3 bg-gray-50 rounded-lg border border-gray-100">
                          <div className="w-8 h-8 bg-white rounded-full flex items-center justify-center text-gray-600 font-bold shadow-sm mr-3">{emp?.name.charAt(0) || '?'}</div>
                          <div>
                            <p className="text-sm font-semibold text-gray-800">{formatFullName(emp?.name)}</p>
                            <div className="mt-1"><Badge status={task.status}>{task.status.replace('_', ' ').toUpperCase()}</Badge></div>
                          </div>
                        </div>
                      );
                  })}
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  );
};

// ============================================================================
// SECTION 6: MAIN APP SHELL & DATAVERSE INTEGRATION
// ============================================================================

export default function App(props) {
  useEffect(() => {
    if (!document.getElementById('tailwind-cdn')) {
      const script = document.createElement('script');
      script.id = 'tailwind-cdn';
      script.src = 'https://cdn.tailwindcss.com';
      document.head.appendChild(script);
      
      const style = document.createElement('style');
      style.innerHTML = `
        .custom-scrollbar::-webkit-scrollbar { width: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #CBD5E1; border-radius: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #94A3B8; }
      `;
      document.head.appendChild(style);
    }
  }, []);

  const [users, setUsers] = useState([]);
  const [equipment, setEquipment] = useState([]);
  const [tasks, setTasks] = useState([]);
  
  const [currentUser, setCurrentUser] = useState(null);
  const [msUser, setMsUser] = useState(null);
  
  const [isAuthenticating, setIsAuthenticating] = useState(true);
  const [isLoadingData, setIsLoadingData] = useState(true);
  const [adminMode, setAdminMode] = useState(false);

  // 1. LOAD MS ACCOUNT CREDENTIALS
  useEffect(() => {
    const fetchUserProfile = async () => {
      let uName = props?.context?.userSettings?.userName || props?.userName;
      let uId = props?.context?.userSettings?.userId || props?.userId;
      let actualEmail = props?.context?.userSettings?.email || props?.userEmail;
      
      const globalXrm = safeGetXrm();
      if ((!uName || !uId) && globalXrm?.Utility) {
        try {
          const xrmContext = globalXrm.Utility.getGlobalContext();
          uName = uName || xrmContext.userSettings.userName;
          uId = uId || xrmContext.userSettings.userId;
        } catch(e) {}
      }

      if (uName) {
        if (!actualEmail && uId && globalXrm?.WebApi) {
          try {
            const cleanUserId = uId.replace(/[{}]/g, '');
            const sysUser = await globalXrm.WebApi.retrieveRecord("systemuser", cleanUserId, "?$select=internalemailaddress");
            if (sysUser && sysUser.internalemailaddress) actualEmail = sysUser.internalemailaddress;
          } catch (error) {}
        }
        setMsUser({ name: uName, email: actualEmail || "", id: uId });
      } else {
        setTimeout(() => setMsUser({ name: "Local Developer", email: "dev@localhost", id: "DEV" }), 500);
      }
    };
    fetchUserProfile();
  }, [props]);

  // 2. LOAD DATAVERSE RECORDS
  useEffect(() => {
    async function loadDataverse() {
      try {
        const dvEmps = await fetchAllActiveRecords("craa5__aa_employee", props.dataApi);
        const dvAssets = await fetchAllActiveRecords("craa5_aa_assets", props.dataApi);
        const dvTasks = await fetchAllActiveRecords("craa5_taskassignment", props.dataApi);

        let resolvedUsers = MOCK_USERS;
        if (dvEmps.length > 0) {
          resolvedUsers = dvEmps.map(e => ({
            id: e.craa5__aa_employeeid,
            uidm: e.craa5_uidm || e.uidm || e.craa5_uid || e.craa5_UIDM || "", // Extract Custom UID
            name: e.craa5_name || 'Unknown',
            email: getEmployeeEmail(e),
            role: e.craa5_role === 256000002 ? 'supervisor' : (e.craa5_role === 256000001 ? 'lead' : 'employee'),
            shift: normalizeShift(e["craa5_shift@OData.Community.Display.V1.FormattedValue"] || e.craa5_shift || e.craa5_Shift),
            _raw: e
          }));
          setUsers(resolvedUsers);
        } else setUsers(MOCK_USERS);

        let resolvedEquip = MOCK_EQUIPMENT;
        if (dvAssets.length > 0) {
          resolvedEquip = dvAssets.map(a => ({
            id: a.craa5_aa_assetsid,
            name: a.craa5_equipmentidentifier || 'Unnamed Equipment',
            area: a.craa5_areaname || 'Unknown Area',
            _raw: a
          }));
          setEquipment(resolvedEquip);
        } else setEquipment(MOCK_EQUIPMENT);

        if (dvTasks.length > 0 && dvEmps.length > 0) {
          
          // Ultra-robust Name Matching Strategy
          const findUserIdByName = (name) => {
              if (!name) return null;
              const cleanName = name.toLowerCase().trim();
              
              let user = dvEmps.find(e => (e.craa5_name || '').toLowerCase().trim() === cleanName);
              if (user) return user.craa5__aa_employeeid;
              
              const noComma = cleanName.replace(/,/g, '');
              user = dvEmps.find(e => (e.craa5_name || '').toLowerCase().replace(/,/g, '').trim() === noComma);
              if (user) return user.craa5__aa_employeeid;

              const parts = cleanName.split(/[\s,]+/).filter(p => p.length > 2);
              if (parts.length > 0) {
                  user = dvEmps.find(e => {
                      const dbName = (e.craa5_name || '').toLowerCase();
                      return parts.every(p => dbName.includes(p));
                  });
                  if (user) return user.craa5__aa_employeeid;
              }
              return null;
          };
          const findEquipIdByName = (name) => dvAssets.find(a => (a.craa5_equipmentidentifier || '').trim().toLowerCase() === name?.trim().toLowerCase())?.craa5_aa_assetsid || null;
          
          // Sort absolutely newest to oldest
          const sortedDvTasks = [...dvTasks].sort((a, b) => {
              const dA = new Date(a.craa5_datetimeofassignment || a.createdon || 0).getTime();
              const dB = new Date(b.craa5_datetimeofassignment || b.createdon || 0).getTime();
              return dB - dA;
          });

          const seenEmps = new Set();
          const parsedTasks = [];

          for (const t of sortedDvTasks) {
              const empName = (t.craa5_id || t.craa5_ID || "").trim();
              const leadName = (t.craa5_lead || t.craa5_Lead || "").trim();
              const equipName = (t.craa5_equip || t.craa5_equipment || t.craa5_Equipment || "").trim();
              const areaName = (t.craa5_area || t.craa5_Area || t["craa5_area@OData.Community.Display.V1.FormattedValue"] || "").trim();

              const empId = findUserIdByName(empName);
              if (!empId) continue;

              let localStatus = 'assigned';
              const s = (t.craa5__currentstatus || '').toLowerCase();
              
              if (s.includes('not applicable') || s.includes('n/a')) localStatus = 'not_applicable';
              else if (t.statecode === 1 || s.includes('done') || t.craa5_percentagecomplete === 100) localStatus = 'done';
              else if (s.includes('pending')) localStatus = 'pending_inspection';
              else if (s.includes('reclean')) localStatus = 'reclean';
              else if (s.includes('working') || t.craa5_equipment) localStatus = 'working';

              const bPic = t.craa5_beforepicture ? `data:image/jpeg;base64,${t.craa5_beforepicture}` : null;
              const aPic = t.craa5_afterpicture ? `data:image/jpeg;base64,${t.craa5_afterpicture}` : null;
              
              // Only the absolutely first task we encounter for this employee is their true active state
              const isLatestForEmp = !seenEmps.has(empId);
              if (isLatestForEmp) {
                  seenEmps.add(empId);
              }

              const parsedTask = {
                  id: t.craa5_taskassignmentid || `local_task_${Date.now()}_${Math.random()}`,
                  dvId: t.craa5_taskassignmentid,
                  empId: empId,
                  leadId: findUserIdByName(leadName),
                  equipId: findEquipIdByName(equipName),
                  equipNameFallback: equipName,
                  area: areaName,
                  status: localStatus,
                  startTime: t.craa5_datetimeofassignment || t.createdon,
                  inspectionTime: t.craa5_inspection,
                  beforePicture: bPic,
                  afterPicture: aPic,
                  isLatestForEmp: isLatestForEmp,
                  _raw: t
              };

              // Push IF it's their true current state, OR if it's a completed task (needed so equipment renders done)
              if (isLatestForEmp || localStatus === 'done' || localStatus === 'not_applicable') {
                  parsedTasks.push(parsedTask);
              }
          }
          setTasks(parsedTasks);
        } else {
            setTasks(INITIAL_TASKS);
        }

      } catch (e) {
        console.error("Dataverse load failed, falling back to mocks", e);
        setUsers(MOCK_USERS);
        setEquipment(MOCK_EQUIPMENT);
        setTasks(INITIAL_TASKS);
      } finally {
        setIsLoadingData(false);
      }
    }
    loadDataverse();
  }, [props.dataApi]);

  // 3. AUTO-LOGIN MAPPING
  useEffect(() => {
    if (!msUser || users.length === 0 || currentUser || adminMode) {
       if (msUser && users.length > 0) setIsAuthenticating(false);
       return;
    }
    
    const msEmailLower = (msUser.email || "").toLowerCase();
    const msNameLower = (msUser.name || "").toLowerCase();
    
    let matchedUser = users.find(u => {
        const dbEmailLower = (u.email || "").toLowerCase();
        if (dbEmailLower && msEmailLower && dbEmailLower === msEmailLower) return true;
        
        const dbNameLower = (u.name || "").toLowerCase();
        if (dbNameLower === msNameLower) return true;
        
        const parts = dbNameLower.split(",");
        if (parts.length > 1) {
            const lastName = parts[0].trim();
            const firstName = parts[1].trim().split(" ")[0]; 
            if (msNameLower.includes(lastName) && msNameLower.includes(firstName)) return true;
        }

        const formattedName = formatFullName(u.name).toLowerCase();
        if (formattedName && msNameLower.includes(formattedName)) return true;
        
        return false;
    });

    if (matchedUser) {
        setCurrentUser(matchedUser);
    }
    setIsAuthenticating(false);
  }, [msUser, users, currentUser, adminMode]);

  // Synchronous background save to Dataverse
  const saveTaskToDataverse = async (task, action) => {
    const writeApi = safeGetXrm()?.WebApi || props.dataApi;
    if (!writeApi) return; 

    const emp = users.find(u => u.id === task.empId);
    const lead = users.find(u => u.id === task.leadId);
    const equip = equipment.find(e => e.id === task.equipId);

    let currentStatusStr = 'Working';
    let stateCodeNum = 0;
    let percent = 0;
    
    if (task.status === 'done') {
        currentStatusStr = 'Done'; stateCodeNum = 1; percent = 100;
    } else if (task.status === 'not_applicable') {
        currentStatusStr = 'Not Applicable'; stateCodeNum = 1; percent = 100;
    } else if (task.status === 'pending_inspection') {
        currentStatusStr = 'Pending Inspection';
    } else if (task.status === 'reclean') {
        currentStatusStr = 'Reclean';
    }

    const payload = {
        craa5_id: emp?.name || "",
        craa5_email: emp?.email || "",
        craa5_lead: lead?.name || "",
        craa5_leademail: lead?.email || "",
        craa5_equipment: equip?.name || task.equipNameFallback || "",
        craa5_equip: equip?.name || task.equipNameFallback || "",
        craa5_area: equip?.area || task.area || "",
        craa5_shift: determineCurrentShift(),
        craa5__currentstatus: currentStatusStr,
        craa5_datetimeofassignment: task.startTime || new Date().toISOString(),
        craa5_percentagecomplete: percent,
        craa5_uid_associated: emp?.uidm || emp?.id || "",
        statecode: stateCodeNum
    };

    if (task.inspectionTime) payload.craa5_inspection = task.inspectionTime;
    if (task.beforePicture) payload.craa5_beforepicture = getCleanBase64(task.beforePicture);
    if (task.afterPicture) payload.craa5_afterpicture = getCleanBase64(task.afterPicture);

    try {
        if (action === 'create') {
            const res = await writeApi.createRecord("craa5_taskassignment", payload);
            return res?.id;
        } else if (action === 'update' && task.dvId) {
            await writeApi.updateRecord("craa5_taskassignment", task.dvId, payload);
        }
    } catch (e) {
        console.error("Failed to save task to Dataverse:", e);
    }
  };

  const updateTask = (taskId, updates) => {
    setTasks(prev => {
        const newTasks = prev.map(t => t.id === taskId ? { ...t, ...updates } : t);
        const updatedTask = newTasks.find(t => t.id === taskId);
        saveTaskToDataverse(updatedTask, 'update');
        return newTasks;
    });
  };

  const createTasks = async (newTasks) => {
    setTasks(prev => [...prev, ...newTasks]);
    for (const t of newTasks) {
        const dvId = await saveTaskToDataverse(t, 'create');
        if (dvId) setTasks(prev => prev.map(task => task.id === t.id ? { ...task, dvId } : task));
    }
  };

  if (isLoadingData || isAuthenticating) {
    return (
      <div className="min-h-screen bg-gray-50 flex flex-col items-center justify-center p-4">
        <Loader2 className="w-12 h-12 text-blue-600 animate-spin mb-4" />
        <h2 className="text-xl font-semibold text-gray-700">Connecting to Supervisor Hub...</h2>
        <p className="text-gray-500">{isAuthenticating ? "Verifying Microsoft Credentials..." : "Retrieving environment data..."}</p>
      </div>
    );
  }

  // --- LOGIN SELECTION / IMPERSONATION SCREEN ---
  if (!currentUser) {
    const currentShift = determineCurrentShift();
    const allShifts = ['A', 'B', 'C', 'D', 'Unassigned'];
    const sortedShifts = [currentShift, ...allShifts.filter(s => s !== currentShift)];

    return (
      <div className="min-h-screen bg-gray-50 flex flex-col items-center justify-center p-4 font-sans">
        <div className="max-w-md w-full bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden">
          <div className="bg-blue-600 px-6 py-8 text-center">
            <CheckCircle2 className="w-12 h-12 text-white mx-auto mb-4 opacity-90" />
            <h1 className="text-2xl font-bold text-white">Supervisor Hub</h1>
            <p className="text-blue-100 mt-2">
              {adminMode ? "Admin Mode Active: Select a profile to impersonate" : "Select a profile to log in"}
            </p>
          </div>
          
          <div className="p-6 space-y-8 max-h-[60vh] overflow-y-auto custom-scrollbar">
            {sortedShifts.map(shift => {
              const shiftUsers = users.filter(u => u.shift === shift);
              if (shiftUsers.length === 0) return null;
              
              return (
                <div key={shift} className="space-y-4">
                  <div className="flex items-center gap-3 border-b border-gray-200 pb-2">
                    <h2 className="text-lg font-bold text-gray-800">Shift {shift}</h2>
                    {shift === currentShift && <Badge status="done">Current Shift</Badge>}
                  </div>
                  
                  {['supervisor', 'lead', 'employee'].map(role => {
                    const roleUsers = shiftUsers.filter(u => u.role === role);
                    if (roleUsers.length === 0) return null;
                    return (
                      <div key={role} className="pl-2 border-l-2 border-gray-100">
                        <h3 className="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-2 pl-2">{role}s</h3>
                        <div className="space-y-2 pl-2">
                          {roleUsers.map(u => (
                            <button key={u.id} onClick={() => setCurrentUser(u)} className="w-full text-left px-4 py-2.5 rounded-lg hover:bg-blue-50 border border-gray-200 font-medium text-gray-700 transition-colors flex items-center justify-between text-sm">
                              {formatFullName(u.name)} <ArrowRightLeft className="w-4 h-4 text-gray-400" />
                            </button>
                          ))}
                        </div>
                      </div>
                    );
                  })}
                </div>
              );
            })}
          </div>
        </div>
      </div>
    );
  }

  // --- MAIN APP SHELL ---
  return (
    <div className="min-h-screen bg-[#F3F4F6] font-sans text-gray-900 flex flex-col overflow-hidden">
      <header className="bg-white border-b border-gray-200 flex-shrink-0 z-10 shadow-sm">
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
          <div className="flex items-center gap-3">
            <div className="bg-blue-600 p-2 rounded-lg"><CheckCircle2 className="w-6 h-6 text-white" /></div>
            <h1 className="text-xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-blue-700 to-blue-500">Supervisor Hub</h1>
            <span className="ml-4 px-2.5 py-1 bg-gray-100 text-gray-600 rounded-md text-xs font-bold uppercase tracking-wide border border-gray-200">{currentUser.role} View</span>
          </div>
          <div className="flex items-center gap-4">
            <div className="hidden md:block text-right">
              <p className="text-sm font-bold text-gray-800">{formatFullName(currentUser.name)}</p>
              <p className="text-xs text-gray-500">{currentUser.email}</p>
            </div>
            
            <div className="flex items-center gap-3 border-l border-gray-200 pl-4">
               {adminMode && <Badge status="pending_inspection">Admin Impersonation</Badge>}
               <Button 
                 variant="secondary" 
                 size="sm" 
                 onClick={() => { 
                   setAdminMode(true); 
                   setCurrentUser(null); 
                 }}
               >
                 <LogOut className="w-4 h-4 mr-2" /> Switch User
               </Button>
            </div>
          </div>
        </div>
      </header>
      <main className="flex-1 w-full mx-auto px-4 sm:px-6 lg:px-8 py-8 overflow-hidden flex flex-col max-w-7xl">
        {currentUser.role === 'employee' && <EmployeeDashboard currentUser={currentUser} tasks={tasks} equipment={equipment} users={users} updateTask={updateTask} />}
        {currentUser.role === 'lead' && <LeadDashboard currentUser={currentUser} tasks={tasks} users={users} equipment={equipment} updateTask={updateTask} createTasks={createTasks} />}
        {currentUser.role === 'supervisor' && <SupervisorDashboard currentUser={currentUser} tasks={tasks} users={users} equipment={equipment} updateTask={updateTask} createTasks={createTasks} />}
      </main>
    </div>
  );
}
