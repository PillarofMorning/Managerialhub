const SupervisorEquipmentSelector = ({ currentEquipId, currentEquipNameFallback, equipmentList, equipByArea, onAssign }) => {
  const [isCustom, setIsCustom] = useState(false);
  const [customVal, setCustomVal] = useState('');

  if (isCustom) {
    return (
      <div className="flex items-center gap-2 w-full bg-white p-1 rounded-lg border border-blue-400 shadow-sm ring-1 ring-blue-100">
        <input 
          type="text" 
          autoFocus
          className="flex-1 bg-transparent text-sm p-1.5 outline-none font-medium text-gray-800 placeholder-gray-400" 
          placeholder="Type custom task..."
          value={customVal}
          onChange={e => setCustomVal(e.target.value)}
          onKeyDown={e => { if (e.key === 'Enter' && customVal.trim()) { onAssign('custom', customVal.trim()); setIsCustom(false); } }}
        />
        <Button size="sm" variant="success" className="px-3" onClick={() => { if(customVal.trim()) { onAssign('custom', customVal.trim()); setIsCustom(false); } }}>Save</Button>
        <Button size="sm" variant="secondary" className="px-2 bg-gray-100 text-gray-600 border-none" onClick={() => setIsCustom(false)}>✕</Button>
      </div>
    );
  }

  return (
    <select 
      className="w-full border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 text-sm bg-white p-2.5 border outline-none hover:border-blue-400 transition-colors cursor-pointer font-medium" 
      value={currentEquipId || (currentEquipNameFallback ? 'custom_existing' : '')} 
      onChange={(e) => {
        if (e.target.value === 'new_custom') setIsCustom(true);
        else if (e.target.value !== 'custom_existing') onAssign('equipment', e.target.value);
      }}
    >
      <option value="">-- Assign Equipment/Task --</option>
      <option value="new_custom" className="font-bold text-blue-600 bg-blue-50">➕ Custom Task (Not on list)...</option>
      {currentEquipNameFallback && !currentEquipId && <option value="custom_existing">{currentEquipNameFallback} (Custom Task)</option>}
      {currentEquipId && equipmentList.find(e => e.id === currentEquipId) && <option value={currentEquipId}>{equipmentList.find(e => e.id === currentEquipId).name} (Current)</option>}
      
      {Object.entries(equipByArea).map(([area, equips]) => (
          <optgroup key={area} label={area} className="font-bold text-gray-500 bg-gray-50 uppercase text-xs tracking-wider">
              {equips.map(eq => <option key={eq.id} value={eq.id} className="font-medium text-gray-900 bg-white normal-case tracking-normal">{eq.name}</option>)}
          </optgroup>
      ))}
    </select>
  );
};


