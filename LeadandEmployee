const EmployeeDashboard = ({ currentUser, tasks, equipment, users, updateTask }) => {
  const [now, setNow] = useState(Date.now());
  const myTask = tasks.find(t => t.empId === currentUser.id && t.isLatestForEmp);
  
  const myEquip = equipment.find(e => e.id === myTask?.equipId);
  const equipNameDisplay = myEquip?.name || myTask?.equipNameFallback;
  const areaDisplay = myEquip?.area || myTask?.area;

  useEffect(() => {
    const interval = setInterval(() => setNow(Date.now()), 60000);
    return () => clearInterval(interval);
  }, []);

  const handleRequestInspection = () => {
    updateTask(myTask.id, { status: 'pending_inspection', inspectionTime: new Date().toISOString() });
  };

  // State 1: Completely unassigned or completed their active task
  if (!myTask || myTask.status === 'done' || myTask.status === 'not_applicable') {
    return (
      <div className="flex flex-col items-center justify-center h-64 bg-white rounded-xl shadow-sm border border-gray-200 p-6 text-center">
        <AlertCircle className="w-12 h-12 text-gray-400 mb-4" />
        <h3 className="text-xl font-bold text-gray-800">No Active Assignment</h3>
        <p className="text-gray-500 mt-2">You have no active tasks. Please wait for a Supervisor or Lead to allocate you.</p>
      </div>
    );
  }

  // State 2: Standby (Assigned to Lead but no specific equipment)
  if (!equipNameDisplay) {
    const lead = users.find(u => u.id === myTask.leadId);
    return (
      <div className="flex flex-col items-center justify-center h-64 bg-white rounded-xl shadow-sm border border-gray-200 p-6 text-center">
        <UserCircle className="w-16 h-16 text-blue-500 mb-4" />
        <h3 className="text-xl font-bold text-gray-800">Team: {formatFullName(lead?.name)}</h3>
        {areaDisplay && <p className="text-gray-600 mt-1 font-medium bg-gray-100 px-3 py-1 rounded-full inline-block">Assigned Area: {areaDisplay}</p>}
        <p className="text-gray-500 mt-4">You are assigned to this team, but no equipment has been allocated yet.</p>
        <Badge status="working" className="mt-6 px-4 py-1.5 text-sm shadow-sm">Standby - Awaiting Lead</Badge>
      </div>
    );
  }

  // State 3: Active Working
  return (
    <div className="max-w-3xl mx-auto space-y-6">
      <div className="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
        <div className="bg-blue-600 px-6 py-8 text-white text-center">
          <Wrench className="w-16 h-16 mx-auto mb-4 opacity-90" />
          <h2 className="text-3xl font-bold">{equipNameDisplay}</h2>
          <p className="text-blue-100 mt-2 text-lg">{areaDisplay || 'Unspecified Area'}</p>
        </div>
        
        <div className="p-6 space-y-8">
          <div className="flex justify-between items-center p-4 bg-gray-50 rounded-lg border border-gray-100">
            <div>
              <p className="text-sm text-gray-500 font-medium mb-1">Current Status</p>
              <Badge status={myTask.status}>{myTask.status.replace('_', ' ').toUpperCase()}</Badge>
            </div>
            <div className="text-right">
              <p className="text-sm text-gray-500 font-medium mb-1 flex items-center justify-end gap-1">
                <Clock className="w-4 h-4" /> Time on Equipment
              </p>
              <p className="text-2xl font-bold text-gray-800">
                {formatDuration(myTask.startTime, myTask.status === 'pending_inspection' ? myTask.inspectionTime : null)}
              </p>
            </div>
          </div>

          <div>
            <h3 className="text-lg font-semibold text-gray-800 flex items-center gap-2 mb-4"><Camera className="w-5 h-5 text-gray-500" /> Verification Photos</h3>
            <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
               <PhotoUploader label="Before Cleaning" imageBase64={myTask.beforePicture} onUpload={(e) => handleFileUpload(e, 'beforePicture', myTask.id, updateTask)} />
               <PhotoUploader label="After Cleaning" imageBase64={myTask.afterPicture} onUpload={(e) => handleFileUpload(e, 'afterPicture', myTask.id, updateTask)} />
            </div>
