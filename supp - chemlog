function formatDateShorthand(date: Date | string | undefined): string {
    if (!date) return "N/A";
    const d = typeof date === "string" ? new Date(date) : date;
    if (isNaN(d.getTime())) return "N/A";
    return d.toLocaleString(undefined, { month: "short", day: "numeric", hour: "2-digit", minute: "2-digit", hour12: true });
}

const GeneratedComponent = ({ dataApi }: GeneratedComponentProps) => {
    const styles = useStyles();
    const [activeNav, setActiveNav] = useState("statusBoard");
    
    // [DIAGNOSIS FIX]: Removed all <Generic> syntax from useState to protect against PowerApps compiler bugs.
    // Casting with `as any[]` bypasses the TSX parser crash while keeping initial state types manageable.
    const [chemicals, setChemicals] = useState([] as any[]);
    const [distributors, setDistributors] = useState([] as any[]);
    const [inventories, setInventories] = useState([] as any[]);

    const refreshBaseData = async () => {
        try {
            // [ERROR HANDLING]: Promise.all is used to parallelize Dataverse requests for speed.
            // If one table fails (e.g. permissions), the entire block goes to catch.
            const [chemRes, distRes, invRes] = await Promise.all([
                dataApi.queryTable("craa5_chemical", { select: ["craa5_chemicalid", "craa5_chemicalname", "craa5_itemnumber", "craa5_priceperunit", "craa5_unit", "_craa5_distributorname_value"], pageSize: 250 }),
                dataApi.queryTable("craa5_distributor", { select: ["craa5_distributorid", "craa5_distributorname"], pageSize: 100 }),
                dataApi.queryTable("craa5_chemicalinventory", { select: ["craa5_chemicalinventoryid", "craa5_chemicalinventoryname", "craa5_quantityonhand", "craa5_minimumthreshold", "craa5_displayorder", "craa5_lastupdated", "craa5_totalinventory", "craa5_quantityonorder", "_craa5_chemicalname_value"], pageSize: 250 })
            ]);
            setChemicals(chemRes.rows as any);
            setDistributors(distRes.rows as any);
            setInventories(invRes.rows as any);
        } catch (e) { 
            // [ERROR HANDLING]: Safe console log. Since this is root initialization, 
            // alerting the user here might block rendering. The tables will simply show "0 found".
            console.error("Failed to fetch base Dataverse tables", e); 
        }
    };

    useEffect(() => { refreshBaseData(); }, [dataApi]);

    return (
        <div className={styles.root}>
            <header className={styles.topNav}>
                <div className={styles.brand}>
                    <DataHistogramRegular fontSize="1.4em" /> Logistics
