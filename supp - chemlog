};

/**
 * 1. STATUS BOARD - Dashboard Grid Version
 */
function StatusBoard({ styles, dataApi, chemicals, inventories, refreshBaseData }: any) {
    const [groupedCarts, setGroupedCarts] = useState([] as any[]);
    const [loading, setLoading] = useState(true);
    const [hasChanges, setHasChanges] = useState(false);
    const [submitStatus, setSubmitStatus] = useState(null as any);

    const fetchAndGroupCarts = async () => {
        setLoading(true);
        setSubmitStatus(null);
        try {
            const res = await dataApi.queryTable("craa5_cart", {
                select: ["craa5_cartid", "craa5_cartname", "craa5_location", "craa5_amountordered", "craa5_ordered"],
                pageSize: 500
            });
            
            const groups: any = {};
            res.rows.forEach((row: any) => {
                if (row.craa5_ordered === STATUS_CHOICES.RECEIVED) return;

                const name = row.craa5_cartname || "Unnamed Cart";
                if (!groups[name]) {
                    let currentStatus = STATUS_CHOICES.SUBMITTED;
                    if (row.craa5_ordered === STATUS_CHOICES.ORDERED) currentStatus = STATUS_CHOICES.ORDERED;
                    else if (row.craa5_ordered === STATUS_CHOICES.APPROVED) currentStatus = STATUS_CHOICES.APPROVED;

                    groups[name] = {
                        name: name, 
                        items: [], 
                        ids: [],
                        status: currentStatus,
                        originalStatus: currentStatus,
                        isModified: false
                    };
                }
                groups[name].items.push({ chem: row.craa5_location, qty: row.craa5_amountordered });
                groups[name].ids.push(row.craa5_cartid);
            });
            
            const statusOrder: any = { [STATUS_CHOICES.SUBMITTED]: 1, [STATUS_CHOICES.APPROVED]: 2, [STATUS_CHOICES.ORDERED]: 3, [STATUS_CHOICES.RECEIVED]: 4, [-1]: 5 };
            const sortedGroups = Object.values(groups).sort((a: any, b: any) => statusOrder[a.status] - statusOrder[b.status]);
            
            setGroupedCarts(sortedGroups as any);
            setHasChanges(false);
        } catch (e) { 
            // [ERROR HANDLING]: Specifically logging fetch errors for carts.
            console.error("Failed to group active carts", e); 
        }
        setLoading(false);
    };

    useEffect(() => { fetchAndGroupCarts(); }, []);

    const handleStatusChange = (cartName: string, newStatus: number) => {
        setGroupedCarts((prev: any[]) => prev.map((c: any) => {
            if (c.name === cartName && c.status !== newStatus) {
                return { ...c, status: newStatus, isModified: true };
            }
            return c;
        }) as any);
        setHasChanges(true);
    };

    const handleSaveChanges = async () => {
        setLoading(true);
        setSubmitStatus(null);
        const modifiedGroups = groupedCarts.filter((c: any) => c.isModified);
        const now = new Date().toISOString();

        try {
            for (const cart of modifiedGroups as any[]) {
                // Lifecycle Event: DELETE
                if (cart.status === -1) { 
                    await Promise.all(cart.ids.map((id: string) => dataApi.deleteRow("craa5_cart", id)));
                    
                    // [ERROR HANDLING & LOGIC]: Safely reverse the On-Order quantity when deleting
                    for (const item of cart.items) {
                        const chem = chemicals.find((c: any) => c.craa5_chemicalname === item.chem);
                        if (!chem) continue;
                        const inv = inventories.find((i: any) => i._craa5_chemicalname_value?.includes(chem.craa5_chemicalid));
                        if (inv) {
                            const newOnOrder = Math.max(0, (inv.craa5_quantityonorder || 0) - item.qty);
                            await dataApi.updateRow("craa5_chemicalinventory", inv.craa5_chemicalinventoryid, {
                                craa5_quantityonorder: newOnOrder,
                                craa5_lastupdated: now
                            });
                        }
                    }
                    continue;
                }

                // Prepare standard lifecycle payload
                const payload: any = { craa5_ordered: cart.status };
                if (cart.status === STATUS_CHOICES.SUBMITTED) payload.craa5_dateofsubmission = now;
                else if (cart.status === STATUS_CHOICES.APPROVED) payload.craa5_dateofapproval = now;
                else if (cart.status === STATUS_CHOICES.RECEIVED) payload.craa5_datereceived = now;

                await Promise.all(cart.ids.map((id: string) => dataApi.updateRow("craa5_cart", id, payload)));

                // Lifecycle Event: RECEIVED
                if (cart.status === STATUS_CHOICES.RECEIVED && cart.originalStatus !== STATUS_CHOICES.RECEIVED) {
                    for (const item of cart.items) {
                        const chem = chemicals.find((c: any) => c.craa5_chemicalname === item.chem);
                        if (!chem) continue;
                        const inv = inventories.find((i: any) => i._craa5_chemicalname_value?.includes(chem.craa5_chemicalid));
                        if (inv) {
                            const newOnOrder = Math.max(0, (inv.craa5_quantityonorder || 0) - item.qty);
                            const newOnHand = (inv.craa5_quantityonhand || 0) + item.qty;
                            await dataApi.updateRow("craa5_chemicalinventory", inv.craa5_chemicalinventoryid, {
                                craa5_quantityonorder: newOnOrder,
                                craa5_quantityonhand: newOnHand,
                                craa5_lastupdated: now
                            });
                        }
                    }
                }
            }
            
            await fetchAndGroupCarts();
            if (refreshBaseData) await refreshBaseData();
            
            // [ERROR HANDLING]: Using inline UI state instead of `alert()` popups to prevent browser interruption
            setSubmitStatus({ type: "success", msg: "Carts synchronized successfully." });
        } catch (e) { 
            // [ERROR HANDLING]: UI Graceful failure
            setSubmitStatus({ type: "error", msg: "Failed to save changes. Please try again." });
            setLoading(false); 
        }
    };

    const getStatusColor = (status: number) => {
        if (status === STATUS_CHOICES.APPROVED) return tokens.colorPaletteWarningBackground3;
        if (status === STATUS_CHOICES.ORDERED) return tokens.colorPaletteBlueBackground3;
        if (status === STATUS_CHOICES.RECEIVED) return tokens.colorPaletteGreenBackground3;
        if (status === -1) return tokens.colorPaletteRedBackground3;
        return "#8C1F28"; 
    };

    const calculateCartTotal = (cart: any) => {
        let total = 0;
        cart.items.forEach((it: any) => {
            const chemObj = chemicals.find((c: any) => c.craa5_chemicalname === it.chem);
            total += (it.qty ?? 0) * (chemObj?.craa5_priceperunit ?? 0);
        });
        return total;
    };

    return (
        // [DIAGNOSIS FIX]: Explicitly using a <div> wrapper instead of a Fragment (<>...</>)
        // because the PowerApps PCF TSX compiler crashes with "Unexpected Token ';'" on fragments.
        <div style={{ display: "flex", flexDirection: "column", height: "100%" }}>
            <div className={styles.headerRow}>
                <div className={styles.titleBlock}>
                    <Text as="h2" size={700} weight="bold" style={{ margin: "0 0 4px 0" }}>Active Carts Pipeline</Text>
                    <Text size={300} style={{ color: tokens.colorNeutralForeground3 }}>Review and advance carts through the fulfillment lifecycle.</Text>
                </div>
                <div style={{ display: "flex", gap: "12px" }}>
                    <Button icon={<ArrowSyncRegular />} onClick={fetchAndGroupCarts} appearance="transparent">Discard</Button>
                    <Button 
                        icon={<SaveRegular />} 
                        onClick={handleSaveChanges} 
                        appearance={hasChanges ? "primary" : "secondary"}
                        disabled={!hasChanges}
                        style={hasChanges ? { backgroundColor: "#8C1F28", color: "#fff" } : {}}
                    >
                        {hasChanges ? "Submit Updates" : "Up to Date"}
                    </Button>
                </div>
            </div>

            {submitStatus && (
                <div className={submitStatus.type === "success" ? styles.alertSuccess : styles.alertError}>
                    {submitStatus.type === "success" ? <CheckmarkCircleRegular /> : <DismissCircleRegular />}
                    <Text>{submitStatus.msg}</Text>
                </div>
            )}

            {loading ? <Spinner label="Loading Carts..." style={{ margin: "40px auto", display: "block" }} /> : (
                <div className={styles.gridDashboard}>
                    {groupedCarts.length === 0 && <Text style={{ gridColumn: "1 / -1", textAlign: "center", color: tokens.colorNeutralForeground4, padding: "40px" }}>No active carts found in the pipeline.</Text>}
                    
                    {groupedCarts.map((cart: any) => (
                        <div key={cart.name} className={styles.card} style={{ 
                            borderTop: `6px solid ${getStatusColor(cart.status)}`,
                            opacity: cart.status === -1 ? 0.5 : 1
                        }}>
                            <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start", gap: "8px" }}>
                                <Text size={400} weight="semibold" style={{ flex: 1, wordBreak: "break-word" }}>
                                    <BoxRegular style={{ marginRight: 6, color: tokens.colorNeutralForeground3 }} />
                                    {cart.name}
                                </Text>
                            </div>
                            
                            <Dropdown
                                value={cart.status === STATUS_CHOICES.SUBMITTED ? "Submitted" : cart.status === STATUS_CHOICES.APPROVED ? "Approved" : cart.status === STATUS_CHOICES.ORDERED ? "Ordered" : cart.status === STATUS_CHOICES.RECEIVED ? "Received (Complete)" : "Delete"}
                                selectedOptions={[cart.status.toString()]}
                                onOptionSelect={(_, d) => handleStatusChange(cart.name, Number(d.optionValue))}
                                style={{ width: "100%", backgroundColor: tokens.colorNeutralBackground1Hover }}
                            >
                                <Option value={STATUS_CHOICES.SUBMITTED.toString()}>Submitted</Option>
                                <Option value={STATUS_CHOICES.APPROVED.toString()}>Approved</Option>
                                <Option value={STATUS_CHOICES.ORDERED.toString()}>Ordered</Option>
                                <Option value={STATUS_CHOICES.RECEIVED.toString()}>Received (Complete)</Option>
                                <Option value="-1" style={{ color: tokens.colorPaletteRedForeground1 }}>Delete</Option>
                            </Dropdown>

                            <Divider style={{ margin: "4px 0" }} />
                            
                            <div style={{ display: "flex", flexDirection: "column", gap: "6px" }}>
                                {cart.items.map((it: any, i: number) => {
                                    const chemObj = chemicals.find((c: any) => c.craa5_chemicalname === it.chem);
                                    const price = chemObj?.craa5_priceperunit ?? 0;
                                    return (
                                        <div key={i} style={{ display: "flex", justifyContent: "space-between", alignItems: "center", fontSize: "0.9rem" }}>
                                            <Text truncate style={{ flex: 1, marginRight: "8px", color: tokens.colorNeutralForeground2 }}>{it.chem}</Text>
                                            <div style={{ display: "flex", alignItems: "center", gap: "8px", whiteSpace: "nowrap" }}>
                                                <Badge appearance="tint" color="brand">{it.qty}</Badge>
                                                <Text size={200} style={{ color: tokens.colorNeutralForeground4 }}>${price.toFixed(2)}/ea</Text>
                                            </div>
                                        </div>
                                    );
                                })}
                            </div>

                            <Divider style={{ margin: "4px 0" }} />
                            
                            <Text align="end" size={400} weight="bold" style={{ color: tokens.colorNeutralForeground1 }}>
                                Total: ${calculateCartTotal(cart).toFixed(2)}
                            </Text>
                        </div>
                    ))}
                </div>
            )}
        </div>
    );
}

/**
 * 2. CART ASSIGNMENT - Dashboard Grid + Compact Action Bar
 */
function CartAssignmentPage({ styles, chemicals, inventories, distributors, dataApi }: any) {
    const getNeeded = () => {
        const list: any[] = [];
        chemicals.forEach((chem: any) => {
            const inv = inventories.find((i: any) => {
                const val = i._craa5_chemicalname_value || "";
                return val === chem.craa5_chemicalid || val.includes(chem.craa5_chemicalid) || (val.match(/\(([^)]+)\)/) && val.match(/\(([^)]+)\)/)[1] === chem.craa5_chemicalid);
            });

            // [ERROR HANDLING & LOGIC]: Safely fallback to 0 if threshold or on-hand is missing/null.
            if (inv && (inv.craa5_minimumthreshold || 0) > (inv.craa5_quantityonhand || 0)) {
                let supplierName = "General";
                if (chem._craa5_distributorname_value) {
                    const rawId = chem._craa5_distributorname_value.match(/\(([^)]+)\)/)?.[1] || chem._craa5_distributorname_value;
                    const distObj = distributors.find((d: any) => d.craa5_distributorid === rawId || d.craa5_distributorid?.includes(rawId));
                    if (distObj) supplierName = distObj.craa5_distributorname;
                }
                list.push({ 
                    chemicalId: chem.craa5_chemicalid, 
                    chemicalName: chem.craa5_chemicalname, 
                    amount: (inv.craa5_minimumthreshold || 0) - (inv.craa5_quantityonhand || 0), 
                    price: chem.craa5_priceperunit || 0,
                    supplierName: supplierName
                });
            }
        });
        return list;
    };

    const [carts, setCarts] = useState([] as any[]);
    const [isInitialized, setIsInitialized] = useState(false);
    const [dragged, setDragged] = useState(null as any);
    const [dragOverIdx, setDragOverIdx] = useState(null as any);
    const [submitStatus, setSubmitStatus] = useState(null as any);
    
    const [manualChemOptions, setManualChemOptions] = useState([] as string[]);
    const [manualQty, setManualQty] = useState("");

    const getFormattedDate = () => formatDateShorthand(new Date());

    const generateInitialCarts = () => {
        const needed = getNeeded();
        const groups: any = {};
        
        needed.forEach((item: any) => {
            if (!groups[item.supplierName]) groups[item.supplierName] = [];
            groups[item.supplierName].push(item);
        });

        setCarts(Object.keys(groups).map(supplier => ({
            name: `${supplier} | ${getFormattedDate()}`,
            items: groups[supplier]
        })) as any);
    };

    useEffect(() => {
        if (!isInitialized && chemicals.length > 0 && inventories.length > 0) {
            generateInitialCarts();
            setIsInitialized(true);
        }
    }, [chemicals, inventories, distributors, isInitialized]);

    const handleManualAdd = () => {
        if (manualChemOptions.length === 0 || !manualQty) return;
        const chemId = manualChemOptions[0];
        const chemObj = chemicals.find((c: any) => c.craa5_chemicalid === chemId);
        if (!chemObj) return;

        const manualItem = {
            chemicalId: chemObj.craa5_chemicalid,
            chemicalName: chemObj.craa5_chemicalname,
            amount: Number(manualQty),
            price: chemObj.craa5_priceperunit || 0,
            supplierName: "Manual Override"
        };

        setCarts((prev: any[]) => [
            { name: `Custom Order | ${getFormattedDate()}`, items: [manualItem] },
            ...prev
        ] as any);

        setManualChemOptions([]);
        setManualQty("");
    };

    const submit = async () => {
        let hasSubmitted = false;
        setSubmitStatus(null);
        
        try {
            for (const cart of carts as any[]) {
                if (cart.items.length === 0) continue;
                hasSubmitted = true;
                
                await Promise.all(cart.items.map(async (item: any) => {
                    await dataApi.createRow("craa5_cart", {
                        craa5_cartname: cart.name, 
                        craa5_location: item.chemicalName,
                        craa5_cost: item.price, 
                        craa5_amountordered: item.amount,
                        craa5_carttotal: item.amount * item.price, 
                        craa5_dateofrequest: new Date().toISOString(),
                        craa5_ordered: STATUS_CHOICES.SUBMITTED 
                    });

                    // [ERROR HANDLING & LOGIC]: Immediately block UI updates to On-Order status to prevent duplicate ordering.
                    const inv = inventories.find((i: any) => i._craa5_chemicalname_value?.includes(item.chemicalId));
                    if (inv) {
                        await dataApi.updateRow("craa5_chemicalinventory", inv.craa5_chemicalinventoryid, {
                            craa5_quantityonorder: (inv.craa5_quantityonorder || 0) + item.amount,
                            craa5_lastupdated: new Date().toISOString()
                        });
                    }
                }));
            }
            
            if (hasSubmitted) {
                setSubmitStatus({ type: "success", msg: "Carts Submitted & On-Order Inventory Synchronized!" });
                generateInitialCarts();
            } else {
                setSubmitStatus({ type: "error", msg: "There are no items in any carts to submit." });
            }
        } catch (e) {
            setSubmitStatus({ type: "error", msg: "Failed to submit carts. Check connections." });
        }
    };

    const handleDrop = (targetIdx: number) => {
        setDragOverIdx(null);
        if (!dragged || dragged.sourceIdx === targetIdx) {
            setDragged(null); return;
        }

        setCarts((prevCarts: any[]) => {
            const newCarts = [...prevCarts];
            newCarts[dragged.sourceIdx] = {
                ...newCarts[dragged.sourceIdx],
                items: newCarts[dragged.sourceIdx].items.filter((i: any) => i.chemicalId !== dragged.item.chemicalId)
            };
            newCarts[targetIdx] = {
                ...newCarts[targetIdx],
                items: [...newCarts[targetIdx].items, dragged.item]
            };
            return newCarts;
        });
        setDragged(null);
    };

    const sortedChemicals = [...chemicals].sort((a: any, b: any) => a.craa5_chemicalname?.localeCompare(b.craa5_chemicalname));

    return (
        // [DIAGNOSIS FIX]: Explicitly using a <div> wrapper instead of a Fragment (<>...</>)
        <div style={{ display: "flex", flexDirection: "column", height: "100%" }}>
            <div className={styles.headerRow}>
                <div className={styles.titleBlock}>
                    <Text as="h2" size={700} weight="bold" style={{ margin: "0 0 4px 0" }}>Assign New Carts</Text>
                    <Text size={300} style={{ color: tokens.colorNeutralForeground3 }}>Auto-generated suggestions based on thresholds. Drag items to reassign.</Text>
                </div>
                <div style={{ display: "flex", gap: "12px", alignItems: "center" }}>
                    <Button appearance="outline" onClick={() => setCarts([{ name: `Custom Cart | ${getFormattedDate()}`, items: [] }, ...carts] as any)}>
                        <AddRegular style={{ marginRight: 4 }} /> Empty Cart
                    </Button>
                    <Button appearance="primary" onClick={submit} style={{ backgroundColor: "#8C1F28" }}>
                        Submit All Carts
                    </Button>
                </div>
            </div>

            <div className={styles.compactActionBar}>
                <Text weight="semibold" style={{ color: "#8C1F28" }}>+ Manual Entry</Text>
                <Divider vertical style={{ height: "24px" }} />
                <Dropdown
                    placeholder="Select chemical..."
                    selectedOptions={manualChemOptions}
                    onOptionSelect={(_, data) => setManualChemOptions(data.optionValue ? [data.optionValue] as any : [])}
                    style={{ flex: "1 1 200px", minWidth: "150px" }}
                >
                    {sortedChemicals.map((chem: any) => (
                        <Option key={chem.craa5_chemicalid} value={chem.craa5_chemicalid}>
                            {chem.craa5_chemicalname}
                        </Option>
                    ))}
                </Dropdown>
                <Input
                    type="number"
                    min={1}
                    placeholder="Qty"
                    value={manualQty}
                    onChange={(_, d) => setManualQty(d.value)}
                    style={{ width: "80px" }}
                />
                <Button 
                    appearance="secondary" 
                    onClick={handleManualAdd} 
                    disabled={manualChemOptions.length === 0 || !manualQty}
                >
                    Add
                </Button>
            </div>

            {submitStatus && (
                <div className={submitStatus.type === "success" ? styles.alertSuccess : styles.alertError}>
                    {submitStatus.type === "success" ? <CheckmarkCircleRegular /> : <DismissCircleRegular />}
                    <Text>{submitStatus.msg}</Text>
                </div>
            )}

            <div className={styles.gridDashboard}>
                {carts.map((c: any, idx: number) => (
                    <div 
                        key={idx} 
                        className={styles.card}
                        onDragOver={e => { e.preventDefault(); setDragOverIdx(idx); }}
                        onDragLeave={() => setDragOverIdx(null)}
                        onDrop={() => handleDrop(idx)}
                        style={{ 
                            borderTop: `4px solid #8C1F28`,
                            borderColor: dragOverIdx === idx ? tokens.colorBrandStroke1 : undefined,
                            boxShadow: dragOverIdx === idx ? tokens.shadow8 : tokens.shadow2,
                            transform: dragOverIdx === idx ? "scale(1.02)" : "scale(1)",
                            transition: "all 0.2s ease"
                        }}
                    >
                        <div style={{ padding: "4px 0", borderBottom: `1px solid ${tokens.colorNeutralStroke2}` }}>
                            <Text size={400} weight="bold">{c.name}</Text>
                        </div>
                        
                        {c.items.length === 0 ? (
                            <div style={{ border: `2px dashed ${tokens.colorNeutralStroke2}`, borderRadius: tokens.borderRadiusMedium, padding: "24px", textAlign: "center" }}>
                                <Text style={{ color: tokens.colorNeutralForeground4, fontStyle: "italic" }}>
                                    Drag items here
                                </Text>
                            </div>
                        ) : (
                            <div style={{ display: "flex", flexDirection: "column", gap: "8px" }}>
                                {c.items.map((it: any) => (
                                    <div 
                                        key={it.chemicalId} 
                                        draggable 
                                        onDragStart={() => setDragged({ item: it, sourceIdx: idx })}
                                        className={styles.dragItem}
                                    >
                                        <Text weight="medium" truncate style={{ flex: 1, paddingRight: 12 }}>{it.chemicalName}</Text>
                                        <Badge appearance="outline" color="brand">Qty: {it.amount}</Badge>
                                    </div>
                                ))}
                            </div>
                        )}
                    </div>
                ))}
            </div>
        </div>
    );
}

/**
 * 3. INVENTORY UPDATE - Split View Architecture
 */
function InventoryUpdateForm({ styles, dataApi, chemicals, inventories, refreshInventories }: any) {
    const [selectedChemicalOptions, setSelectedChemicalOptions] = useState([] as string[]);
    const [selectedChemicalName, setSelectedChemicalName] = useState("");
    const [quantityOnHand, setQuantityOnHand] = useState("");
    const [submitStatus, setSubmitStatus] = useState(null as any);

    const getInventoryForChemical = (chemicalId: string) => {
        return inventories.find((inv: any) => {
            const val = inv._craa5_chemicalname_value || "";
            return val === chemicalId || val.includes(chemicalId) || (val.match(/\(([^)]+)\)/) && val.match(/\(([^)]+)\)/)[1] === chemicalId);
        });
    };

    const sortedChemicalOptions = [...chemicals].sort((a: any, b: any) => {
        const invA = getInventoryForChemical(a.craa5_chemicalid);
        const invB = getInventoryForChemical(b.craa5_chemicalid);
        const orderA = invA?.craa5_displayorder ?? 9999;
        const orderB = invB?.craa5_displayorder ?? 9999;
        return orderA - orderB;
    });

    useEffect(() => {
        if (selectedChemicalOptions.length > 0) {
            const chemId = selectedChemicalOptions[0];
            const inv = getInventoryForChemical(chemId);
            setQuantityOnHand(inv && typeof inv.craa5_quantityonhand === "number" ? inv.craa5_quantityonhand.toString() : "");
            
            const chemObj = chemicals.find((chem: any) => chem.craa5_chemicalid === chemId);
            setSelectedChemicalName(chemObj?.craa5_chemicalname || "");
        } else {
            setQuantityOnHand("");
            setSelectedChemicalName("");
        }
    }, [selectedChemicalOptions, inventories, chemicals]);

    const handleSubmit = async (e: React.FormEvent) => {
        e.preventDefault();
        setSubmitStatus(null);

        // [ERROR HANDLING]: Form validation before attempting Dataverse update.
        if (selectedChemicalOptions.length === 0) {
            setSubmitStatus({ type: "error", msg: "Please select a chemical." }); return;
        }
        if (quantityOnHand === "" || isNaN(Number(quantityOnHand))) {
            setSubmitStatus({ type: "error", msg: "Please enter a valid quantity." }); return;
        }

        const chemId = selectedChemicalOptions[0];
        const inv = getInventoryForChemical(chemId);
        
        if (!inv) {
            setSubmitStatus({ type: "error", msg: "No inventory record found for this chemical." }); return;
        }

        try {
            await dataApi.updateRow("craa5_chemicalinventory", inv.craa5_chemicalinventoryid, {
                craa5_lastupdated: new Date().toISOString(),
                craa5_quantityonhand: Number(quantityOnHand)
            });
            setSubmitStatus({ type: "success", msg: "Inventory updated successfully!" });
            if(refreshInventories) await refreshInventories();
        } catch (err) {
            setSubmitStatus({ type: "error", msg: "Failed to update inventory record." });
        }
    };

    const selectedChemicalObj = chemicals.find((chem: any) => chem.craa5_chemicalid === selectedChemicalOptions[0]);
    const sortedTableInventories = [...inventories].sort((a: any, b: any) => (a.craa5_displayorder || 0) - (b.craa5_displayorder || 0));

    return (
        <div className={styles.splitView}>
            <div className={styles.splitFormCol}>
                <div className={styles.titleBlock}>
                    <Text as="h2" size={700} weight="bold" style={{ margin: "0 0 4px 0" }}>Physical Inventory</Text>
                    <Text size={300} style={{ color: tokens.colorNeutralForeground3 }}>Manually override On-Hand counts.</Text>
                </div>

                <div className={styles.card} style={{ position: "sticky", top: 0 }}>
                    <form onSubmit={handleSubmit} style={{ display: "flex", flexDirection: "column", gap: "16px" }}>
                        <div>
                            <Text size={200} weight="semibold" style={{ display: "block", marginBottom: 4 }}>Chemical</Text>
                            <Dropdown
                                placeholder="Select chemical..."
                                value={selectedChemicalName}
                                selectedOptions={selectedChemicalOptions}
                                onOptionSelect={(_, data) => setSelectedChemicalOptions(data.optionValue ? [data.optionValue] as any : [])}
                                style={{ width: "100%" }}
                            >
                                {sortedChemicalOptions.map((chem: any) => (
                                    <Option key={chem.craa5_chemicalid} value={chem.craa5_chemicalid}>
                                        {chem.craa5_chemicalname}
                                    </Option>
                                ))}
                            </Dropdown>
                        </div>

                        {selectedChemicalObj && (
                            <div style={{ backgroundColor: tokens.colorNeutralBackground2, padding: "8px", borderRadius: tokens.borderRadiusSmall }}>
                                <Text size={200} style={{ color: tokens.colorNeutralForeground3 }}>Item #: <span style={{ color: tokens.colorNeutralForeground1, fontWeight: "500" }}>{selectedChemicalObj.craa5_itemnumber}</span></Text>
                            </div>
                        )}

                        <div>
                            <Text size={200} weight="semibold" style={{ display: "block", marginBottom: 4 }}>Quantity on Hand</Text>
                            <Input
                                type="number"
                                placeholder="0"
                                value={quantityOnHand}
                                onChange={(_, d) => setQuantityOnHand(d.value)}
                                min={0}
                                style={{ width: "100%" }}
                            />
                        </div>

                        <Button appearance="primary" type="submit" size="large" style={{ backgroundColor: "#8C1F28", marginTop: "8px" }}>
                            Commit Update
                        </Button>

                        {submitStatus && (
                            <div className={submitStatus.type === "success" ? styles.alertSuccess : styles.alertError} style={{ margin: 0 }}>
                                {submitStatus.type === "success" ? <CheckmarkCircleRegular /> : <DismissCircleRegular />}
                                <Text size={300}>{submitStatus.msg}</Text>
                            </div>
                        )}
                    </form>
                </div>
            </div>
            
            <div className={styles.splitTableCol}>
                <div className={styles.tableWrapper}>
                    <Table aria-label="Inventory Table">
                        <TableHeader>
                            <TableRow className={styles.stickyHeader}>
                                <TableHeaderCell>Name</TableHeaderCell>
                                <TableHeaderCell>On Hand</TableHeaderCell>
                                <TableHeaderCell>On Order</TableHeaderCell>
                                <TableHeaderCell>Last Updated</TableHeaderCell>
                                <TableHeaderCell>Total Limit</TableHeaderCell>
                            </TableRow>
                        </TableHeader>
                        <TableBody>
                            {sortedTableInventories.map((inv: any) => (
                                <TableRow key={inv.craa5_chemicalinventoryid}>
                                    <TableCell>{inv.craa5_chemicalinventoryname}</TableCell>
                                    <TableCell><Badge color="brand" appearance="tint" size="medium">{inv.craa5_quantityonhand ?? "N/A"}</Badge></TableCell>
                                    <TableCell>{inv.craa5_quantityonorder ?? "0"}</TableCell>
                                    <TableCell>
                                        <Text size={200} style={{ color: tokens.colorNeutralForeground3 }}>
                                            {formatDateShorthand(inv.craa5_lastupdated)}
                                        </Text>
                                    </TableCell>
                                    <TableCell>{inv.craa5_totalinventory ?? "N/A"}</TableCell>
                                </TableRow>
                            ))}
                        </TableBody>
                    </Table>
                </div>
            </div>
        </div>
    );
}

/**
 * 4. MIN/MAX UPDATE FORM - Split View Architecture
 */
function MinMaxUpdateForm({ styles, dataApi, chemicals, inventories, refreshInventories }: any) {
    const [selectedChemicalOptions, setSelectedChemicalOptions] = useState([] as string[]);
    const [selectedChemicalName, setSelectedChemicalName] = useState("");
    
    const [minThreshold, setMinThreshold] = useState("");

    const [submitStatus, setSubmitStatus] = useState(null as any);

    const getInventoryForChemical = (chemicalId: string) => {
        return inventories.find((inv: any) => {
            const val = inv._craa5_chemicalname_value || "";
            return val === chemicalId || val.includes(chemicalId);
        });
    };

    const sortedChemicalOptions = [...chemicals].sort((a: any, b: any) => {
        const invA = getInventoryForChemical(a.craa5_chemicalid);
        const invB = getInventoryForChemical(b.craa5_chemicalid);
        return (invA?.craa5_displayorder ?? 9999) - (invB?.craa5_displayorder ?? 9999);
    });

    useEffect(() => {
        if (selectedChemicalOptions.length > 0) {
            const chemId = selectedChemicalOptions[0];
            const inv = getInventoryForChemical(chemId);
            setMinThreshold(inv && typeof inv.craa5_minimumthreshold === "number" ? inv.craa5_minimumthreshold.toString() : "");
            
            const chemObj = chemicals.find((chem: any) => chem.craa5_chemicalid === chemId);
            setSelectedChemicalName(chemObj?.craa5_chemicalname || "");
        } else {
            setMinThreshold("");
            setSelectedChemicalName("");
        }
    }, [selectedChemicalOptions, inventories, chemicals]);

    const handleSubmit = async (e: React.FormEvent) => {
        e.preventDefault();
        setSubmitStatus(null);

        // [ERROR HANDLING]: Form validation before attempting Dataverse update.
        if (selectedChemicalOptions.length === 0) {
            setSubmitStatus({ type: "error", msg: "Please select a chemical." }); return;
        }

        const chemId = selectedChemicalOptions[0];
        const inv = getInventoryForChemical(chemId);
        if (!inv) {
            setSubmitStatus({ type: "error", msg: "No inventory record found." }); return;
        }

        try {
            const payload: any = {
                craa5_lastupdated: new Date().toISOString(),
                craa5_minimumthreshold: minThreshold ? Number(minThreshold) : null
            };

            await dataApi.updateRow("craa5_chemicalinventory", inv.craa5_chemicalinventoryid, payload);
            setSubmitStatus({ type: "success", msg: "Thresholds updated successfully!" });
            if(refreshInventories) await refreshInventories(); 
        } catch (err) {
            setSubmitStatus({ type: "error", msg: "Failed to update thresholds." });
        }
    };

    const sortedTableInventories = [...inventories].sort((a: any, b: any) => (a.craa5_displayorder || 0) - (b.craa5_displayorder || 0));

    return (
        <div className={styles.splitView}>
            <div className={styles.splitFormCol}>
                <div className={styles.titleBlock}>
                    <Text as="h2" size={700} weight="bold" style={{ margin: "0 0 4px 0" }}>Threshold Rules</Text>
                    <Text size={300} style={{ color: tokens.colorNeutralForeground3 }}>Configure auto-reorder trigger points.</Text>
                </div>

                <div className={styles.card} style={{ position: "sticky", top: 0 }}>
                    <form onSubmit={handleSubmit} style={{ display: "flex", flexDirection: "column", gap: "16px" }}>
                        <div>
                            <Text size={200} weight="semibold" style={{ display: "block", marginBottom: 4 }}>Chemical</Text>
                            <Dropdown
                                placeholder="Select chemical..."
                                value={selectedChemicalName}
                                selectedOptions={selectedChemicalOptions}
                                onOptionSelect={(_, data) => setSelectedChemicalOptions(data.optionValue ? [data.optionValue] as any : [])}
                                style={{ width: "100%" }}
                            >
                                {sortedChemicalOptions.map((chem: any) => (
                                    <Option key={chem.craa5_chemicalid} value={chem.craa5_chemicalid}>
                                        {chem.craa5_chemicalname}
                                    </Option>
                                ))}
                            </Dropdown>
                        </div>

                        <div>
                            <Text size={200} weight="semibold" style={{ display: "block", marginBottom: 4 }}>Minimum Threshold (Trigger)</Text>
                            <Input
                                type="number"
                                placeholder="Min Qty"
                                value={minThreshold}
                                onChange={(_, d) => setMinThreshold(d.value)}
                                min={0}
                                style={{ width: "100%" }}
                            />
                        </div>

                        <Button appearance="primary" type="submit" size="large" style={{ backgroundColor: "#8C1F28", marginTop: 8 }}>
                            Save Thresholds
                        </Button>

                        {submitStatus && (
                            <div className={submitStatus.type === "success" ? styles.alertSuccess : styles.alertError} style={{ margin: 0 }}>
                                {submitStatus.type === "success" ? <CheckmarkCircleRegular /> : <DismissCircleRegular />}
                                <Text size={300}>{submitStatus.msg}</Text>
                            </div>
                        )}
                    </form>
                </div>
            </div>
            
            <div className={styles.splitTableCol}>
                <div className={styles.tableWrapper}>
                    <Table aria-label="Threshold Table">
                        <TableHeader>
                            <TableRow className={styles.stickyHeader}>
                                <TableHeaderCell>Name</TableHeaderCell>
                                <TableHeaderCell>Min Threshold</TableHeaderCell>
                                <TableHeaderCell>On Hand</TableHeaderCell>
                                <TableHeaderCell>Status</TableHeaderCell>
                            </TableRow>
                        </TableHeader>
                        <TableBody>
                            {sortedTableInventories.map((inv: any) => {
                                const onHand = inv.craa5_quantityonhand || 0;
                                const min = inv.craa5_minimumthreshold || 0;
                                const needsOrder = onHand < min;
                                
                                return (
                                    <TableRow key={inv.craa5_chemicalinventoryid}>
                                        <TableCell>{inv.craa5_chemicalinventoryname}</TableCell>
                                        <TableCell><Text weight="bold">{min}</Text></TableCell>
                                        <TableCell>{onHand}</TableCell>
                                        <TableCell>
                                            {needsOrder ? (
                                                <Badge appearance="filled" color="danger">Needs Order</Badge>
                                            ) : (
                                                <Badge appearance="tint" color="success">Sufficient</Badge>
                                            )}
                                        </TableCell>
                                    </TableRow>
                                );
                            })}
                        </TableBody>
                    </Table>
                </div>
            </div>
        </div>
    );
}

