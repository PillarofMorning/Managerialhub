// ============================================================================
// HELPER FUNCTIONS (Preserved exactly from Dataverse Context)
// ============================================================================
function formatFullName(name) {
    if (!name) return "";
    const parts = name.split(",");
    if (parts?.length > 1) {
        const lastName = parts[0].trim();
        const firstNames = parts.slice(1).join(",").trim();
        return `${firstNames} ${lastName}`;
    }
    return name.trim();
}

function getEmployeeEmail(e) {
    if (!e) return "";
    return e.craa5_email || e.craa5_Email || e.email || e.emailaddress1 || e.internalemailaddress || "";
}

function renderSafe(val) {
    if (val === null || val === undefined) return "";
    if (typeof val === 'object') return String(val.Label || val.Value || val.name || JSON.stringify(val));
    return String(val);
}

function getInputValue(e, d) {
    if (typeof d === 'string') return d;
    if (d && typeof d === 'object' && d.value !== undefined) return d.value;
    if (e && e.target && e.target.value !== undefined) return e.target.value;
    return "";
}

function determineCurrentShift() {
    const now = new Date();
    const day = now.getDay(); 
    const hour = now.getHours();
    if (hour >= 6 && hour < 18) {
        if (day === 0 || day === 1 || day === 2) return "A";
        if (day === 4 || day === 5 || day === 6) return "C";
        if (day === 3) return hour < 12 ? "A" : "C"; 
    } else {
        if (hour >= 18) {
            if (day === 0 || day === 1 || day === 2 || day === 3) return "B"; 
            if (day === 4 || day === 5 || day === 6) return "D";              
        } else {
            if (day === 1 || day === 2 || day === 3) return "B";              
            if (day === 4 || day === 5 || day === 6 || day === 0) return "D"; 
        }
    }
    return "A";
}

function normalizeShift(val) {
    if (val === null || val === undefined) return "";
    let str = typeof val === 'object' ? String(val.Label || val.Value || "") : String(val);
    const upper = str.toUpperCase();
    if (upper.includes("256000000") || upper.includes("A")) return "A";
    if (upper.includes("256000001") || upper.includes("B")) return "B";
    if (upper.includes("256000002") || upper.includes("C")) return "C";
    if (upper.includes("256000003") || upper.includes("D")) return "D";
    return "Unknown Shift";
}

function getLocalYMD(dateObj) {
    const y = dateObj.getFullYear();
    const m = String(dateObj.getMonth() + 1).padStart(2, '0');
    const d = String(dateObj.getDate()).padStart(2, '0');
    return `${y}-${m}-${d}`;
}

function getTaskDate(task) {
    const raw = task.craa5_datetimeofassignment || task.createdon;
    if (!raw) return "";
    return getLocalYMD(new Date(raw));
}

function parseDurationStr(str) {
    if (!str) return 0;
    let ms = 0;
    const hMatch = str.match(/(\d+)\s*h/i);
    const mMatch = str.match(/(\d+)\s*m/i);
    if (hMatch) ms += parseInt(hMatch[1], 10) * 3600000;
    if (mMatch) ms += parseInt(mMatch[1], 10) * 60000;
    return ms;
}

function formatMsToDuration(ms) {
    if (ms <= 0) return "0m";
    const diffMins = Math.floor(ms / 60000);
    const hrs = Math.floor(diffMins / 60);
    const mins = diffMins % 60;
    return hrs > 0 ? `${hrs}h ${mins}m` : `${mins}m`;
}

function safeGetXrm() {
    if (typeof window === 'undefined') return null;
    if (window.Xrm) return window.Xrm;
    try { if (window.parent && window.parent !== window && window.parent.Xrm) return window.parent.Xrm; } catch (e) {}
    try { if (window.top && window.top !== window && window.top.Xrm) return window.top.Xrm; } catch (e) {}
    return null;
}

async function fetchAllActiveRecords(entityName, dataApi) {
    const xrm = safeGetXrm();
    if (xrm?.WebApi) {
        try {
            const fetchXml = `<fetch top='5000'><entity name='${entityName}'><all-attributes/><filter><condition attribute='statecode' operator='eq' value='0'/></filter></entity></fetch>`;
            const res = await xrm.WebApi.retrieveMultipleRecords(entityName, "?fetchXml=" + encodeURIComponent(fetchXml));
            if (res && res.entities) return res.entities;
        } catch (e) {
            console.warn(`FetchXML failed for ${entityName}, falling back...`, e);
        }
    }
    if (dataApi?.queryTable) {
        try {
            const res = await dataApi.queryTable(entityName, { filter: "statecode eq 0", top: 5000 });
            if (res && res.rows) return res.rows;
        } catch (e) {
            console.warn(`queryTable failed for ${entityName}`, e);
        }
    }
    return [];
}

// ============================================================================
// MAIN COMPONENT
// ============================================================================
export default function ScheduleApp({ dataApi, ...props }) {
    // --- DATAVERSE TABLE TARGETS ---
    const TABLE_EMPLOYEE = "craa5__aa_employee";
    const TABLE_TASK = "craa5_taskassignment";
    const TABLE_TODO = "craa5__supervisor_todo"; 
    const TABLE_PROD = "craa5__aa_prd_schd"; 
    
    // --- SYSTEM STATE ---
    const [isLoading, setIsLoading] = useState(true);
    const [activeTab, setActiveTab] = useState("overview");
    const [currentShift, setCurrentShift] = useState(determineCurrentShift());
    const [currentTime, setCurrentTime] = useState(Date.now());
    
    // --- DATE SELECTION STATE ---
    const [selectedDate, setSelectedDate] = useState(getLocalYMD(new Date()));
    const [calendarMonth, setCalendarMonth] = useState(new Date(new Date().getFullYear(), new Date().getMonth(), 1));
    const [prodCalendarMonth, setProdCalendarMonth] = useState(new Date(new Date().getFullYear(), new Date().getMonth(), 1));
    const [ganttViewType, setGanttViewType] = useState("daily");
    
    // --- DATA COLLECTIONS ---
    const [employees, setEmployees] = useState([]);
    const [supervisors, setSupervisors] = useState([]);
    const [areas, setAreas] = useState([]);
    const [allAssignments, setAllAssignments] = useState([]);
    const [todoTasks, setTodoTasks] = useState([]);
    const [prodSchedules, setProdSchedules] = useState([]);

    // --- TASK & PROD FORM STATE ---
    const [isTaskDialogOpen, setIsTaskDialogOpen] = useState(false);
    const [taskPayload, setTaskPayload] = useState({ title: "", description: "", supervisorEmail: "", expectationDate: "" });
    const [isSubmittingTask, setIsSubmittingTask] = useState(false);

    const [schPayload, setSchPayload] = useState({ 
        area: "", product: "", 
        startDate: selectedDate, startTime: "06:00", 
        endDate: selectedDate, endTime: "14:00", 
        runLength: "8", 
        isRecurring: false, recurType: "daily", recurDays: 1, recurDayOfWeek: new Date(selectedDate).getDay().toString(),
        allergen: false, typeOfAllergen: "", crumbClean: false 
    });
    const [isSubmittingSch, setIsSubmittingSch] = useState(false);
    const [schSubmitStatus, setSchSubmitStatus] = useState(null); 
    
    // --- PROD EDIT STATE ---
    const [editSchOpen, setEditSchOpen] = useState(false);
    const [editSchData, setEditSchData] = useState(null);

    // ========================================================================
    // INJECT TAILWIND CSS (Fixes the unstyled layout in PowerApps)
    // ========================================================================
    useEffect(() => {
        if (typeof document !== 'undefined' && !document.getElementById('tailwind-cdn')) {
            const script = document.createElement('script');
            script.id = 'tailwind-cdn';
            script.src = 'https://cdn.tailwindcss.com';
            document.head.appendChild(script);
        }
    }, []);

    // ========================================================================
    // HYDRATION & TIMERS
    // ========================================================================
    useEffect(() => {
        const interval = setInterval(() => setCurrentTime(Date.now()), 60000);
        return () => clearInterval(interval);
    }, []);

    useEffect(() => {
        let isMounted = true;
        const loadDashboardData = async () => {
            setIsLoading(true);
            try {
                const allStaff = await fetchAllActiveRecords(TABLE_EMPLOYEE, dataApi);
                const sups = allStaff?.filter(e => (e.craa5_role || e.craa5_Role) === 256000002) || [];
                
                const allTasks = await fetchAllActiveRecords(TABLE_TASK, dataApi);
                const todoList = await fetchAllActiveRecords(TABLE_TODO, dataApi);
                const schList = await fetchAllActiveRecords(TABLE_PROD, dataApi);

                let areaList = await fetchAllActiveRecords("craa5__aa_areas", dataApi);
                if (!areaList || areaList?.length === 0) areaList = await fetchAllActiveRecords("craa5_aa_areas", dataApi);
                if (!areaList || areaList?.length === 0) areaList = await fetchAllActiveRecords("craa5_aa_mss_area", dataApi);

                // Mock Data Fallback for preview
                if (!allStaff?.length && !areaList?.length) {
                    console.log("Applying Mock Data for Canvas Preview");
                    areaList = [
                        { craa5_area: 'Breading', craa5_production: true },
                        { craa5_area: 'Fryer Line 1', craa5_production: true },
                        { craa5_area: 'Packaging', craa5_production: true },
                        { craa5_area: 'Maintenance', craa5_production: false },
                    ];
                    schList.push(
                        { craa5__aa_prd_schdid: '1', craa5_area: 'Breading', craa5_product: 'Heavy Run', craa5_datestarttime: `${selectedDate}T06:00:00Z`, craa5_dateendtime: `${selectedDate}T14:00:00Z` },
                        { craa5__aa_prd_schdid: '2', craa5_area: 'Fryer Line 1', craa5_product: 'Standard', craa5_datestarttime: `${selectedDate}T10:00:00Z`, craa5_dateendtime: `${selectedDate}T18:30:00Z` }
                    );
                    allTasks.push(
                        { craa5_taskassignmentid: 't1', craa5_id: 'Doe, John', craa5_area: 'Breading', craa5_lead: 'Smith Team', craa5_team: 'Smith', craa5_percentagecomplete: 50, createdon: new Date().toISOString(), craa5_shift: 'A' },
                        { craa5_taskassignmentid: 't2', craa5_id: 'Roe, Jane', craa5_area: 'Fryer Line 1', craa5_lead: 'Jones Team', craa5_team: 'Jones', craa5_percentagecomplete: 100, createdon: new Date().toISOString(), craa5_shift: 'A' }
                    );
                }

                if (isMounted) {
                    setEmployees(allStaff || []);
                    setSupervisors(sups.sort((a, b) => (a.craa5_name || "").localeCompare(b.craa5_name || "")));
                    setAreas(areaList || []);
                    setAllAssignments(allTasks || []);
                    setTodoTasks(todoList?.sort((a,b) => new Date(b.createdon) - new Date(a.createdon)) || []);
                    setProdSchedules(schList || []);
                }
            } catch (err) {
                console.error("Dashboard Hydration Error", err);
            } finally {
                if (isMounted) setIsLoading(false);
            }
        };

        loadDashboardData();
        return () => { isMounted = false; };
    }, [dataApi]);

    // ========================================================================
    // DATE-FILTERED DATA AGGREGATION & EXECUTIVE SUMMARY
    // ========================================================================
    const dailyAssignments = useMemo(() => {
        return allAssignments?.filter(t => getTaskDate(t) === selectedDate) || [];
    }, [allAssignments, selectedDate]);

    const liveCurrentShiftAssignments = useMemo(() => {
        return allAssignments?.filter(t => 
            getTaskDate(t) === getLocalYMD(new Date()) && 
            normalizeShift(t["craa5_shift@OData.Community.Display.V1.FormattedValue"] || t.craa5_shift || t.craa5_Shift) === currentShift
        ) || [];
    }, [allAssignments, currentShift]);

    // Playbook Grouping (Deduplicated & Filtered by Latest Task/Completed Status)
    const { activePlaybookByLead, completedTasks, unassignedTasks } = useMemo(() => {
        const leadsMap = {};
        const completed = [];
        const unassigned = [];
        const seenEmployees = new Set();

        const sortedLive = [...liveCurrentShiftAssignments].sort((a, b) => {
            const timeA = new Date(a.craa5_datetimeofassignment || a.createdon).getTime();
            const timeB = new Date(b.craa5_datetimeofassignment || b.createdon).getTime();
            return timeB - timeA;
        });

        sortedLive.forEach(task => {
            const empName = formatFullName(task.craa5_id);
            const isComplete = task.craa5_percentagecomplete === 100 || (task.craa5__currentstatus || "").toLowerCase().includes("complete");

            if (!empName) {
                if (isComplete) completed.push(task); else unassigned.push(task);
                return;
            }

            const dedupeKey = empName;
            if (!seenEmployees.has(dedupeKey)) {
                seenEmployees.add(dedupeKey);
                if (isComplete) {
                    completed.push(task);
                } else {
                    const leadName = (task.craa5_lead || task.craa5_team || "Unassigned Lead").trim();
                    if (!leadsMap[leadName]) leadsMap[leadName] = [];
                    leadsMap[leadName].push(task);
                }
            } else if (isComplete && !completed.some(c => c.craa5_taskassignmentid === task.craa5_taskassignmentid)) {
                completed.push(task);
            }
        });

        Object.keys(leadsMap).forEach(lead => {
            leadsMap[lead].sort((a, b) => {
                const areaA = a.craa5_area || "";
                const areaB = b.craa5_area || "";
                if (areaA !== areaB) return areaA.localeCompare(areaB);
                return formatFullName(a.craa5_id).localeCompare(formatFullName(b.craa5_id));
            });
        });

        return { activePlaybookByLead: leadsMap, completedTasks: completed, unassignedTasks: unassigned };
    }, [liveCurrentShiftAssignments]);

    // Active Production Lines mapping
    const activeProductionLines = useMemo(() => {
        const prodFromTable = areas?.filter(a => {
            const isProd = a.craa5_production || a.craa5_Production || a.craa5_isproduction || a.craa5_IsProduction;
            return isProd === true || isProd === 1 || String(isProd).toLowerCase() === 'yes' || a.craa5_type === 256000000; 
        }) || [];

        const todaySchedules = prodSchedules?.filter(t => {
            const sd = new Date(t.craa5_datestarttime || t.craa5_Datestarttime || t.craa5_starttime); 
            const ed = new Date(t.craa5_dateendtime || t.craa5_Dateendtime || t.craa5_endtime);
            const target = new Date(selectedDate);
            return (sd.toDateString() === target.toDateString() || ed.toDateString() === target.toDateString() || (sd <= target && ed >= target));
        }) || [];

        const scheduledAreaNames = [...new Set(todaySchedules.map(s => s.craa5_area || s.craa5_Area))];
        const allAreaNames = [...new Set([...prodFromTable.map(a => a.craa5_area || a.craa5_name), ...scheduledAreaNames])].filter(Boolean).sort();

        return allAreaNames.map(areaName => {
            const currentSch = todaySchedules.find(s => (s.craa5_area || s.craa5_Area) === areaName);
            return {
                area: areaName,
                product: currentSch ? (currentSch.craa5_product || currentSch.craa5_Product) : "Idle / Empty",
                isScheduled: !!currentSch
            };
        });
    }, [areas, prodSchedules, selectedDate]);

    // KPIs
    const kpis = useMemo(() => {
        const uniqueEmpsAssigned = new Set();
        const activeLeads = new Set();
        let completedAreas = 0;
        let totalAreas = 0;
        
        dailyAssignments?.forEach(task => {
            if (task.craa5_id) uniqueEmpsAssigned.add(task.craa5_id);
            if (task.craa5_lead) activeLeads.add(task.craa5_lead);
            if (task.craa5_area) {
                totalAreas++;
                if (task.craa5_percentagecomplete === 100) completedAreas++;
            }
        });

        const activeSups = new Set(dailyAssignments?.map(a => a.craa5_team).filter(Boolean));
        const openManagerTasks = todoTasks?.filter(t => t.craa5_complete !== true && t.craa5_complete !== 1)?.length || 0;
        const activeProdAreas = new Set();
        
        prodSchedules?.forEach(sch => {
            const sd = new Date(sch.craa5_datestarttime || sch.craa5_Datestarttime || sch.craa5_starttime);
            const ed = new Date(sch.craa5_dateendtime || sch.craa5_Dateendtime || sch.craa5_endtime);
            const target = new Date(selectedDate);
            if (sd.toDateString() === target.toDateString() || ed.toDateString() === target.toDateString() || (sd <= target && ed >= target)) {
                activeProdAreas.add(sch.craa5_area || sch.craa5_Area);
            }
        });

        return {
            staffUtilized: uniqueEmpsAssigned.size,
            leadsActive: activeLeads.size,
            supsActive: activeSups.size,
            completionRate: totalAreas === 0 ? 0 : Math.round((completedAreas / totalAreas) * 100),
            openManagerTasks,
            activeProdAreas: Array.from(activeProdAreas)
        };
    }, [dailyAssignments, todoTasks, prodSchedules, selectedDate]);

    // ========================================================================
    // SHIFTS GRID PROCESSING
    // ========================================================================
    const groupedDailyAssignments = useMemo(() => {
        const groups = {};
        dailyAssignments?.forEach(item => {
            const shift = normalizeShift(item["craa5_shift@OData.Community.Display.V1.FormattedValue"] || item.craa5_shift || item.craa5_Shift);
            const area = (item.craa5_area || "").trim().toLowerCase();
            const empName = formatFullName(item.craa5_id).trim().toLowerCase();
            const equip = (item.craa5_equipment || item.craa5_equip || "").trim();

            const key = empName ? `${shift}_${area}_${empName}` : item.craa5_taskassignmentid || Math.random().toString();

            if (!groups[key]) {
                groups[key] = {
                    ...item,
                    _equipList: equip ? new Set([equip]) : new Set(),
                    _groupCount: 1,
                    _totalSavedDurationMs: parseDurationStr(item.craa5__duration_assigned),
                    _latestStartTime: item.craa5_datetimeofassignment || item.createdon
                };
            } else {
                groups[key]._groupCount += 1;
                if (equip) groups[key]._equipList.add(equip);
                groups[key]._totalSavedDurationMs += parseDurationStr(item.craa5__duration_assigned);
                
                const newTime = new Date(item.craa5_datetimeofassignment || item.createdon).getTime();
                const oldTime = new Date(groups[key]._latestStartTime).getTime();
                if (newTime > oldTime) {
                    groups[key]._latestStartTime = item.craa5_datetimeofassignment || item.createdon;
                }
                
                const currentPct = groups[key].craa5_percentagecomplete || 0;
                const newPct = item.craa5_percentagecomplete || 0;
                if (newPct > currentPct) {
                    groups[key].craa5_percentagecomplete = newPct;
                }
            }
        });

        return Object.values(groups).sort((a, b) => {
            const shiftA = normalizeShift(a["craa5_shift@OData.Community.Display.V1.FormattedValue"] || a.craa5_shift || a.craa5_Shift);
            const shiftB = normalizeShift(b["craa5_shift@OData.Community.Display.V1.FormattedValue"] || b.craa5_shift || b.craa5_Shift);
            if (shiftA !== shiftB) return shiftA.localeCompare(shiftB);
            
            const areaA = a.craa5_area || "";
            const areaB = b.craa5_area || "";
            if (areaA !== areaB) return areaA.localeCompare(areaB);

            return formatFullName(a.craa5_id).localeCompare(formatFullName(b.craa5_id));
        });
    }, [dailyAssignments]);

    // ========================================================================
    // CALENDAR / GANTT HELPERS
    // ========================================================================
    const changeMonth = (offset) => setCalendarMonth(new Date(calendarMonth.getFullYear(), calendarMonth.getMonth() + offset, 1));
    const getCalendarDays = () => {
        const year = calendarMonth.getFullYear();
        const month = calendarMonth.getMonth();
        const firstDay = new Date(year, month, 1).getDay();
        const daysInMonth = new Date(year, month + 1, 0).getDate();
        const days = [];
        for (let i = 0; i < firstDay; i++) days.push(null);
        for (let i = 1; i <= daysInMonth; i++) days.push(i);
        return days;
    };

    const changeProdMonth = (offset) => setProdCalendarMonth(new Date(prodCalendarMonth.getFullYear(), prodCalendarMonth.getMonth() + offset, 1));
    const getProdCalendarDays = () => {
        const year = prodCalendarMonth.getFullYear();
        const month = prodCalendarMonth.getMonth();
        const firstDay = new Date(year, month, 1).getDay();
        const daysInMonth = new Date(year, month + 1, 0).getDate();
        const days = [];
        for (let i = 0; i < firstDay; i++) days.push(null);
        for (let i = 1; i <= daysInMonth; i++) days.push(i);
        return days;
    };

    const ganttSchedules = useMemo(() => {
        const map = {};
        prodSchedules?.forEach(sch => {
            const start = new Date(sch.craa5_datestarttime || sch.craa5_Datestarttime || sch.craa5_starttime);
            const end = new Date(sch.craa5_dateendtime || sch.craa5_Dateendtime || sch.craa5_endtime);
            const base = new Date(selectedDate);
            let include = false;

            if (ganttViewType === "daily") {
                if (start.toDateString() === base.toDateString() || end.toDateString() === base.toDateString() || (start < base && end > base)) include = true;
            } else {
                const weekEnd = new Date(base); weekEnd.setDate(weekEnd.getDate() + 7);
                if (start <= weekEnd && end >= base) include = true;
            }

            if (include) {
                const area = sch.craa5_area || sch.craa5_Area || "Unassigned Area";
                if (!map[area]) map[area] = [];
                map[area].push(sch);
            }
        });
        return map;
    }, [prodSchedules, selectedDate, ganttViewType]);

