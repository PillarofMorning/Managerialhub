                                        <div>
                                            <label className="block text-sm font-medium text-gray-500 mb-1">End Time (Auto-Sets)</label>
                                            <input type="time" value={schPayload.endTime} disabled className="w-full border border-gray-200 bg-gray-50 text-gray-500 rounded-md py-2 px-3 cursor-not-allowed" />
                                        </div>
                                    </div>

                                    {/* Row 4: Checkboxes */}
                                    <div className="flex flex-col sm:flex-row sm:items-center gap-6 p-4 bg-gray-50 rounded-lg border border-gray-100">
                                        <div className="flex items-center gap-4 flex-1">
                                            <label className="flex items-center space-x-3 cursor-pointer">
                                                <input 
                                                    type="checkbox" 
                                                    checked={schPayload.allergen}
                                                    onChange={e => updateScheduleTime('allergen', e.target.checked)}
                                                    className="w-4 h-4 text-blue-600 rounded focus:ring-blue-500" 
                                                />
                                                <span className="text-sm font-medium text-gray-700">Allergen Present</span>
                                            </label>
                                            {schPayload.allergen && (
                                                <input 
                                                    type="text" placeholder="Type of Allergen" 
                                                    value={schPayload.typeOfAllergen} onChange={e => updateScheduleTime('typeOfAllergen', e.target.value)}
                                                    className="flex-1 border border-gray-300 rounded-md py-1.5 px-3 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 border-orange-300"
                                                />
                                            )}
                                        </div>
                                        <label className="flex items-center space-x-3 cursor-pointer flex-1">
                                            <input 
                                                type="checkbox" 
                                                checked={schPayload.crumbClean}
                                                onChange={e => updateScheduleTime('crumbClean', e.target.checked)}
                                                className="w-4 h-4 text-blue-600 rounded focus:ring-blue-500" 
                                            />
                                            <span className="text-sm font-medium text-gray-700">Crumb Clean Required</span>
                                        </label>
                                    </div>

                                    {/* Row 5: Recurrence Box */}
                                    <div className={`rounded-lg border transition-all duration-300 ${schPayload.isRecurring ? 'border-gray-200 shadow-sm' : 'border-transparent'}`}>
                                        <div className="p-4 bg-gray-50 rounded-t-lg flex items-center border-b border-gray-100">
                                            <label className="flex items-center space-x-3 cursor-pointer font-medium text-gray-800">
                                                <input 
                                                    type="checkbox" 
                                                    checked={schPayload.isRecurring}
                                                    onChange={e => updateScheduleTime('isRecurring', e.target.checked)}
                                                    className="w-5 h-5 text-blue-600 rounded focus:ring-blue-500" 
                                                />
                                                <span>Enable Recurrence</span>
                                            </label>
                                        </div>

                                        {schPayload.isRecurring && (
                                            <div className="p-6 bg-white space-y-6 rounded-b-lg">
                                                <div className="flex flex-col md:flex-row gap-6 items-center">
                                                    <div className="w-full md:w-1/3 space-y-2">
                                                        <label className="block text-sm font-medium text-gray-700">Pattern Type</label>
                                                        <select 
                                                            value={schPayload.recurType} 
                                                            onChange={e => updateScheduleTime('recurType', e.target.value)} 
                                                            className="w-full border border-gray-300 rounded-md py-2 px-3 focus:ring-blue-500"
                                                        >
                                                            <option value="daily">Daily (Consecutive Days)</option>
                                                            <option value="weekly">Weekly (Rest of Year)</option>
                                                        </select>
                                                    </div>
                                                    
                                                    <div className="w-full md:w-2/3 md:border-l md:pl-6 pt-6 md:pt-0">
                                                        {schPayload.recurType === 'daily' && (
                                                            <div className="flex items-center gap-3 text-sm text-gray-700">
                                                                <span>Repeat for</span>
                                                                <input 
                                                                    type="number" min="1" max="30" 
                                                                    value={schPayload.recurDays} onChange={e => updateScheduleTime('recurDays', e.target.value)} 
                                                                    className="w-20 border border-gray-300 rounded-md py-1.5 px-3 text-center focus:ring-blue-500" 
                                                                />
                                                                <span>consecutive days.</span>
                                                            </div>
                                                        )}
                                                        {schPayload.recurType === 'weekly' && (
                                                            <div className="flex items-center gap-3 text-sm text-gray-700 flex-wrap">
                                                                <span>Repeat every</span>
                                                                <select 
                                                                    value={schPayload.recurDayOfWeek} onChange={e => updateScheduleTime('recurDayOfWeek', e.target.value)} 
                                                                    className="border border-gray-300 rounded-md py-1.5 px-3 focus:ring-blue-500"
                                                                >
                                                                    <option value="0">Sunday</option>
                                                                    <option value="1">Monday</option>
                                                                    <option value="2">Tuesday</option>
                                                                    <option value="3">Wednesday</option>
                                                                    <option value="4">Thursday</option>
                                                                    <option value="5">Friday</option>
                                                                    <option value="6">Saturday</option>
                                                                </select>
                                                                <span>until Dec 31st.</span>
                                                                <p className="w-full text-xs text-gray-500 mt-2 italic">The system will generate individual batches for each scheduled day, allowing specific adjustments on the Gantt chart.</p>
                                                            </div>
                                                        )}
                                                    </div>
                                                </div>
                                            </div>
                                        )}
                                    </div>

                                    {/* Action & Status */}
                                    <div className="pt-4 border-t border-gray-100 flex flex-col items-end gap-4">
                                        <button 
                                            onClick={handleCreateProductionSchedule}
                                            disabled={isSubmittingSch || !schPayload.area || !schPayload.product}
                                            className="bg-blue-600 hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed text-white font-medium py-2.5 px-6 rounded-md shadow transition-colors flex items-center justify-center min-w-[250px]"
                                        >
                                            {isSubmittingSch ? <RotateCcwIcon className="w-5 h-5 animate-spin" /> : "Save to Production Schedule"}
                                        </button>
                                        
                                        {schSubmitStatus && (
                                            <div className={`p-3 rounded-lg border flex gap-3 items-center w-full md:w-auto min-w-[300px] ${schSubmitStatus.type === 'success' ? 'bg-green-50 border-green-200 text-green-800' : 'bg-red-50 border-red-200 text-red-800'}`}>
                                                <CheckCircleIcon className="w-5 h-5 flex-shrink-0" />
                                                <span className="text-sm font-medium">{schSubmitStatus.message}</span>
                                            </div>
                                        )}
                                    </div>
                                </div>
                            </div>
                        </div>
                    )}
                </div>
            </main>

            {/* ======================================================================== */}
            {/* MODALS / DIALOGS */}
            {/* ======================================================================== */}

            {/* Edit Schedule Time Dialog */}
            {editSchOpen && editSchData && (
                <div className="fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm p-4">
                    <div className="bg-white rounded-xl shadow-2xl max-w-md w-full overflow-hidden animate-in zoom-in-95 duration-200">
                        <div className="bg-blue-900 px-6 py-4 flex justify-between items-center">
                            <h3 className="text-lg font-bold text-white">Adjust Production Timeframe</h3>
                        </div>
                        <div className="p-6 space-y-5">
                            <div className="bg-gray-50 p-3 rounded-lg border border-gray-200">
                                <p className="text-sm"><strong className="text-gray-700">Area:</strong> {editSchData.area}</p>
                                <p className="text-sm"><strong className="text-gray-700">Product:</strong> {editSchData.product}</p>
                            </div>
                            <div className="flex gap-4">
                                <div className="flex-1 space-y-1">
                                    <label className="text-xs font-semibold text-gray-500 uppercase">Start Date</label>
                                    <input type="date" value={editSchData.startDate} onChange={(e) => setEditSchData(p => ({...p, startDate: e.target.value}))} className="w-full border border-gray-300 rounded py-2 px-3 text-sm focus:ring-blue-500" />
                                </div>
                                <div className="flex-1 space-y-1">
                                    <label className="text-xs font-semibold text-gray-500 uppercase">Start Time</label>
                                    <input type="time" value={editSchData.startTime} onChange={(e) => setEditSchData(p => ({...p, startTime: e.target.value}))} className="w-full border border-gray-300 rounded py-2 px-3 text-sm focus:ring-blue-500" />
                                </div>
                            </div>
                            <div className="flex gap-4">
                                <div className="flex-1 space-y-1">
                                    <label className="text-xs font-semibold text-gray-500 uppercase">End Date</label>
                                    <input type="date" value={editSchData.endDate} onChange={(e) => setEditSchData(p => ({...p, endDate: e.target.value}))} className="w-full border border-gray-300 rounded py-2 px-3 text-sm focus:ring-blue-500" />
                                </div>
                                <div className="flex-1 space-y-1">
                                    <label className="text-xs font-semibold text-gray-500 uppercase">End Time</label>
                                    <input type="time" value={editSchData.endTime} onChange={(e) => setEditSchData(p => ({...p, endTime: e.target.value}))} className="w-full border border-gray-300 rounded py-2 px-3 text-sm focus:ring-blue-500" />
                                </div>
                            </div>
                        </div>
                        <div className="bg-gray-50 px-6 py-4 flex justify-end gap-3 border-t border-gray-200">
                            <button onClick={() => setEditSchOpen(false)} className="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50">Cancel</button>
                            <button onClick={handleUpdateSchedule} className="px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-md hover:bg-blue-700">Save Update</button>
                        </div>
                    </div>
                </div>
            )}

            {/* Task Delegation Dialog */}
            {isTaskDialogOpen && (
                <div className="fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm p-4">
                    <div className="bg-white rounded-xl shadow-2xl max-w-lg w-full overflow-hidden animate-in zoom-in-95 duration-200">
                        <div className="bg-blue-900 px-6 py-4 flex justify-between items-center">
                            <h3 className="text-lg font-bold text-white flex items-center gap-2"><TargetIcon className="w-5 h-5"/> Delegate Task to Supervisor</h3>
                        </div>
                        <div className="p-6 space-y-5">
                            <div className="space-y-1">
                                <label className="text-sm font-semibold text-gray-700">Assign To (Supervisor)</label>
                                <select 
                                    value={taskPayload.supervisorEmail} 
                                    onChange={(e) => setTaskPayload(p => ({ ...p, supervisorEmail: e.target.value }))} 
                                    className="w-full border border-gray-300 rounded py-2 px-3 focus:ring-blue-500"
                                >
                                    <option value="">Select a supervisor...</option>
                                    {supervisors?.map(sup => {
                                        const email = getEmployeeEmail(sup);
                                        return <option key={sup.craa5__aa_employeeid} value={email} disabled={!email}>{formatFullName(sup.craa5_name)} {email ? `(${email})` : '(No Email)'}</option>;
                                    })}
                                </select>
                            </div>
                            <div className="space-y-1">
                                <label className="text-sm font-semibold text-gray-700">Task Title</label>
                                <input 
                                    type="text" placeholder="e.g. Audit Line 4 Safety Protocol" 
                                    value={taskPayload.title} onChange={(e) => setTaskPayload(p => ({ ...p, title: e.target.value }))} 
                                    className="w-full border border-gray-300 rounded py-2 px-3 focus:ring-blue-500" 
                                />
                            </div>
                            <div className="space-y-1">
                                <label className="text-sm font-semibold text-gray-700">Task Description</label>
                                <textarea 
                                    placeholder="Provide specific instructions..." rows={4}
                                    value={taskPayload.description} onChange={(e) => setTaskPayload(p => ({ ...p, description: e.target.value }))} 
                                    className="w-full border border-gray-300 rounded py-2 px-3 focus:ring-blue-500 resize-none" 
                                />
                            </div>
                            <div className="space-y-1">
                                <label className="text-sm font-semibold text-gray-700">Expectation Date</label>
                                <input 
                                    type="date" 
                                    value={taskPayload.expectationDate} onChange={(e) => setTaskPayload(p => ({ ...p, expectationDate: e.target.value }))} 
                                    className="w-full border border-gray-300 rounded py-2 px-3 focus:ring-blue-500" 
                                />
                            </div>
                        </div>
                        <div className="bg-gray-50 px-6 py-4 flex justify-end gap-3 border-t border-gray-200">
                            <button onClick={() => setIsTaskDialogOpen(false)} className="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50">Cancel</button>
                            <button onClick={handleCreateTask} disabled={isSubmittingTask || !taskPayload.title || !taskPayload.supervisorEmail} className="px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-md hover:bg-blue-700 disabled:opacity-50 flex items-center gap-2">
                                {isSubmittingTask ? <RotateCcwIcon className="w-4 h-4 animate-spin" /> : "Assign & Notify"}
                            </button>
                        </div>
                    </div>
                </div>
            )}

        </div>
    );
}
