    const personnelGanttData = useMemo(() => {
        const [y, m, d] = selectedDate.split('-');
        const windowStartObj = new Date(y, m - 1, d, 6, 0, 0);
        const windowStart = windowStartObj.getTime();
        const windowEnd = windowStart + (24 * 3600000);
        
        const isToday = selectedDate === getLocalYMD(new Date());
        const effectiveCurrentTime = isToday ? currentTime : windowEnd;

        const empTasks = {};

        allAssignments?.forEach(task => {
            const empName = formatFullName(task.craa5_id);
            if (!empName) return;
            if (!empTasks[empName]) empTasks[empName] = { tasks: [], shift: 'A' };
            empTasks[empName].tasks.push(task);
            
            const taskShift = normalizeShift(task["craa5_shift@OData.Community.Display.V1.FormattedValue"] || task.craa5_shift || task.craa5_Shift);
            if (taskShift && taskShift !== "Unknown Shift") empTasks[empName].shift = taskShift;
        });

        const chartData = [];

        Object.entries(empTasks).forEach(([empName, data]) => {
            const shift = data.shift;
            const tasks = data.tasks;

            let s1, e1;
            if (shift === 'A' || shift === 'C') {
                s1 = windowStart; 
                e1 = windowStart + (12 * 3600000); 
            } else {
                s1 = windowStart + (12 * 3600000); 
                e1 = windowEnd; 
            }

            const shiftBlocks = [{ start: s1, end: e1 }];

            tasks.sort((a, b) => new Date(a.craa5_datetimeofassignment || a.createdon).getTime() - new Date(b.craa5_datetimeofassignment || b.createdon).getTime());

            let activeBlocks = [];
            for (let i = 0; i < tasks.length; i++) {
                const task = tasks[i];
                const startMs = new Date(task.craa5_datetimeofassignment || task.createdon).getTime();
                const nextTask = tasks[i + 1];
                let endMs = nextTask ? new Date(nextTask.craa5_datetimeofassignment || nextTask.createdon).getTime() : effectiveCurrentTime;
                
                if (endMs < windowStart) continue;
                if (startMs > windowEnd) continue;
                
                let cStart = Math.max(startMs, windowStart);
                let cEnd = Math.min(endMs, windowEnd);

                if (e1 > cStart && s1 < cEnd) {
                    const iStart = Math.max(cStart, s1);
                    const iEnd = Math.min(cEnd, e1);
                    if (iEnd > iStart) {
                        activeBlocks.push({
                            id: task.craa5_taskassignmentid || Math.random().toString(),
                            area: renderSafe(task.craa5_area) || "Unassigned",
                            status: renderSafe(task.craa5__currentstatus) || "",
                            start: iStart,
                            end: iEnd
                        });
                    }
                }
            }

            const mergedBlocks = [];
            if (activeBlocks.length > 0) {
                let currentBlock = activeBlocks[0];
                for(let i=1; i<activeBlocks.length; i++) {
                    if (activeBlocks[i].area === currentBlock.area) {
                        currentBlock.end = activeBlocks[i].end; 
                    } else {
                        mergedBlocks.push(currentBlock);
                        currentBlock = activeBlocks[i];
                    }
                }
                mergedBlocks.push(currentBlock);
            }

            const hasTaskOnDate = tasks.some(t => getTaskDate(t) === selectedDate);
            if (hasTaskOnDate || mergedBlocks.length > 0) {
                chartData.push({ empName, shift, shiftBlocks, activeBlocks: mergedBlocks });
            }
        });

        chartData.sort((a, b) => {
            if (a.shift !== b.shift) return a.shift.localeCompare(b.shift);
            return a.empName.localeCompare(b.empName);
        });

        return chartData;
    }, [allAssignments, selectedDate, currentTime]);

