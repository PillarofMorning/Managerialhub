                                            title={`Double Click to Edit\nUID: ${shortUid} | ${renderSafe(sch.craa5_product || sch.craa5_Product)} (${sd.toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'})} - ${ed.toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'})})`}
                                        >
                                            {isMultiDay && <div className="absolute right-1 top-1/2 -translate-y-1/2 text-blue-300 text-[10px]">►</div>}
                                            
                                            <div className="flex justify-between items-start gap-1">
