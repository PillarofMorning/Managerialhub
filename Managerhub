    const handleCreateProductionSchedule = async () => {
        if (!schPayload.area || !schPayload.product || !schPayload.startDate) { 
            setSchSubmitStatus({ type: 'error', message: 'Area, Product, and Start Date are required.' });
            return; 
        }
        setSchSubmitStatus(null);
        setIsSubmittingSch(true);
        const writeApi = dataApi?.createRecord ? dataApi : safeGetXrm()?.WebApi;
        if (!writeApi) { 
            setSchSubmitStatus({ type: 'error', message: 'No Dataverse Write API available in this environment. (Preview Mode)' });
            setIsSubmittingSch(false); 
            return; 
        }

        try {
            let ops = [];
            const baseStart = new Date(`${schPayload.startDate}T${schPayload.startTime}:00`);
            const baseEnd = new Date(`${schPayload.endDate}T${schPayload.endTime}:00`);
            const durationMs = baseEnd.getTime() - baseStart.getTime();

            const buildAndSendPayload = (sTime, eTime) => {
                const logicalPayload = {
                    craa5_area: schPayload.area,
                    craa5_line: parseInt(schPayload.line, 10) || 1,
                    craa5_productcode: parseInt(schPayload.productCode, 10) || null,
                    craa5_product: schPayload.product,
                    craa5_datestarttime: sTime.toISOString(),
                    craa5_dateendtime: eTime.toISOString(),
                    craa5_allergen: schPayload.allergen,
                    craa5_crumbclean: schPayload.crumbClean,
                    craa5_typeofallergen: schPayload.allergen ? schPayload.typeOfAllergen : ""
                };
                return writeApi.createRecord(TABLE_PROD, logicalPayload).then(res => ({id: res?.id, ...logicalPayload}));
            };

            if (schPayload.isRecurring) {
                if (schPayload.recurType === 'daily') {
                    const daysToLoop = parseInt(schPayload.recurDays, 10) || 1;
                    for (let i = 0; i < daysToLoop; i++) {
                        const curStart = new Date(baseStart.getTime() + (i * 86400000));
                        const curEnd = new Date(curStart.getTime() + durationMs);
                        ops.push(buildAndSendPayload(curStart, curEnd));
                    }
                } else if (schPayload.recurType === 'weekly') {
                    const targetDow = parseInt(schPayload.recurDayOfWeek, 10);
                    const endOfYear = new Date(baseStart.getFullYear(), 11, 31, 23, 59, 59);
                    let curStart = new Date(baseStart);
                    while (curStart.getDay() !== targetDow) curStart.setDate(curStart.getDate() + 1);
                    while (curStart <= endOfYear) {
                        const curEnd = new Date(curStart.getTime() + durationMs);
                        ops.push(buildAndSendPayload(curStart, curEnd));
                        curStart.setDate(curStart.getDate() + 7);
                    }
                }
            } else {
                ops.push(buildAndSendPayload(baseStart, baseEnd));
            }

            const results = await Promise.all(ops);
            setProdSchedules(p => [...p, ...results]);
            setSchSubmitStatus({ type: 'success', message: `Successfully scheduled ${ops.length} production run(s).` });
            setTimeout(() => {
                setSchPayload({ 
                    area: "", line: "1", productCode: "", product: "", 
                    startDate: selectedDate, startTime: "06:00", 
                    endDate: selectedDate, endTime: "14:00", runLength: "8",
                    isRecurring: false, recurType: "daily", recurDays: 1, recurDayOfWeek: new Date(selectedDate).getDay().toString(),
                    allergen: false, crumbClean: false, typeOfAllergen: ""
                });
                setSchSubmitStatus(null);
            }, 3000);

        } catch (e) {
            console.error(e); 
            setSchSubmitStatus({ type: 'error', message: e.message || 'Failed to save to Dataverse.' });
        } finally { setIsSubmittingSch(false); }
    };

