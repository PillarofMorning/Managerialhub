                                    <div className="absolute top-1 left-2 text-xs font-bold text-gray-800">
                                        {curDate.toLocaleDateString([], {weekday: 'short', month: 'numeric', day: 'numeric'})}
                                    </div>
                                    <div className="absolute left-[25%] bottom-0 text-[9px] font-bold text-gray-500 -translate-x-1/2 pb-0.5">6 AM</div>
                                    <div className="absolute left-[75%] bottom-0 text-[9px] font-bold text-gray-500 -translate-x-1/2 pb-0.5">6 PM</div>
                                </div>
                            )
                        })}
                    </div>

                    <div className="flex flex-col gap-2 relative">
                        {/* Background Grid Lines */}
                        <div className="absolute inset-0 left-[150px] flex pointer-events-none z-0">
                            {Array.from({length: ganttZoomDays}).map((_, dayIdx) => {
                                const isEven = dayIdx % 2 === 0;
                                const bgClass = isEven ? 'bg-transparent' : 'bg-blue-50/30';
                                return (
                                    <div key={dayIdx} className={`relative h-full border-l border-gray-300 ${bgClass}`} style={{ width: `${100 / ganttZoomDays}%` }}>
                                        <div className="absolute top-0 bottom-0 left-[25%] border-l border-dashed border-gray-400 opacity-40"></div>
                                        <div className="absolute top-0 bottom-0 left-[75%] border-l border-dashed border-gray-400 opacity-40"></div>
                                    </div>
                                )
                            })}
                        </div>

                        {Object.entries(ganttSchedules).sort(([a],[b]) => a.localeCompare(b)).map(([areaLineStr, schList]) => {
                            const [y, m, d] = selectedDate.split('-');
                            const baseStartMs = new Date(y, m - 1, d, 0, 0, 0).getTime();
                            const totalWindowMs = ganttZoomDays * 24 * 3600000;
                            const baseEndMs = baseStartMs + totalWindowMs;

                            // Get ALL runs for this line globally to determine accurate gaps before window starts
                            const allRunsInArea = prodSchedules
                                .filter(s => getAreaLine(s) === areaLineStr)
                                .sort((a,b) => new Date(a.craa5_datestarttime || a.craa5_starttime).getTime() - new Date(b.craa5_datestarttime || b.craa5_starttime).getTime());

                            const rawBlocks = [];
                            let currentMs = baseStartMs;
                            let lastRunInArea = allRunsInArea.filter(s => new Date(s.craa5_dateendtime || s.craa5_endtime).getTime() <= currentMs).pop();

                            schList.forEach(sch => {
                                const sTime = new Date(sch.craa5_datestarttime || sch.craa5_Datestarttime || sch.craa5_starttime).getTime();
                                const eTime = new Date(sch.craa5_dateendtime || sch.craa5_Dateendtime || sch.craa5_endtime).getTime();
                                
                                const clampedStart = Math.max(sTime, baseStartMs);
                                const clampedEnd = Math.min(eTime, baseEndMs);

                                if (clampedStart > currentMs) {
                                    let isAllergen = lastRunInArea ? (lastRunInArea.craa5_allergen === true || lastRunInArea.craa5_allergen === 1) : false;
                                    let trueGapHrs = lastRunInArea ? (sTime - new Date(lastRunInArea.craa5_dateendtime || lastRunInArea.craa5_endtime).getTime()) / 3600000 : 99;

                                    rawBlocks.push({ 
                                        type: 'sanitation', 
                                        start: currentMs, end: clampedStart,
                                        isAllergenClean: isAllergen,
                                        isShortAllergen: isAllergen && trueGapHrs <= 8
                                    });
                                }

                                if (clampedEnd > clampedStart) {
                                    let chunkStart = clampedStart;
                                    while (chunkStart < clampedEnd) {
                                        let chunkEnd = Math.min(clampedEnd, chunkStart + 24 * 3600000);
                                        rawBlocks.push({
                                            type: 'production',
                                            sch, start: chunkStart, end: chunkEnd,
                                            productName: renderSafe(sch.craa5_product || sch.craa5_Product)
                                        });
                                        chunkStart = chunkEnd;
                                    }
                                }
                                currentMs = Math.max(currentMs, clampedEnd);
                                lastRunInArea = sch;
                            });

                            if (currentMs < baseEndMs) {
                                let isAllergen = lastRunInArea ? (lastRunInArea.craa5_allergen === true || lastRunInArea.craa5_allergen === 1) : false;
                                const nextRun = allRunsInArea.find(s => new Date(s.craa5_datestarttime || s.craa5_starttime).getTime() >= baseEndMs);
                                let trueGapHrs = (nextRun && lastRunInArea) ? (new Date(nextRun.craa5_datestarttime || nextRun.craa5_starttime).getTime() - new Date(lastRunInArea.craa5_dateendtime || lastRunInArea.craa5_endtime).getTime()) / 3600000 : 99;

                                rawBlocks.push({ 
                                    type: 'sanitation', 
                                    start: currentMs, end: baseEndMs,
                                    isAllergenClean: isAllergen,
                                    isShortAllergen: isAllergen && trueGapHrs <= 8
                                });
                            }

                            // Final pass to calculate durations
                            const blocks = rawBlocks.map(b => {
                                if (b.type === 'sanitation') {
                                    let hrs = ((b.end - b.start) / 3600000).toFixed(1);
                                    if (hrs.endsWith('.0')) hrs = hrs.slice(0, -2);
                                    return { ...b, durationHrs: hrs };
                                }
                                return b;
                            });

                            return (
                                <div key={areaLineStr} className="flex items-stretch min-h-[50px] border-b border-dashed border-gray-300 z-10 hover:bg-gray-50/80">
                                    <div className="w-[150px] p-2 flex-shrink-0 border-r-2 border-gray-300 flex items-center bg-white z-20">
                                        <span className="font-bold text-sm text-gray-800 leading-tight">{areaLineStr}</span>
                                    </div>
                                    
                                    <div className="flex-1 relative">
                                        {blocks.map((block, idx) => {
                                            const leftPct = ((block.start - baseStartMs) / totalWindowMs) * 100;
                                            const widthPct = ((block.end - block.start) / totalWindowMs) * 100;
                                            
                                            if (block.type === 'sanitation') {
                                                let bgClass = 'bg-teal-50 border-teal-200 text-teal-800';
                                                let bgGradient = 'repeating-linear-gradient(45deg, transparent, transparent 5px, rgba(0,128,128,0.05) 5px, rgba(0,128,128,0.05) 10px)';
                                                let label = `Sanitation (${block.durationHrs}h)`;

                                                if (block.isAllergenClean) {
                                                    if (block.isShortAllergen) {
                                                        bgClass = 'bg-purple-100 border-purple-400 text-purple-900';
                                                        bgGradient = 'repeating-linear-gradient(45deg, transparent, transparent 5px, rgba(128,0,128,0.05) 5px, rgba(128,0,128,0.05) 10px)';
                                                        label = `Allergen Clean (<8h) - ${block.durationHrs}h`;
                                                    } else {
                                                        bgClass = 'bg-yellow-100 border-yellow-400 text-yellow-900';
                                                        bgGradient = 'repeating-linear-gradient(45deg, transparent, transparent 5px, rgba(202,138,4,0.1) 5px, rgba(202,138,4,0.1) 10px)';
                                                        label = `Allergen Clean (${block.durationHrs}h)`;
                                                    }
                                                }
                                                return (
                                                    <div key={`sanitation-${idx}`} 
                                                         className={`absolute top-0.5 bottom-0.5 rounded-sm text-[9px] font-bold px-1.5 py-0.5 flex items-center overflow-hidden z-0 border ${bgClass}`}
                                                         style={{ left: `${leftPct}%`, width: `${widthPct}%`, backgroundImage: bgGradient }}
                                                         title={`${label} (${new Date(block.start).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'})} - ${new Date(block.end).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'})})`}>
                                                        <span className="truncate opacity-80 leading-tight">{label}</span>
                                                    </div>
                                                );
                                            } else {
                                                const isMaint = block.productName.toLowerCase().includes('maintenance');
                                                const hasAllergen = block.sch.craa5_allergen === true || block.sch.craa5_allergen === 1;
                                                const hasCrumb = block.sch.craa5_crumbclean === true || block.sch.craa5_crumbclean === 1 || block.sch.craa5_CrumbClean === true;
                                                
                                                let bgClass = hasAllergen ? 'bg-orange-500 border-orange-700 text-white' : 'bg-blue-500 border-blue-600 text-white';
                                                if (isMaint) bgClass = 'bg-black border-gray-800 text-white';

                                                let displayLabel = isMaint ? 'MAINTENANCE' : block.productName;

                                                return (
                                                    <div key={`prod-${idx}`} 
                                                         onDoubleClick={() => openEditDialog(block.sch)}
                                                         className={`absolute top-0.5 bottom-0.5 rounded-sm shadow-sm text-[10px] font-medium px-1.5 py-0.5 flex flex-col justify-center overflow-hidden cursor-pointer hover:brightness-110 transition border z-10 ${bgClass}`}
                                                         style={{ left: `${leftPct}%`, width: `${widthPct}%` }}
                                                         title={`Double-Click to Edit\n${block.productName} (${new Date(block.start).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'})} - ${new Date(block.end).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'})})`}>
                                                        <span className="truncate leading-tight">{displayLabel}</span>
                                                        {hasAllergen && !isMaint && widthPct > 10 && <span className="text-[8px] opacity-90 truncate leading-none uppercase font-bold tracking-wider mt-px">Allergen</span>}
                                                    </div>
                                                );
                                            }
                                        })}
                                    </div>
                                </div>
                            )
                        })}
                    </div>
                </div>
            </div>
        </div>
    );

