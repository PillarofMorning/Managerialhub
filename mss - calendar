            newMap.set(`${aNorm}|${lDate}`, l);
            mappedLogIds.add(l.craa5__log_id || l.craa5_uid);
          }
        });
      });

      fetchedLogs.forEach(l => {
        if (!mappedLogIds.has(l.craa5__log_id || l.craa5_uid)) unmapped.push(l);
      });

      setAssets(fetchedAssets);
      setLogs(fetchedLogs);
      setCompletionMap(newMap);
      setUnmappedLogs(unmapped);
      
      const initialExpands = {};
      fetchedAssets.forEach(a => {
        const r = safeString(getProp(a, 'craa5_roomname')) || '[Unassigned Room]';
        initialExpands[r] = true;
      });
      setExpandedKeys(initialExpands);
      setLoadProgress(100);
