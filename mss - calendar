    while (cur.getFullYear() === anchorYear) {
      const mIdx = cur.getMonth();
      const isVisible = visibleMonths.includes(mIdx);

      if (isVisible) {
          days.push({
            dateStr: normalizeDateStr(cur),
            dayNum: cur.getDate(),
            month: MONTHS[mIdx],
            monthIdx: mIdx,
            week: getWeekNumber(cur),
            label: cur.toLocaleDateString('en-US', { weekday: 'short' }) + ' ' + cur.getDate(),
            isToday: normalizeDateStr(cur) === normalizeDateStr(today)
