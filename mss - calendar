        </div>

        <div className="flex items-center justify-between">
          <div className="flex">
            <button className={`tab-btn ${activeTab === 'master' ? 'active' : ''}`} onClick={() => setActiveTab('master')}>Master MSS</button>
            <button className={`tab-btn ${activeTab === 'snapshot' ? 'active' : ''}`} onClick={() => setActiveTab('snapshot')}>Daily Snapshot</button>
          </div>
          <div className="flex items-center gap-4">
             <button style={{ color: '#107c41', background: 'transparent', border: 'none', cursor: 'pointer', fontSize: '11px', fontWeight: 'bold' }} onClick={copyToExcel}>COPY TSV</button>
             {activeTab === 'snapshot' && (
              <div style={{ display: 'flex', alignItems: 'center', gap: '12px', background: '#fff', border: '1px solid #e2e8f0', borderRadius: '6px', padding: '2px 12px', marginBottom: '8px' }}>
                <span style={{ fontSize: '10px', fontWeight: 'bold', color: '#64748b' }}>RANGE:</span>
                <input type="date" value={snapshotStart} onChange={e => setSnapshotStart(e.target.value)} style={{ border: 'none', outline: 'none', fontSize: '11px', fontWeight: 'bold' }} />
                <ChevronRightIcon />
                <input type="date" value={snapshotEnd} onChange={e => setSnapshotEnd(e.target.value)} style={{ border: 'none', outline: 'none', fontSize: '11px', fontWeight: 'bold' }} />
              </div>
            )}
          </div>
        </div>

        {/* PROGRESS BAR */}
        {isLoading && (
          <div className="progress-bar-container">
            <div className="progress-bar-fill" style={{ width: `${loadProgress}%` }}></div>
          </div>
        )}
      </header>

      {/* MASTER GRID VIEWPORT */}
      <main className="matrix-outer-container">
        <div className="viewport-scroll-area custom-scrollbar">
          
          <div className="sticky-header-tier shadow-sm">
            <div className="frozen-top-left">FACILITY NAVIGATOR</div>
            <div className="header-rows-wrapper">
              <div className="tier-row">
                {timelineData.map(m => (
                  <div key={`${m.label}-${m.year}`} onClick={() => setExpandedHeaderKeys(p => ({ ...p, [`m-${m.index}`]: !p[`m-${m.index}`] }))} 
                    className={`cell-month ${m.isToday ? 'today-track' : ''}`} style={{ width: `${getMonthTotalWidth(m)}px` }}>
                    {expandedHeaderKeys[`m-${m.index}`] ? <ChevronDownIcon /> : <ChevronRightIcon />} {m.label}
                  </div>
                ))}
              </div>
              <div className="tier-row">
                {timelineData.map(m => expandedHeaderKeys[`m-${m.index}`] ? m.weeks.map(w => (
                  <div key={w.weekNum} onClick={() => setExpandedHeaderKeys(p => ({ ...p, [`w-${w.weekNum}`]: !p[`w-${w.weekNum}`] }))} 
                    className={`cell-week ${w.days.some(d => d.isToday) ? 'today-track' : ''}`} style={{ width: `${getWeekTotalWidth(w)}px` }}>
                    {expandedHeaderKeys[`w-${w.weekNum}`] ? <ChevronDownIcon /> : <ChevronRightIcon />} Wk {w.weekNum}
                  </div>
                )) : <div key={`sp-m-${m.index}`} className="cell-spacer" style={{ width: `${moSlotW}px` }} />)}
              </div>
              <div className="tier-row">
                {timelineData.map(m => expandedHeaderKeys[`m-${m.index}`] ? m.weeks.map(w => expandedHeaderKeys[`w-${w.weekNum}`] ? w.days.map((d, i) => (
                  <div key={i} className={`cell-day ${d.isToday ? 'today-track' : ''}`} style={{ width: `${colW}px` }}>{d.day}</div>
                )) : <div key={`sp-w-${w.weekNum}`} className="cell-spacer" style={{ width: `${wkSlotW}px`, background: '#f8fafc' }} />) : <div key={`sp-d-${m.index}`} className="cell-spacer" style={{ width: `${moSlotW}px`, background: '#f8fafc' }} />)}
              </div>
            </div>
          </div>

          <div className="body-rows-wrapper">
            {assets.length === 0 && !isLoading ? (
              <div style={{ padding: '40px', color: '#94a3b8', textAlign: 'center', width: '320px' }}>No Data. Please click Sync.</div>
            ) : (
              Object.keys(filteredTreeData).map(room => {
                const roomAssets = Object.values(filteredTreeData[room]).flat();
                return (
                <React.Fragment key={room}>
                  <div className="asset-row" style={{ background: '#f1f5f9' }}>
                    <div className="frozen-label-cell" style={{ background: '#f1f5f9' }} onClick={() => setExpandedKeys(p => ({ ...p, [room]: !p[room] }))}>
                      {expandedKeys[room] ? <ChevronDownIcon /> : <ChevronRightIcon />} <FolderIcon color="#1e40af" /> <span style={{ fontWeight: 'bold' }}>{room}</span>
                    </div>
                    <div className="data-cells-container">
                      {timelineData.map(m => {
                        if (!expandedHeaderKeys[`m-${m.index}`]) {
                          return <div key={m.index} className="data-cell" style={{ width: `${moSlotW}px` }}>{checkCompliance(roomAssets, 'month', m.index, true) ? <CheckCircleIcon style={{ width: '14px' }} /> : <div className="dot-none" />}</div>;
                        }
                        return m.weeks.map(w => {
                          if (!expandedHeaderKeys[`w-${w.weekNum}`]) {
                            return <div key={w.weekNum} className="data-cell" style={{ width: `${wkSlotW}px` }}>{checkCompliance(roomAssets, 'week', w.weekNum, true) ? <CheckCircleIcon style={{ width: '10px' }} /> : <div className="dot-none" />}</div>;
                          }
                          return w.days.map((d, i) => (
                            <div key={i} className={`data-cell ${d.isToday ? 'today-track' : ''}`} style={{ width: `${colW}px` }}>
                              {logs.some(l => roomAssets.some(ra => isFuzzyMatch(safeString(getProp(ra, 'craa5_equipmentidentifier')), safeString(getProp(l, 'craa5_equipment')))) && normalizeDateStr(getProp(l, 'craa5_lastcleaned')) === d.dateStr) ? <div className="dot" /> : <div className="dot-none" />}
                            </div>
                          ));
                        });
                      })}
                    </div>
                  </div>

                  {expandedKeys[room] && Object.keys(filteredTreeData[room]).map(area => {
                    const ak = `${room}-${area}`;
                    const areaAssets = filteredTreeData[room][area];
                    return (
                      <React.Fragment key={area}>
                        <div className="asset-row" style={{ background: '#fdfdfd' }}>
                          <div className="frozen-label-cell" style={{ paddingLeft: '32px', background: '#fdfdfd' }} onClick={() => setExpandedKeys(p => ({ ...p, [ak]: !p[ak] }))}>
                            {expandedKeys[ak] ? <ChevronDownIcon /> : <ChevronRightIcon />} <FolderIcon color="#10b981" /> <span style={{ fontWeight: '700' }}>{area}</span>
                          </div>
                          <div className="data-cells-container">
                            {timelineData.map(m => {
                              if (!expandedHeaderKeys[`m-${m.index}`]) {
                                return <div key={m.index} className="data-cell" style={{ width: `${moSlotW}px` }}>{checkCompliance(areaAssets, 'month', m.index, true) ? <CheckCircleIcon style={{ width: '14px' }} /> : <div className="dot-none" />}</div>;
                              }
                              return m.weeks.map(w => {
                                if (!expandedHeaderKeys[`w-${w.weekNum}`]) {
                                  return <div key={w.weekNum} className="data-cell" style={{ width: `${wkSlotW}px` }}>{checkCompliance(areaAssets, 'week', w.weekNum, true) ? <CheckCircleIcon style={{ width: '10px' }} /> : <div className="dot-none" />}</div>;
                                }
                                return w.days.map((d, i) => (
                                  <div key={i} className={`data-cell ${d.isToday ? 'today-track' : ''}`} style={{ width: `${colW}px` }}>
                                    {logs.some(l => areaAssets.some(aa => isFuzzyMatch(safeString(getProp(aa, 'craa5_equipmentidentifier')), safeString(getProp(l, 'craa5_equipment')))) && normalizeDateStr(getProp(l, 'craa5_lastcleaned')) === d.dateStr) ? <div className="dot" /> : <div className="dot-none" />}
                                  </div>
                                ));
                              });
                            })}
                          </div>
                        </div>

                        {expandedKeys[ak] && areaAssets.map(asset => {
                          const name = safeString(getProp(asset, 'craa5_equipmentidentifier'));
                          return (
                            <div key={asset.craa5_aa_assetsid} className="asset-row">
                              <div className="frozen-label-cell" style={{ paddingLeft: '54px' }}><FileIcon /> {name}</div>
                              <div className="data-cells-container">
                                  {timelineData.map(m => {
                                    if (!expandedHeaderKeys[`m-${m.index}`]) {
                                      return <div key={m.index} className="data-cell" style={{ width: `${moSlotW}px` }}>{checkCompliance(name, 'month', m.index) ? <CheckCircleIcon style={{ width: '14px' }} /> : <div className="dot-none" />}</div>;
                                    }
                                    return m.weeks.map(w => {
                                      if (!expandedHeaderKeys[`w-${w.weekNum}`]) {
                                        return <div key={w.weekNum} className="data-cell" style={{ width: `${wkSlotW}px` }}>{checkCompliance(name, 'week', w.weekNum) ? <div className="dot" /> : <div className="dot-none" />}</div>;
                                      }
                                      return w.days.map((d, i) => {
                                        const match = logs.find(l => isFuzzyMatch(name, safeString(getProp(l, 'craa5_equipment'))) && normalizeDateStr(getProp(l, 'craa5_lastcleaned')) === d.dateStr);
                                        return (
                                          <div key={i} className={`data-cell ${d.isToday ? 'today-track' : ''}`} style={{ width: `${colW}px` }}>
                                            {match ? <div className="dot" onMouseEnter={() => setHoveredLog(match)} onMouseLeave={() => setHoveredLog(null)} /> : <div className="dot-none" />}
                                          </div>
                                        );
                                      });
                                    });
                                  })}
                              </div>
                            </div>
                          );
                        })}
                      </React.Fragment>
                    );
                  })}
                </React.Fragment>
              );})
            )}
          </div>
        </div>
      </main>

      {/* DIAGNOSTICS */}
      <div className="dev-console shrink-0 flex flex-col" style={{ height: isConsoleOpen ? '160px' : '36px', background: '#1e1e1e' }}>
        <div className="flex items-center justify-between px-4 h-[35px] border-b border-white/5" style={{ background: '#252525' }}>
          <div className="flex items-center" style={{ gap: '8px', cursor: 'pointer' }} onClick={() => setIsConsoleOpen(!isConsoleOpen)}>
            <TerminalIcon style={{ color: '#94a3b8' }} /> <span style={{ fontSize: '10px', fontWeight: 'bold', color: '#e2e8f0', letterSpacing: '1px' }}>DIAGNOSTICS</span>
          </div>
          <button style={{ background: 'none', border: 'none', color: '#666', cursor: 'pointer' }} onClick={() => setIsConsoleOpen(!isConsoleOpen)}>{isConsoleOpen ? <ChevronDownIcon /> : <ChevronUpIcon />}</button>
        </div>
        {isConsoleOpen && <div className="flex-1 overflow-auto p-3 font-mono custom-scrollbar" style={{ fontSize: '10px' }}>{consoleLogs.map(l => (<div key={l.id}><span style={{ color: '#666' }}>[{l.timestamp}]</span> <span style={{ color: l.level === 'error' ? '#f87171' : '#4ade80', margin: '0 8px' }}>[{l.level.toUpperCase()}]</span> <span style={{ color: '#aaa' }}>{l.message}</span></div>))}<div ref={logsEndRef} /></div>}
      </div>
      <style>{` @keyframes spin { 100% { transform:rotate(360deg); } } `}</style>
    </div>
  );
}
