// --- HELPERS ---

const getProp = (obj, targetKey) => {
  if (!obj || !targetKey) return null;
  const lowerTarget = targetKey.toLowerCase();
  const formattedKey = `${targetKey}@OData.Community.Display.V1.FormattedValue`;
  if (obj[formattedKey] !== undefined) return obj[formattedKey];
  const internalFormattedKey = `_${targetKey}_value@OData.Community.Display.V1.FormattedValue`;
  if (obj[internalFormattedKey] !== undefined) return obj[internalFormattedKey];
  if (obj[targetKey] !== undefined) {
    const val = obj[targetKey];
    if (val && typeof val === 'object' && val.name) return val.name;
    return val;
  }
  const foundKey = Object.keys(obj).find(k => k.toLowerCase() === lowerTarget);
  if (foundKey) {
    const val = obj[foundKey];
    if (val && typeof val === 'object' && val.name) return val.name;
    return val;
  }
  return null;
};

const safeString = (val) => {
  if (val === null || val === undefined) return '';
  return String(val).trim();
};

const normalizeName = (s) => (s || "").toLowerCase().replace(/[^a-z0-9]/g, '');

const isLenientMatch = (assetName, logName) => {
  const a = normalizeName(assetName);
  const l = normalizeName(logName);
  if (!a || !l) return false;
  return a === l || a.includes(l) || l.includes(a);
};

const normalizeDateStr = (d) => {
  if (!d) return "";
  const dateObj = new Date(d);
  if (isNaN(dateObj.getTime())) return "";
  const year = dateObj.getFullYear();
  const month = String(dateObj.getMonth() + 1).padStart(2, '0');
  const day = String(dateObj.getDate()).padStart(2, '0');
  return `${year}-${month}-${day}`;
};

const getWeekNumber = (d) => {
  const date = new Date(Date.UTC(d.getFullYear(), d.getMonth(), d.getDate()));
  date.setUTCDate(date.getUTCDate() + 4 - (date.getUTCDay() || 7));
  const yearStart = new Date(Date.UTC(date.getUTCFullYear(), 0, 1));
  return Math.ceil((((date - yearStart) / 86400000) + 1) / 7);
};

const MONTHS = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];

